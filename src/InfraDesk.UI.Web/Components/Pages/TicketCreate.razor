@* Dateipfad: src/InfraDesk.UI.Web/Components/Pages/TicketCreate.razor *@
@page "/tickets/create"
@page "/tickets/edit/{Id:guid}"
@using InfraDesk.Core.Entities
@using MudBlazor
@using System.Text
@using System.Text.Json
@using System.IO
@inject HttpClient Http
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject IJSRuntime JSRuntime
@implements IAsyncDisposable

<PageTitle>InfraDesk - @(IsEditMode ? "Ticket bearbeiten" : "Neues Ticket anlegen")</PageTitle>

<style>
    .pdq-container { background-color: #fff; height: calc(100vh - 150px); display: flex; flex-direction: row; border: 1px solid #ccc; border-radius: 0 0 4px 4px; border-top: none; overflow: hidden; }
    .pdq-sidebar { width: 240px; border-right: 1px solid #ccc; background-color: #f0f0f0; overflow-y: auto; flex-shrink: 0; }
    .pdq-content { flex-grow: 1; overflow-y: auto; background-color: #fff; padding: 24px; }
    
    .pdq-section-header { background-color: #e0e0e0; padding: 4px 12px; font-weight: 800; font-size: 0.75rem; text-transform: uppercase; border-bottom: 1px solid #ccc; border-top: 1px solid #ccc; color: #333; margin-bottom: 16px; margin-top: 24px; }
    .pdq-section-header:first-child { margin-top: 0; border-top: none; }
    
    .pdq-toolbar { height: 48px; background-color: #eee; border: 1px solid #ccc; border-radius: 4px 4px 0 0; display: flex; align-items: center; padding: 0 16px; margin-top: 24px; }
    
    .wizard-step { padding: 12px 16px; display: flex; align-items: center; border-bottom: 1px solid #e8e8e8; color: #555; transition: background-color 0.2s; cursor: pointer; }
    .wizard-step.active { background-color: #fff; border-left: 4px solid var(--mud-palette-primary); font-weight: bold; color: var(--mud-palette-primary); }
    .wizard-step.completed { color: var(--mud-palette-success); }
    .wizard-step:hover { background-color: #e6e6e6; }

    /* Drag & Drop File Upload Zone */
    .file-dropzone-container { position: relative; border: 1px solid #e0e0e0; border-radius: 4px; padding: 20px 24px; background-color: #f8f9fa; text-align: left; transition: all 0.2s ease-in-out; width: 100%; overflow: hidden; }
    .file-dropzone-container:hover, .file-dropzone-container.drag-active { border-color: var(--mud-palette-primary); background-color: #f0f4f8; }
    .file-dropzone-input { position: absolute; width: 100%; height: 100%; top: 0; left: 0; opacity: 0; cursor: pointer; z-index: 10; }
    .file-dropzone-title { margin: 0 0 6px 0; font-size: 1.35rem; font-weight: 400; color: #222; }
    .file-dropzone-subtitle { margin: 0; font-size: 0.9rem; color: #555; }

    /* Inline Rich Text Editor */
    .rich-editor { min-height: 120px; max-height: 400px; overflow-y: auto; border: 1px solid #ccc; border-radius: 4px; padding: 12px; background-color: #fff; font-family: Roboto, sans-serif; font-size: 0.875rem; color: #333; outline: none; transition: border-color 0.2s; line-height: 1.5; }
    .rich-editor:focus { border-color: var(--mud-palette-primary); box-shadow: 0 0 0 1px var(--mud-palette-primary); }
    .rich-editor:empty:not(:focus):before { content: attr(data-placeholder); color: #999; pointer-events: none; }
</style>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="px-8">

    <div class="pdq-toolbar">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" OnClick="@(() => Nav.NavigateTo("/tickets"))" Size="Size.Small" Class="mr-2" />
        <MudIcon Icon="@Icons.Material.Filled.AddComment" Color="Color.Primary" Size="Size.Small" Class="mr-2" />
        <MudText Typo="Typo.body2" Class="font-weight-bold">@(IsEditMode ? "Ticket bearbeiten" : "Neues Ticket anlegen")</MudText>
        
        <MudSpacer />
        
        <MudButton Disabled="@(_currentStepIndex == 0)" OnClick="PrevStep" Variant="Variant.Outlined" Size="Size.Small" Class="mr-2" Style="background-color: white;">Zurück</MudButton>
        @if (_currentStepIndex < ActiveSteps.Count - 1)
        {
            <MudButton OnClick="NextStep" Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" Disabled="@(!CanProceed())">Weiter</MudButton>
        }
        else
        {
            <MudButton OnClick="SubmitTicket" Variant="Variant.Filled" Color="Color.Success" Size="Size.Small" StartIcon="@Icons.Material.Filled.Save" Disabled="@(!CanProceed() || _isSaving)">
                @if (_isSaving) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2"/> }
                Ticket speichern
            </MudButton>
        }
    </div>

    <div class="pdq-container">
        <div class="pdq-sidebar">
            <div class="pdq-section-header" style="margin-bottom: 0;">Erstellungsprozess</div>
            
            @for (int i = 0; i < ActiveSteps.Count; i++)
            {
                int index = i;
                var step = ActiveSteps[index];
                bool isActive = index == _currentStepIndex;
                bool isCompleted = index < _currentStepIndex;

                <div class="wizard-step @(isActive ? "active" : "") @(isCompleted ? "completed" : "")" @onclick="@(() => JumpToStep(index))">
                    <MudIcon Icon="@(isCompleted ? Icons.Material.Filled.CheckCircle : step.Icon)" Size="Size.Small" Class="mr-3" />
                    <span style="font-size: 0.85rem;">@step.Name</span>
                </div>
            }
        </div>

        <div class="pdq-content">
            @if (_isLoading)
            {
                <div class="d-flex justify-center align-center" style="height: 100%;"><MudProgressCircular Color="Color.Primary" Indeterminate="true" /></div>
            }
            else
            {
                var currentStepDef = ActiveSteps[_currentStepIndex];

                @if (currentStepDef.Id == "Basics")
                {
                    <div class="pdq-section-header">1. Problembeschreibung</div>
                    
                    <MudGrid Spacing="2" Class="mb-6">
                        <MudItem xs="12">
                            <MudTextField @bind-Value="_newTicket.Title" Label="Kurzbeschreibung (Betreff) *" Variant="Variant.Outlined" Margin="Margin.Dense" Required="true" AutoFocus="true" />
                        </MudItem>
                        <MudItem xs="12">
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-1 d-block">
                                <MudIcon Icon="@Icons.Material.Filled.ContentPaste" Size="Size.Small" Class="mr-1" Style="vertical-align: middle;" />
                                Sie können Screenshots direkt mit Strg+V einfügen oder Dateien unten anhängen.
                            </MudText>
                            
                            <div id="ticket-desc-wrapper">
                                <!-- Leere Hülle: Isoliert das JS vom Blazor Virtual DOM, wodurch keine Abstürze mehr entstehen -->
                                <div id="ticket-desc-container" data-placeholder="Bitte beschreiben Sie das Problem oder Ihre Anfrage hier so detailliert wie möglich..."></div>
                            </div>
                            
                            <div class="mt-3">
                                <div class="file-dropzone-container @(_dragActive ? "drag-active" : "")"
                                     @ondragenter="@(() => _dragActive = true)"
                                     @ondragleave="@(() => _dragActive = false)"
                                     @ondrop="@(() => _dragActive = false)"
                                     ondragover="event.preventDefault();">
                                    
                                    <InputFile id="hidden-file-input" OnChange="UploadFiles" multiple class="file-dropzone-input" />
                                    
                                    <h4 class="file-dropzone-title">Dokumente hinzufügen</h4>
                                    <p class="file-dropzone-subtitle">Dateien zum Upload (auch mehrere) hier hereinziehen oder klicken zur Dateiauswahl</p>
                                </div>
                            </div>
                        </MudItem>
                    </MudGrid>

                    <div class="pdq-section-header">Kontakt & Mandant</div>
                    <MudGrid Spacing="2">
                        <MudItem xs="12" md="6">
                            <MudSelect T="Guid?" Label="Gemeldet von (Kontakt) *" @bind-Value="_newTicket.RequesterId" Variant="Variant.Outlined" Margin="Margin.Dense" AnchorOrigin="Origin.BottomCenter" Required="true">
                                @foreach (var p in _availablePersons) { <MudSelectItem T="Guid?" Value="@p.Id">@p.LastName, @p.FirstName</MudSelectItem> }
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudSelect T="Guid" Label="Mandant *" @bind-Value="_newTicket.TenantId" Variant="Variant.Outlined" Margin="Margin.Dense" AnchorOrigin="Origin.BottomCenter" Required="true">
                                @foreach (var t in _tenants) { <MudSelectItem Value="@t.Id">@t.Name</MudSelectItem> }
                            </MudSelect>
                        </MudItem>
                    </MudGrid>
                }

                @if (currentStepDef.Id == "Classification")
                {
                    <div class="pdq-section-header">2. ITIL Kategorisierung</div>
                    
                    <MudGrid Spacing="2" Class="mb-6">
                        <MudItem xs="12" md="6">
                            <MudSelect T="string" Label="Ticket-Typ (ITIL) *" @bind-Value="_newTicket.Category1" Variant="Variant.Outlined" Margin="Margin.Dense" AnchorOrigin="Origin.BottomCenter" Required="true">
                                <MudSelectItem Value="@("Incident (Störung)")"><div class="d-flex align-center"><MudIcon Icon="@Icons.Material.Filled.Bolt" Size="Size.Small" Color="Color.Error" Class="mr-2"/>Incident (Störung)</div></MudSelectItem>
                                <MudSelectItem Value="@("Service Request (Serviceanfrage)")"><div class="d-flex align-center"><MudIcon Icon="@Icons.Material.Filled.ShoppingCart" Size="Size.Small" Color="Color.Info" Class="mr-2"/>Service Request</div></MudSelectItem>
                                <MudSelectItem Value="@("Problem (Problem)")"><div class="d-flex align-center"><MudIcon Icon="@Icons.Material.Filled.Search" Size="Size.Small" Color="Color.Dark" Class="mr-2"/>Problem</div></MudSelectItem>
                                <MudSelectItem Value="@("Change (Änderung)")"><div class="d-flex align-center"><MudIcon Icon="@Icons.Material.Filled.Settings" Size="Size.Small" Color="Color.Warning" Class="mr-2"/>Change</div></MudSelectItem>
                            </MudSelect>
                        </MudItem>
                        
                        <MudItem xs="12" md="6">
                            <MudSelect T="string" Label="Priorität *" @bind-Value="_newTicket.Priority" Variant="Variant.Outlined" Margin="Margin.Dense" AnchorOrigin="Origin.BottomCenter" Required="true">
                                @foreach (var p in _ticketPriorities) {
                                    <MudSelectItem Value="@p.Name">
                                        <div class="d-flex align-center" style="font-weight: bold; color: @p.Color;">
                                            <MudIcon Icon="@GetDynamicIcon(p.Icon)" Size="Size.Small" Class="mr-2"/>@p.Name.ToUpper()
                                        </div>
                                    </MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>
                        
                        <MudItem xs="12" md="6">
                            <MudSelect T="string" Label="Status *" @bind-Value="_newTicket.Status" Variant="Variant.Outlined" Margin="Margin.Dense" AnchorOrigin="Origin.BottomCenter" Required="true">
                                @foreach (var s in _ticketStatuses) {
                                    <MudSelectItem Value="@s.Name">
                                        <div class="d-flex align-center" style="font-weight: bold; color: @s.Color;">
                                            <MudIcon Icon="@GetDynamicIcon(s.Icon)" Size="Size.Small" Class="mr-2"/>@s.Name.ToUpper()
                                        </div>
                                    </MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>

                        <MudItem xs="12" md="6">
                            <MudSelect T="string" Label="Asset-Kategorie" @bind-Value="_newTicket.Category2" Variant="Variant.Outlined" Margin="Margin.Dense" AnchorOrigin="Origin.BottomCenter">
                                @foreach(var type in _dynamicAssetTypes) { <MudSelectItem Value="@type.Name">@type.Name</MudSelectItem> }
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="_newTicket.Category3" Label="Subkategorie (z.B. Softwarename)" Variant="Variant.Outlined" Margin="Margin.Dense" />
                        </MudItem>
                    </MudGrid>

                    <div class="pdq-section-header">Optionale Metadaten</div>
                    <MudGrid Spacing="2">
                        <MudItem xs="12">
                            <MudTextField T="string" @bind-Value="_newTicket.Tags" Label="Schlagworte (Tags)" Placeholder="Hardware, Netzwerk, VIP" HelperText="Komma-getrennt eingeben" Variant="Variant.Outlined" Margin="Margin.Dense" />
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudCheckBox T="bool" @bind-Value="_newTicket.IsInternal" Label="Internes Ticket (Nur für Techniker sichtbar)" Color="Color.Primary" Dense="true" />
                        </MudItem>
                    </MudGrid>
                }

                @if (currentStepDef.Id == "Assets")
                {
                    <div class="pdq-section-header">3. Betroffene Hardware / Assets verknüpfen</div>
                    <MudText Typo="Typo.body2" Class="mb-4" Color="Color.Secondary">Suchen Sie nach betroffenen Geräten und fügen Sie diese dem Ticket hinzu.</MudText>
                    
                    <MudAutocomplete T="Asset" Label="Asset suchen & anfügen..." ValueChanged="AddAsset" 
                                     SearchFunc="SearchAssets" ToStringFunc="@(a => a == null ? null : $"{a.Name} ({a.AssetTag})")" 
                                     Variant="Variant.Outlined" Margin="Margin.Dense" Dense="true" Clearable="true" 
                                     ResetValueOnEmptyText="true" CoerceText="false" CoerceValue="false" Class="mb-6" />

                    @if (_newTicket.AssignedAssets != null && _newTicket.AssignedAssets.Any())
                    {
                        <div class="pdq-section-header">Zugewiesene Assets</div>
                        <MudDataGrid Items="@_newTicket.AssignedAssets" Dense="true" Bordered="true" Elevation="0">
                            <Columns>
                                <PropertyColumn Property="x => x.AssetTag" Title="Tag" />
                                <PropertyColumn Property="x => x.Name" Title="Name" />
                                <TemplateColumn Title="Aktion" CellClass="d-flex justify-end">
                                    <CellTemplate>
                                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" OnClick="@(() => RemoveAsset(context.Item))" />
                                    </CellTemplate>
                                </TemplateColumn>
                            </Columns>
                        </MudDataGrid>
                    }
                    else
                    {
                        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mt-4">Bislang wurden keine Assets verknüpft.</MudAlert>
                    }
                }

                <!-- NEU: Der 4. Schritt für erweiterte Optionen direkt bei der Erstellung -->
                @if (currentStepDef.Id == "Extended")
                {
                    <div class="pdq-section-header">4. Erweiterte Optionen (Optional)</div>
                    <MudText Typo="Typo.body2" Class="mb-4" Color="Color.Secondary">Alle hier aufgeführten Felder sind optional und können auch später im Ticket gesetzt werden.</MudText>
                    
                    <MudGrid Spacing="2" Class="mb-6">
                        <MudItem xs="12" md="6">
                            <MudSelect T="Guid?" Label="Verantwortlicher Entscheider (Genehmigung)" @bind-Value="_newTicket.ApproverId" Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true">
                                @foreach(var p in _availablePersons) { <MudSelectItem T="Guid?" Value="@p.Id">@p.LastName, @p.FirstName</MudSelectItem> }
                            </MudSelect>
                        </MudItem>
                        
                        <MudItem xs="12" md="6">
                            <MudAutocomplete T="Ticket" Label="Untergeordnet zu Master-Ticket..." @bind-Value="SelectedMasterTicket" 
                                             SearchFunc="SearchTickets" ToStringFunc="@(t => t == null ? "" : $"#{t.TicketNumber} {t.Title}")" 
                                             Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true" />
                        </MudItem>
                        
                        <MudItem xs="12" md="6">
                            <MudDatePicker Label="Fällig am (Due Date)" @bind-Date="_newTicket.DueAt" Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true" />
                        </MudItem>
                        
                        <MudItem xs="12" md="6">
                            <MudNumericField T="int" Label="Geschätzter Aufwand (Soll-Minuten)" @bind-Value="_newTicket.EstimatedMinutes" Variant="Variant.Outlined" Margin="Margin.Dense" />
                        </MudItem>

                        <MudItem xs="12">
                            <div class="d-flex align-center justify-space-between mb-2 mt-4 pa-4" style="border: 1px solid #ccc; border-radius: 4px;">
                                <MudText Typo="Typo.subtitle2" Class="font-weight-bold">Eskalationsstufe direkt setzen</MudText>
                                <MudRating @bind-SelectedValue="_newTicket.EscalationLevel" Size="Size.Medium" />
                            </div>
                        </MudItem>
                    </MudGrid>

                    <div class="pdq-section-header">Beobachter (CC / Watchers)</div>
                    <MudGrid Spacing="2">
                        <MudItem xs="12">
                            <MudSelect T="Person" Label="Watcher hinzufügen" ValueChanged="AddWatcher" Variant="Variant.Outlined" Margin="Margin.Dense">
                                @foreach(var p in _availablePersons) { <MudSelectItem Value="@p">@p.FirstName @p.LastName</MudSelectItem> }
                            </MudSelect>
                            
                            @if (_newTicket.Watchers != null && _newTicket.Watchers.Any()) {
                                <MudList T="string" Dense="true" Class="mt-2">
                                    @foreach(var w in _newTicket.Watchers) {
                                        <MudListItem T="string" Icon="@Icons.Material.Filled.Person">
                                            <div class="d-flex align-center w-100">
                                                <MudText Typo="Typo.body2">@w.FirstName @w.LastName</MudText>
                                                <MudSpacer />
                                                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" OnClick="@(() => RemoveWatcher(w))" />
                                            </div>
                                        </MudListItem>
                                    }
                                </MudList>
                            }
                        </MudItem>
                    </MudGrid>
                }
            }
        </div>
    </div>
</MudContainer>

@code {
    [Parameter] public Guid? Id { get; set; }
    private bool IsEditMode => Id.HasValue;

    public class WizardStep { public string Id {get;set;}=""; public string Name {get;set;}=""; public string Icon {get;set;}=""; }
    private List<WizardStep> ActiveSteps = new();
    private int _currentStepIndex = 0;
    
    private bool _isLoading = true;
    private bool _isSaving = false;
    private bool _dragActive = false;
    private bool _hasDescription = false;
    private bool _isSubmitPending = false;
    private bool _editorInitialized = false;
    
    private DotNetObjectReference<TicketCreate>? _objRef;
    private Dictionary<string, StringBuilder> _htmlChunks = new();

    private Ticket _newTicket = new() { 
        Title = "", 
        Description = "",
        Status = "OFFEN", 
        Priority = "Normal",
        Category1 = "Incident (Störung)",
        EscalationLevel = 1,
        AssignedAssets = new List<Asset>(),
        Watchers = new List<Person>()
    };
    
    private List<Person> _availablePersons = new();
    private List<Tenant> _tenants = new();
    private List<AssetType> _dynamicAssetTypes = new();
    private List<Asset> _allAssets = new();
    private List<Ticket> _allTickets = new();

    public class TicketStatusItem { public string Name { get; set; } = ""; public string Color { get; set; } = "#757575"; public string Icon { get; set; } = "Adjust"; }
    public class TicketPriorityItem { public string Name { get; set; } = ""; public string Color { get; set; } = "#333333"; public string Icon { get; set; } = "Flag"; }

    private List<TicketStatusItem> _ticketStatuses = new();
    private List<TicketPriorityItem> _ticketPriorities = new();

    public class SettingsDto {
        public List<TicketStatusItem> TicketStatusList { get; set; } = new();
        public List<TicketPriorityItem> TicketPriorityList { get; set; } = new();
    }

    public Ticket? SelectedMasterTicket {
        get => _newTicket.MasterTicketId.HasValue ? _allTickets.FirstOrDefault(t => t.Id == _newTicket.MasterTicketId) : null;
        set { if (_newTicket.MasterTicketId != value?.Id) { _newTicket.MasterTicketId = value?.Id; } }
    }

    protected override async Task OnInitializedAsync()
    {
        _isLoading = true;
        try
        {
            try { _availablePersons = await Http.GetFromJsonAsync<List<Person>>("api/persons") ?? new(); } catch {}
            try { _tenants = await Http.GetFromJsonAsync<List<Tenant>>("api/tenants") ?? new(); } catch {}
            try { _dynamicAssetTypes = await Http.GetFromJsonAsync<List<AssetType>>("api/assets/types") ?? new(); } catch {}
            try { _allAssets = await Http.GetFromJsonAsync<List<Asset>>("api/assets") ?? new(); } catch {}
            try { _allTickets = await Http.GetFromJsonAsync<List<Ticket>>("api/tickets") ?? new(); } catch {}

            try {
                var settings = await Http.GetFromJsonAsync<SettingsDto>("api/settings/masterdata");
                if (settings != null) {
                    if (settings.TicketStatusList?.Any() == true) _ticketStatuses = settings.TicketStatusList;
                    if (settings.TicketPriorityList?.Any() == true) _ticketPriorities = settings.TicketPriorityList;
                }
            } catch { }

            if (!_ticketStatuses.Any()) _ticketStatuses.Add(new TicketStatusItem { Name = "OFFEN", Color = "#2E7D32", Icon = "Adjust" });
            if (!_ticketPriorities.Any()) _ticketPriorities.Add(new TicketPriorityItem { Name = "Normal", Color = "#1976D2", Icon = "Remove" });

            if (IsEditMode)
            {
                var existing = await Http.GetFromJsonAsync<Ticket>($"api/tickets/{Id}");
                if (existing != null)
                {
                    _newTicket = existing;
                    _newTicket.AssignedAssets ??= new List<Asset>();
                    _newTicket.Watchers ??= new List<Person>();
                    _hasDescription = !string.IsNullOrWhiteSpace(_newTicket.Description);
                }
            }

            if (!_ticketStatuses.Any(s => s.Name == _newTicket.Status)) _newTicket.Status = _ticketStatuses.First().Name;
            if (!_ticketPriorities.Any(p => p.Name == _newTicket.Priority)) _newTicket.Priority = _ticketPriorities.First().Name;

            if (_tenants.Any() && _newTicket.TenantId == Guid.Empty)
            {
                _newTicket.TenantId = _tenants.First().Id;
            }

            RebuildSteps();
        }
        finally { _isLoading = false; }
    }

    private string GetDynamicIcon(string? iconName) {
        if (string.IsNullOrWhiteSpace(iconName)) return Icons.Material.Filled.Label;
        try {
            var field = typeof(Icons.Material.Filled).GetField(iconName);
            if (field != null) return field.GetValue(null)?.ToString() ?? Icons.Material.Filled.Label;
        } catch {}
        return Icons.Material.Filled.Label;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var jsCode = @"
                window.initRichEditor = function(containerId, dotNetRef, initialHtml) { 
                    var container = document.getElementById(containerId); 
                    if(!container) return;
                    
                    if(container.dataset.initialized) return; 
                    container.dataset.initialized = 'true'; 
                    
                    var editor = document.createElement('div');
                    editor.id = containerId + '-inner';
                    editor.className = 'rich-editor';
                    editor.contentEditable = 'true';
                    editor.setAttribute('data-placeholder', container.getAttribute('data-placeholder') || 'Bitte tippen...');
                    editor.innerHTML = initialHtml || '';
                    
                    container.appendChild(editor);
                    
                    editor.addEventListener('input', function() { 
                        var hasText = editor.innerText.trim().length > 0 || editor.querySelectorAll('img, a').length > 0;
                        if (editor.dataset.hasText !== String(hasText)) {
                            editor.dataset.hasText = String(hasText);
                            dotNetRef.invokeMethodAsync('SetHasDescription', hasText); 
                        }
                    }); 
                    
                    editor.addEventListener('paste', function(e) { 
                        var clipboardData = e.clipboardData || window.clipboardData; 
                        if (!clipboardData) return; 
                        var items = clipboardData.items; 
                        for (var i = 0; i < items.length; i++) { 
                            if (items[i].type.indexOf('image') !== -1) { 
                                e.preventDefault(); 
                                var blob = items[i].getAsFile(); 
                                var dt = new DataTransfer();
                                dt.items.add(blob);
                                var input = document.getElementById('hidden-file-input');
                                if (input) {
                                    input.files = dt.files;
                                    input.dispatchEvent(new Event('change', { bubbles: true }));
                                }
                                break; 
                            } 
                        } 
                    }); 
                };
                
                window.appendRichEditor = function(containerId, htmlContent) {
                    var editor = document.getElementById(containerId + '-inner');
                    if(editor) {
                        editor.focus();
                        if (typeof window.getSelection !== 'undefined' && typeof document.createRange !== 'undefined') {
                            var range = document.createRange();
                            range.selectNodeContents(editor);
                            range.collapse(false);
                            var sel = window.getSelection();
                            sel.removeAllRanges();
                            sel.addRange(range);
                        }
                        document.execCommand('insertHTML', false, htmlContent);
                        editor.dispatchEvent(new Event('input'));
                    }
                };

                window.syncEditorContent = async function(containerId, dotNetRef, callbackMethod) {
                    var editor = document.getElementById(containerId + '-inner');
                    if(!editor) {
                        await dotNetRef.invokeMethodAsync(callbackMethod, """");
                        return;
                    }

                    var html = editor.innerHTML;
                    const chunkSize = 20000;
                    const totalChunks = Math.ceil(html.length / chunkSize);
                    let sessionId = Math.random().toString(36).substring(2);

                    if (totalChunks === 0) {
                        await dotNetRef.invokeMethodAsync('ReceiveChunk', sessionId, """", 0, 1);
                    } else {
                        for (let i = 0; i < totalChunks; i++) {
                            let chunk = html.substring(i * chunkSize, (i + 1) * chunkSize);
                            await dotNetRef.invokeMethodAsync('ReceiveChunk', sessionId, chunk, i, totalChunks);
                        }
                    }
                    await dotNetRef.invokeMethodAsync(callbackMethod, sessionId);
                };
            ";
            
            await JSRuntime.InvokeVoidAsync("eval", jsCode);
            _objRef = DotNetObjectReference.Create(this);
        }

        if (!_isLoading && ActiveSteps.Count > 0 && ActiveSteps[_currentStepIndex].Id == "Basics")
        {
            if (!_editorInitialized) {
                _editorInitialized = true;
                await JSRuntime.InvokeVoidAsync("initRichEditor", "ticket-desc-container", _objRef, _newTicket.Description);
            }
        }
        else
        {
            _editorInitialized = false;
        }
    }

    [JSInvokable]
    public void SetHasDescription(bool hasContent)
    {
        if (_hasDescription != hasContent)
        {
            _hasDescription = hasContent;
            StateHasChanged();
        }
    }

    [JSInvokable]
    public void ReceiveChunk(string sessionId, string chunk, int index, int total)
    {
        if (!_htmlChunks.ContainsKey(sessionId)) _htmlChunks[sessionId] = new StringBuilder();
        _htmlChunks[sessionId].Append(chunk);
    }

    [JSInvokable]
    public async Task ProcessDescriptionAndProceed(string sessionId)
    {
        if (_htmlChunks.TryGetValue(sessionId, out var sb))
        {
            _newTicket.Description = sb.ToString();
            _htmlChunks.Remove(sessionId);
        }
        else
        {
            _newTicket.Description = "";
        }

        if (_isSubmitPending) {
            await SubmitTicketAction();
        } else {
            _currentStepIndex++;
            StateHasChanged();
        }
    }

    private async Task UploadFiles(InputFileChangeEventArgs e)
    {
        var files = e.GetMultipleFiles(10);
        foreach (var file in files)
        {
            try
            {
                var maxAllowedSize = 10 * 1024 * 1024;
                using var stream = file.OpenReadStream(maxAllowedSize);
                using var ms = new MemoryStream();
                await stream.CopyToAsync(ms);
                var base64 = Convert.ToBase64String(ms.ToArray());
                var mimeType = file.ContentType;
                
                string appendHtml = "";
                
                if (mimeType.StartsWith("image/"))
                {
                    appendHtml = $"<br/><img src=\"data:{mimeType};base64,{base64}\" style=\"max-width: 100%; border-radius: 6px; border: 1px solid #ddd; margin: 10px 0; display: block;\" /><br/>";
                }
                else
                {
                    appendHtml = $"<br/><a href=\"data:{mimeType};base64,{base64}\" download=\"{file.Name}\" style=\"display: inline-flex; align-items: center; padding: 8px 12px; background: #f0f0f0; border: 1px solid #ccc; border-radius: 4px; text-decoration: none; color: #333; margin: 5px 0;\">📎 {file.Name} ({(file.Size / 1024)} KB)</a><br/>";
                }
                
                await JSRuntime.InvokeVoidAsync("appendRichEditor", "ticket-desc-container", appendHtml);
                
                SetHasDescription(true);
                Snackbar.Add($"{file.Name} erfolgreich angehängt.", Severity.Success);
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Fehler bei {file.Name}: {ex.Message}", Severity.Error);
            }
        }
        StateHasChanged();
    }

    private void RebuildSteps()
    {
        ActiveSteps.Clear();
        ActiveSteps.Add(new WizardStep { Id = "Basics", Name = "Problem", Icon = Icons.Material.Filled.Description });
        ActiveSteps.Add(new WizardStep { Id = "Classification", Name = "Klassifizierung", Icon = Icons.Material.Filled.Category });
        ActiveSteps.Add(new WizardStep { Id = "Assets", Name = "Assets", Icon = Icons.Material.Filled.Computer });
        ActiveSteps.Add(new WizardStep { Id = "Extended", Name = "Erweitert", Icon = Icons.Material.Filled.MoreTime });
        StateHasChanged();
    }

    private async Task NextStep() 
    { 
        if (_currentStepIndex == 0) 
        {
            _isSubmitPending = false;
            await JSRuntime.InvokeVoidAsync("syncEditorContent", "ticket-desc-container", _objRef, "ProcessDescriptionAndProceed");
        }
        else if (_currentStepIndex < ActiveSteps.Count - 1) 
        {
            _currentStepIndex++; 
        }
    }

    private void PrevStep() { if (_currentStepIndex > 0) _currentStepIndex--; }
    private void JumpToStep(int index) { if (index <= _currentStepIndex || CanProceed()) _currentStepIndex = index; }

    private bool CanProceed()
    {
        if (ActiveSteps == null || ActiveSteps.Count == 0 || _currentStepIndex < 0) return false;

        if (ActiveSteps[_currentStepIndex].Id == "Basics") 
        {
            return !string.IsNullOrWhiteSpace(_newTicket.Title) 
                && _hasDescription
                && _newTicket.RequesterId.HasValue
                && _newTicket.TenantId != Guid.Empty;
        }
        if (ActiveSteps[_currentStepIndex].Id == "Classification") 
        {
            return !string.IsNullOrWhiteSpace(_newTicket.Category1) && !string.IsNullOrWhiteSpace(_newTicket.Priority) && !string.IsNullOrWhiteSpace(_newTicket.Status);
        }
        
        return true; 
    }

    private Task<IEnumerable<Asset>> SearchAssets(string value, CancellationToken cancellationToken) {
        if (string.IsNullOrWhiteSpace(value)) return Task.FromResult(_allAssets.Take(10));
        return Task.FromResult(_allAssets.Where(a => 
            (a.Name?.Contains(value, StringComparison.OrdinalIgnoreCase) == true) || 
            (a.AssetTag?.Contains(value, StringComparison.OrdinalIgnoreCase) == true)
        ).Take(10));
    }

    private Task<IEnumerable<Ticket>> SearchTickets(string val, CancellationToken ct) {
        if (string.IsNullOrWhiteSpace(val)) return Task.FromResult(_allTickets.Take(10));
        return Task.FromResult(_allTickets.Where(t => 
            t.TicketNumber.ToString().Contains(val) || 
            (t.Title != null && t.Title.Contains(val, StringComparison.OrdinalIgnoreCase))
        ).Take(10));
    }

    private void AddAsset(Asset? a) { 
        if (a != null) {
            _newTicket.AssignedAssets ??= new List<Asset>();
            if (!_newTicket.AssignedAssets.Any(x => x.Id == a.Id)) {
                _newTicket.AssignedAssets.Add(a);
            }
        }
    }
    private void RemoveAsset(Asset a) { _newTicket.AssignedAssets?.Remove(a); }

    private void AddWatcher(Person p) { 
        if (p != null) {
            _newTicket.Watchers ??= new List<Person>();
            if (!_newTicket.Watchers.Any(w => w.Id == p.Id)) _newTicket.Watchers.Add(p); 
        }
    }
    private void RemoveWatcher(Person p) { _newTicket.Watchers?.Remove(p); }

    private async Task SubmitTicket()
    {
        if (!CanProceed()) return;

        if (_currentStepIndex == 0)
        {
            _isSubmitPending = true;
            await JSRuntime.InvokeVoidAsync("syncEditorContent", "ticket-desc-container", _objRef, "ProcessDescriptionAndProceed");
        }
        else
        {
            await SubmitTicketAction();
        }
    }

    private async Task SubmitTicketAction()
    {
        _isSaving = true;
        StateHasChanged();
        
        try
        {
            HttpResponseMessage response;
            if (IsEditMode)
            {
                response = await Http.PutAsJsonAsync($"api/tickets/{Id}", _newTicket);
            }
            else
            {
                response = await Http.PostAsJsonAsync("api/tickets", _newTicket);
            }

            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add(IsEditMode ? "Ticket erfolgreich aktualisiert!" : "Ticket erfolgreich erstellt!", Severity.Success);
                if (IsEditMode) Nav.NavigateTo($"/tickets/{Id}");
                else {
                    var created = await response.Content.ReadFromJsonAsync<Ticket>();
                    Nav.NavigateTo(created != null ? $"/tickets/{created.Id}" : "/tickets");
                }
            }
            else
            {
                var err = await response.Content.ReadAsStringAsync();
                Snackbar.Add($"Fehler: {err}", Severity.Error);
            }
        }
        catch (Exception ex) 
        { 
            Snackbar.Add($"API Fehler: {ex.Message}", Severity.Error); 
        }
        finally 
        { 
            _isSaving = false; 
            StateHasChanged();
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_objRef != null) _objRef.Dispose();
    }
}