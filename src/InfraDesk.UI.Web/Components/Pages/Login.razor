@* Dateipfad: src/InfraDesk.UI.Web/Components/Pages/Login.razor *@
@page "/login"
@using InfraDesk.UI.Web.Components.Layout
@layout EmptyLayout
@using InfraDesk.UI.Web.Services
@using MudBlazor
@using System.Text.Json
@inject NavigationManager Nav
@inject HttpClient Http
@inject InfraDeskAuthStateProvider AuthStateProvider
@inject ISnackbar Snackbar

<PageTitle>InfraDesk - Login</PageTitle>

<div style="height: 100vh; width: 100vw; display: flex; align-items: center; justify-content: center; background-color: #f0f2f5; position: fixed; top: 0; left: 0;">
    <MudPaper Elevation="4" Style="width: 100%; max-width: 450px; border-radius: 16px; overflow: hidden; margin: 16px;">
        
        <div style="background-color: var(--mud-palette-primary); padding: 32px 24px; text-align: center;">
            <img src="InfraDesk_Logo.png" alt="InfraDesk" style="height: 64px; object-fit: contain; margin-bottom: 16px; filter: brightness(0) invert(1);" />
            <MudText Typo="Typo.h5" Style="color: white; font-weight: bold;">Enterprise CMDB</MudText>
            <MudText Typo="Typo.body2" Style="color: rgba(255,255,255,0.8);">Bitte melden Sie sich an.</MudText>
        </div>

        <div style="padding: 32px;">
            <MudStack Spacing="4">
                <MudTextField @bind-Value="_email" Label="E-Mail Adresse" Variant="Variant.Outlined" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Person" />
                
                <MudTextField @bind-Value="_password" Label="Passwort" Variant="Variant.Outlined" InputType="InputType.Password" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Lock" OnKeyDown="@(async (e) => { if (e.Key == "Enter") await PerformLogin(); })" />

                <div class="d-flex justify-space-between align-center mt-2 mb-4">
                    <MudCheckBox @bind-Value="_rememberMe" Label="Angemeldet bleiben" Color="Color.Primary" Dense="true" />
                    <MudLink Href="#" Color="Color.Primary" Typo="Typo.body2">Passwort vergessen?</MudLink>
                </div>

                <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" FullWidth="true" OnClick="PerformLogin" Style="border-radius: 8px;" Loading="_isLoading">
                    Anmelden
                </MudButton>
            </MudStack>
        </div>
    </MudPaper>
</div>

@code {
    private string _email = "";
    private string _password = "";
    private bool _rememberMe = false;
    private bool _isLoading = false;

    private async Task PerformLogin()
    {
        if (string.IsNullOrWhiteSpace(_email) || string.IsNullOrWhiteSpace(_password))
        {
            Snackbar.Add("Bitte geben Sie E-Mail und Passwort ein.", Severity.Warning);
            return;
        }

        _isLoading = true;

        try
        {
            var response = await Http.PostAsJsonAsync("api/auth/login", new { Email = _email, Password = _password });
            
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<LoginResult>();
                if (result != null && result.Success)
                {
                    await AuthStateProvider.MarkUserAsAuthenticated(result.Email, result.Role, result.Name, result.AllowedTenants);
                    Nav.NavigateTo("/");
                }
            }
            else
            {
                Snackbar.Add("E-Mail oder Passwort ist inkorrekt.", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"API nicht erreichbar: {ex.Message}", Severity.Error);
        }
        finally { _isLoading = false; }
    }

    public class LoginResult
    {
        public bool Success { get; set; }
        public string Email { get; set; } = "";
        public string Name { get; set; } = "";
        public string Role { get; set; } = "";
        public string AllowedTenants { get; set; } = "";
    }
}