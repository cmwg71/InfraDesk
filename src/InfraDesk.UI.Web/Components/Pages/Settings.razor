    private void OnDarkModeChanged(bool isDark) { 
        var cfg = ThemeService.Config;
        cfg.IsDark = isDark; 
        ThemeService.UpdateConfig(cfg); 
    }
    
    private void ApplyColor() { 
        var cfg = ThemeService.Config;
        cfg.PrimaryColor = _tempPrimaryColor; 
        ThemeService.UpdateConfig(cfg); 
    }
    
    private void SelectPalette(string hex) { _tempPrimaryColor = hex; ApplyColor(); }
    
    private void RemoveStatus(string g, string s) {
        if (_lifecycleConfig.ContainsKey(g)) {
            _lifecycleConfig[g].Remove(s);
            OnFieldChanged();
        }
    }
    
    private void AddStatus(string g) { 
        if(!_lifecycleConfig.ContainsKey(g)) _lifecycleConfig[g] = new List<string>(); 
        _lifecycleConfig[g].Add("NEUER STATUS"); 
        OnFieldChanged(); 
    }

    private async Task CheckForUpdates()
    {
        if (_isChecking) return;
        _isChecking = true; 
        await InvokeAsync(StateHasChanged);
        
        try 
        {
            var release = await UpdateService.GetLatestReleaseAsync();
            if (release != null && !string.IsNullOrWhiteSpace(release.TagName)) 
            {
                _latestVersion = release.TagName;
                string cleanLatest = _latestVersion.TrimStart('v', 'V');
                _updateFound = cleanLatest != _currentVersion;
                _updateChecked = true;
            }
        } 
        catch { }
        finally 
        { 
            _isChecking = false; 
            await InvokeAsync(StateHasChanged); 
        }
    }

