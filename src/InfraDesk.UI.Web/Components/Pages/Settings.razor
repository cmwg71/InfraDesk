            ".label { width: " + _masterData.LabelWidth + "mm; height: " + _masterData.LabelHeight + "mm; padding: 2mm; box-sizing: border-box; display: flex; flex-direction: column; align-items: center; justify-content: space-between; font-family: sans-serif; text-align: center; -webkit-print-color-adjust: exact; print-color-adjust: exact; } " +
            ".barcode { width: 100%; height: 8mm; background: repeating-linear-gradient(90deg, #000, #000 0.5mm, #fff 0.5mm, #fff 1mm); margin-bottom: 1mm; } " +
            ".content { display: flex; width: 100%; align-items: center; justify-content: space-around; flex: 1; } " +
            ".qr { width: 12mm; height: 12mm; }" +
            "</style></head><body onload='window.print();window.close();'>" +
            "<div class='label'>" + companyHtml + 
            "<div class='content'><div style='flex:1; display:flex; flex-direction:column; align-items:center; justify-content:center; overflow:hidden;'>" +
            "<div class='barcode'></div>" + tagHtml + "</div><div class='qr'>" + qrSvg + "</div></div>" +
            footerHtml + "</div></body></html>";

        string base64Html = Convert.ToBase64String(System.Text.Encoding.UTF8.GetBytes(html));
        await JSRuntime.InvokeVoidAsync("eval", "var w = window.open('', '_blank'); w.document.write(atob('" + base64Html + "')); w.document.close();");
