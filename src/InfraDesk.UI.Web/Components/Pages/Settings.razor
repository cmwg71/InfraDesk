@* Dateipfad: src/InfraDesk.UI.Web/Components/Pages/Settings.razor *@
@page "/settings"
@using MudBlazor
@using InfraDesk.UI.Web.Services
@using System.Text.Json
@using System.Reflection
@inject HttpClient Http
@inject ISnackbar Snackbar
@inject ThemeService ThemeService
@inject UpdateService UpdateService
@inject NavigationManager Nav

<PageTitle>InfraDesk - Einstellungen</PageTitle>

<style>
    /* PDQ Inventory Style: High Density Layout */
    .pdq-container { background-color: #fff; height: calc(100vh - 100px); display: flex; flex-direction: row; border-top: none; }
    .pdq-sidebar { width: 240px; border-right: 1px solid #ccc; background-color: #f0f0f0; overflow-y: auto; flex-shrink: 0; }
    .pdq-content { flex-grow: 1; overflow-y: auto; background-color: #fff; padding: 12px 24px; }
    
    .pdq-section-header { background-color: #e0e0e0; padding: 4px 12px; font-weight: 800; font-size: 0.75rem; text-transform: uppercase; border-bottom: 1px solid #ccc; border-top: 1px solid #ccc; color: #333; margin-bottom: 12px; margin-top: 20px; }
    .pdq-section-header:first-child { margin-top: 0; border-top: none; }
    
    .pdq-toolbar { height: 42px; background-color: #eee; border-bottom: 1px solid #ccc; display: flex; align-items: center; padding: 0 12px; }
    
    .sidebar-active { background-color: #fff !important; font-weight: bold; border-left: 4px solid var(--mud-palette-primary); color: var(--mud-palette-primary) !important; }
    
    /* Preset Buttons Style */
    .preset-card { cursor: pointer; transition: transform 0.1s; border: 1px solid #ddd; }
    .preset-card:hover { transform: scale(1.02); box-shadow: 0 4px 8px rgba(0,0,0,0.1); }
</style>

<div class="pdq-toolbar">
    <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" OnClick="@(() => Nav.NavigateTo("/"))" Size="Size.Small" Class="mr-2" />
    <MudIcon Icon="@Icons.Material.Filled.Settings" Color="Color.Primary" Size="Size.Small" Class="mr-2" />
    <MudText Typo="Typo.body2" Class="font-weight-bold">System-Einstellungen</MudText>
</div>

<div class="pdq-container">
    
    <!-- NAVIGATION SIDEBAR -->
    <div class="pdq-sidebar">
        <MudNavMenu Margin="Margin.Dense" Rounded="false">
            
            <div class="pdq-section-header" style="margin-top: 0; border-top: none;">Allgemein</div>
            <MudNavLink OnClick="@(() => _activeTab = "Profile")" Class="@(_activeTab == "Profile" ? "sidebar-active" : "")" Icon="@Icons.Material.Filled.Business">Unternehmensprofil</MudNavLink>
            <MudNavLink OnClick="@(() => _activeTab = "Inventory")" Class="@(_activeTab == "Inventory" ? "sidebar-active" : "")" Icon="@Icons.Material.Filled.QrCodeScanner">Inventarisierung</MudNavLink>
            
            <div class="pdq-section-header">Sicherheit & IAM</div>
            <MudNavLink OnClick="@(() => _activeTab = "IAM")" Class="@(_activeTab == "IAM" ? "sidebar-active" : "")" Icon="@Icons.Material.Filled.Security">Benutzer & Rollen</MudNavLink>

            <div class="pdq-section-header">Konfiguration</div>
            <MudNavLink OnClick="@(() => _activeTab = "Theme")" Class="@(_activeTab == "Theme" ? "sidebar-active" : "")" Icon="@Icons.Material.Filled.Palette">Design & Theme</MudNavLink>
            <MudNavLink OnClick="@(() => _activeTab = "Lifecycle")" Class="@(_activeTab == "Lifecycle" ? "sidebar-active" : "")" Icon="@Icons.Material.Filled.Recycling">Asset-Lebenszyklus</MudNavLink>
            
            <div class="pdq-section-header">System</div>
            <MudNavLink OnClick="@(() => _activeTab = "Update")" Class="@(_activeTab == "Update" ? "sidebar-active" : "")" Icon="@Icons.Material.Filled.SystemUpdate">Update & Info</MudNavLink>

        </MudNavMenu>
    </div>

    <!-- CONTENT AREA -->
    <div class="pdq-content">
        
        <!-- 1. UNTERNEHMENSPROFIL -->
        @if (_activeTab == "Profile")
        {
            <MudText Typo="Typo.h5" Class="mb-2 font-weight-bold">Zentrale Stammdaten</MudText>
            <MudText Typo="Typo.body2" Class="mb-6" Color="Color.Secondary">Definieren Sie hier Ihre primäre Organisation (Mandant) und den Hauptstandort.</MudText>

            @if (_isLoadingMasterData) { <MudProgressCircular Indeterminate="true" Color="Color.Primary" /> }
            else {
                <div class="pdq-section-header">Organisation / Firma</div>
                <MudGrid Spacing="2" Class="mb-6">
                    <MudItem xs="12" md="6"><MudTextField @bind-Value="_masterData.CompanyName" Label="Name der Organisation *" Variant="Variant.Outlined" Margin="Margin.Dense" Required="true" /></MudItem>
                    <MudItem xs="12" md="6"><MudTextField @bind-Value="_masterData.Domain" Label="Primäre Domain" Variant="Variant.Outlined" Margin="Margin.Dense" /></MudItem>
                    <MudItem xs="12" md="4"><MudTextField @bind-Value="_masterData.CompanyPrefix" Label="Firmen-Kürzel *" MaxLength="3" Variant="Variant.Outlined" Margin="Margin.Dense" Required="true" /></MudItem>
                </MudGrid>

                <div class="pdq-section-header">Zentrale / Hauptstandort</div>
                <MudGrid Spacing="2" Class="mb-8">
                    <MudItem xs="12" md="6"><MudTextField @bind-Value="_masterData.Street" Label="Straße und Hausnummer" Variant="Variant.Outlined" Margin="Margin.Dense" /></MudItem>
                    <MudItem xs="12" md="6"><MudTextField @bind-Value="_masterData.ZipCity" Label="PLZ und Ort *" Variant="Variant.Outlined" Margin="Margin.Dense" Required="true" /></MudItem>
                    <MudItem xs="12" md="6"><MudTextField @bind-Value="_masterData.State" Label="Bundesland / Kanton" Variant="Variant.Outlined" Margin="Margin.Dense" /></MudItem>
                    <MudItem xs="12" md="6"><MudTextField @bind-Value="_masterData.Country" Label="Land" Variant="Variant.Outlined" Margin="Margin.Dense" /></MudItem>
                </MudGrid>

                <div class="pdq-section-header">Mandanten-Sicherheit & Compliance</div>
                <MudPaper Class="pa-4 mb-8" Elevation="0" Outlined="true" Style="border-radius: 4px; background-color: var(--mud-palette-background-grey);">
                    <MudSwitch @bind-Value="_masterData.EnableMultiTenancy" Color="Color.Primary" Label="Multi-Mandanten-Architektur erzwingen" />
                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="d-block mt-2">Isoliert Daten rechtlich eigenständiger Firmen innerhalb dieser Instanz.</MudText>
                </MudPaper>

                <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Save" Size="Size.Small" OnClick="SaveMasterData">Stammdaten speichern</MudButton>
            }
        }

        <!-- 2. INVENTARISIERUNG -->
        @if (_activeTab == "Inventory")
        {
            <MudText Typo="Typo.h5" Class="mb-4 font-weight-bold">Asset-Tag Generierung</MudText>
            <div class="pdq-section-header">Live-Vorschau des Schemas</div>
            <MudPaper Class="pa-6 mb-8" Elevation="0" Outlined="true" Style="border-radius: 4px; background-color: var(--mud-palette-background-grey);">
                <div class="d-flex align-center" style="font-family: monospace; font-size: 1.5rem; background-color: #fff; padding: 16px; border-radius: 4px; border: 1px solid #ccc;">
                    <strong style="color: var(--mud-palette-primary);">@(string.IsNullOrWhiteSpace(_masterData.CompanyPrefix) ? "[FIRMA]" : _masterData.CompanyPrefix.ToUpper())</strong>
                    <span style="opacity: 0.5; margin: 0 8px;">-</span>
                    <span style="color: var(--mud-palette-secondary);">[ST]</span>
                    <span style="opacity: 0.5; margin: 0 8px;">-</span>
                    <span style="color: var(--mud-palette-info);">[KAT]</span>
                    <span style="opacity: 0.5; margin: 0 8px;">-</span>
                    <strong style="color: var(--mud-palette-success);">[00001]</strong>
                </div>
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-4 d-block">Das Kürzel wird aus dem Unternehmensprofil übernommen.</MudText>
            </MudPaper>
        }

        <!-- 3. IDENTITY & ACCESS (RBAC) -->
        @if (_activeTab == "IAM")
        {
            <MudText Typo="Typo.h5" Class="mb-4 font-weight-bold">Benutzer & Berechtigungen</MudText>
            <div class="pdq-section-header">Identity Provider (IdP)</div>
            <MudPaper Class="pa-4 mb-6" Elevation="0" Outlined="true" Style="border-radius: 4px;">
                <MudStack Row="true" AlignItems="AlignItems.Center">
                    <MudIcon Icon="@Icons.Custom.Brands.Microsoft" Color="Color.Primary" Size="Size.Large" />
                    <MudText Typo="Typo.body2">Microsoft Entra ID (Azure AD) ist zur Anbindung bereit.</MudText>
                    <MudSpacer />
                    <MudButton Variant="Variant.Outlined" Size="Size.Small">Konfigurieren</MudButton>
                </MudStack>
            </MudPaper>
            
            <div class="pdq-section-header">Aktive Benutzer (Mock)</div>
            <MudDataGrid Items="@_mockUsers" Dense="true" Bordered="true" Elevation="0" Striped="true">
                <Columns>
                    <PropertyColumn Property="x => x.Name" Title="Benutzer" />
                    <PropertyColumn Property="x => x.Role" Title="Rolle (RBAC)" />
                    <PropertyColumn Property="x => x.Tenants" Title="Zugriff (Mandanten)" />
                </Columns>
            </MudDataGrid>
        }

        <!-- 4. DESIGN & THEME (Vollständiger Umfang) -->
        @if (_activeTab == "Theme")
        {
            <MudText Typo="Typo.h5" Class="mb-4 font-weight-bold">Design & Benutzeroberfläche</MudText>
            <MudGrid Spacing="4">
                <MudItem xs="12" lg="7">
                    <div class="pdq-section-header">Farbschema manuell</div>
                    <MudGrid Spacing="2">
                        <MudItem xs="6"><MudColorPicker Label="Primärfarbe" @bind-Text="_themeConfig.PrimaryColor" Variant="Variant.Outlined" Margin="Margin.Dense" OnClick="NotifyManualChange" /></MudItem>
                        <MudItem xs="6"><MudColorPicker Label="Sekundärfarbe" @bind-Text="_themeConfig.SecondaryColor" Variant="Variant.Outlined" Margin="Margin.Dense" OnClick="NotifyManualChange" /></MudItem>
                        <MudItem xs="6"><MudColorPicker Label="Hintergrund" @bind-Text="_themeConfig.BackgroundColor" Variant="Variant.Outlined" Margin="Margin.Dense" OnClick="NotifyManualChange" /></MudItem>
                        <MudItem xs="6"><MudColorPicker Label="Oberflächen" @bind-Text="_themeConfig.SurfaceColor" Variant="Variant.Outlined" Margin="Margin.Dense" OnClick="NotifyManualChange" /></MudItem>
                    </MudGrid>

                    <div class="pdq-section-header">Typografie</div>
                    <MudGrid Spacing="2">
                        <MudItem xs="8">
                            <MudSelect T="string" Label="Schriftart" @bind-Value="_themeConfig.FontFamily" Variant="Variant.Outlined" Margin="Margin.Dense" SelectedValuesChanged="NotifyManualChange">
                                <MudSelectItem Value="@("'Roboto', sans-serif")">Roboto (Standard)</MudSelectItem>
                                <MudSelectItem Value="@("'Inter', sans-serif")">Inter (Modern)</MudSelectItem>
                                <MudSelectItem Value="@("'Segoe UI', sans-serif")">System UI</MudSelectItem>
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="4"><MudNumericField Label="Basis-Größe" @bind-Value="_themeConfig.BaseFontSize" Min="12" Max="20" Variant="Variant.Outlined" Margin="Margin.Dense" @onkeyup="NotifyManualChange" /></MudItem>
                    </MudGrid>
                    <MudButton Class="mt-6" Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" OnClick="SaveThemeSettings">Design permanent speichern</MudButton>
                </MudItem>

                <MudItem xs="12" lg="5">
                    <div class="pdq-section-header">Vordefinierte Presets</div>
                    <MudStack Spacing="1">
                        <MudButton Variant="Variant.Filled" OnClick="@(() => ApplyPreset("Corporate"))" FullWidth Style="background-color: #1976D2; color: white; justify-content: flex-start; text-transform: none; font-size: 0.75rem;">Corporate Blue</MudButton>
                        <MudButton Variant="Variant.Filled" OnClick="@(() => ApplyPreset("Midnight"))" FullWidth Style="background-color: #1A237E; color: white; justify-content: flex-start; text-transform: none; font-size: 0.75rem;">Midnight Deep Ocean</MudButton>
                        <MudButton Variant="Variant.Filled" OnClick="@(() => ApplyPreset("Nature"))" FullWidth Style="background-color: #2E7D32; color: white; justify-content: flex-start; text-transform: none; font-size: 0.75rem;">Nature Inspired</MudButton>
                        <MudButton Variant="Variant.Filled" OnClick="@(() => ApplyPreset("Energy"))" FullWidth Style="background-color: #FF6D00; color: white; justify-content: flex-start; text-transform: none; font-size: 0.75rem;">Vibrant Energy</MudButton>
                        <MudButton Variant="Variant.Filled" OnClick="@(() => ApplyPreset("Pastel"))" FullWidth Style="background-color: #F48FB1; color: white; justify-content: flex-start; text-transform: none; font-size: 0.75rem;">Soft Pastels</MudButton>
                        <MudButton Variant="Variant.Filled" OnClick="@(() => ApplyPreset("Elegance"))" FullWidth Style="background-color: #8D6E63; color: white; justify-content: flex-start; text-transform: none; font-size: 0.75rem;">Neutral Elegance</MudButton>
                        <MudButton Variant="Variant.Filled" OnClick="@(() => ApplyPreset("Retro"))" FullWidth Style="background-color: #E64A19; color: white; justify-content: flex-start; text-transform: none; font-size: 0.75rem;">Retro Sunset</MudButton>
                        <MudButton Variant="Variant.Filled" OnClick="@(() => ApplyPreset("HighContrast"))" FullWidth Style="background-color: #000; color: #FFFF00; justify-content: flex-start; text-transform: none; font-size: 0.75rem;">High Contrast</MudButton>
                    </MudStack>
                </MudItem>
            </MudGrid>
        }

        <!-- 5. ASSET-LEBENSZYKLUS (Vollständig) -->
        @if (_activeTab == "Lifecycle")
        {
            <MudText Typo="Typo.h5" Class="mb-4 font-weight-bold">Asset-Lebenszyklus</MudText>
            @if (_lifecycleConfig == null) { <MudProgressCircular Indeterminate="true" Color="Color.Primary" /> }
            else {
                @foreach (var phase in _lifecycleConfig.Keys.ToList()) {
                    <MudPaper Class="pa-4 mb-4" Elevation="0" Outlined="true" Style="border-radius: 4px;">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
                            <MudIcon Icon="@Icons.Material.Filled.Label" Color="Color.Primary" Size="Size.Small" />
                            <MudTextField @bind-Value="_phaseRenames[phase]" Label="Name der Phase" Variant="Variant.Outlined" Margin="Margin.Dense" Style="max-width: 300px; font-weight: bold;" />
                            <MudSpacer />
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" OnClick="@(() => RemovePhase(phase))" />
                        </MudStack>
                        <MudChipSet T="string" AllClosable="true" OnClose="@((chip) => { if (chip.Text != null) RemoveStatus(phase, chip.Text); })">
                            @foreach (var status in _lifecycleConfig[phase]) { <MudChip Text="@status" Color="Color.Primary" Size="Size.Small" Variant="Variant.Outlined" /> }
                        </MudChipSet>
                        <MudStack Row="true" Class="mt-2" AlignItems="AlignItems.Center">
                            <MudTextField T="string" @bind-Value="_newStatusInputs[phase]" Placeholder="Neuer Status..." Variant="Variant.Outlined" Margin="Margin.Dense" Style="max-width: 200px;" />
                            <MudIconButton Icon="@Icons.Material.Filled.Add" Color="Color.Success" Size="Size.Small" OnClick="@(() => AddStatus(phase))" Variant="Variant.Filled" />
                        </MudStack>
                    </MudPaper>
                }
                <MudButton StartIcon="@Icons.Material.Filled.AddCircle" Color="Color.Primary" Variant="Variant.Outlined" Size="Size.Small" OnClick="AddPhase">Neue Phase hinzufügen</MudButton>
                <MudButton Class="ml-4" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Save" Size="Size.Small" OnClick="SaveLifecycleSettings">Konfiguration speichern</MudButton>
            }
        }

        <!-- 6. UPDATE & SYSTEM INFO -->
        @if (_activeTab == "Update")
        {
            <div class="d-flex justify-center py-10">
                <MudPaper Class="pa-10 d-flex flex-column align-center" Elevation="0" Outlined="true" Style="max-width: 700px; width: 100%; border-radius: 8px;">
                    <img src="InfraDesk_Ico.png" alt="Logo" style="height: 100px; margin-bottom: 24px;" />
                    <MudText Typo="Typo.h4" Class="font-weight-bold mb-2">InfraDesk Enterprise</MudText>
                    
                    <div class="pdq-grid w-100 mt-8">
                        <div class="pdq-label">Version</div>
                        <div class="pdq-value" style="font-family: monospace; font-weight: bold;">@_currentVersion</div>
                        <div class="pdq-label">Entwicklung</div>
                        <div class="pdq-value">Christian Grams (Grams IT)</div>
                        <div class="pdq-label">Lizenz</div>
                        <div class="pdq-value">Enterprise Subscription</div>
                    </div>

                    <div class="pdq-section-header w-100 mt-8">GitHub Update-Service</div>
                    <MudAlert Severity="Severity.Info" Dense="true" Class="w-100 mb-4 mt-2">Prüft live gegen das private GitHub Repository.</MudAlert>
                    <MudTextField @bind-Value="_gitHubToken" Label="GitHub Personal Access Token (PAT)" Variant="Variant.Outlined" Margin="Margin.Dense" InputType="InputType.Password" Placeholder="ghp_..." FullWidth="true" />
                    
                    <MudStack Row="true" Class="mt-4 w-100" AlignItems="AlignItems.Center">
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="CheckForUpdates" Loading="_isCheckingUpdate" StartIcon="@Icons.Material.Filled.Refresh">Nach Updates suchen</MudButton>
                        @if (_newVersionAvailable) { <MudChip T="string" Color="Color.Error" Icon="@Icons.Material.Filled.NewReleases">Update verfügbar!</MudChip> }
                        else if (_isUpToDate) { <MudChip T="string" Color="Color.Success" Icon="@Icons.Material.Filled.CheckCircle">Aktuell</MudChip> }
                    </MudStack>

                    <MudText Typo="Typo.caption" Class="mt-10 opacity-50">© @DateTime.Now.Year Grams IT. PDQ High-Density Edition.</MudText>
                </MudPaper>
            </div>
        }
    </div>
</div>

@code {
    private string _activeTab = "Profile";
    private ThemeConfig _themeConfig = new();
    private MasterDataModel _masterData = new();
    private bool _isLoadingMasterData = true;
    
    // Lifecycle Management
    private Dictionary<string, List<string>>? _lifecycleConfig;
    private Dictionary<string, string> _newStatusInputs = new();
    private Dictionary<string, string> _phaseRenames = new();

    // GitHub Updates
    private string _currentVersion = "Lade...";
    private string _gitHubToken = "";
    private bool _isCheckingUpdate = false;
    private bool _newVersionAvailable = false;
    private bool _isUpToDate = false;

    public class MasterDataModel { public string CompanyName { get; set; } = ""; public string Domain { get; set; } = ""; public string CompanyPrefix { get; set; } = ""; public string Street { get; set; } = ""; public string ZipCity { get; set; } = ""; public string State { get; set; } = ""; public string Country { get; set; } = ""; public bool EnableMultiTenancy { get; set; } = true; }
    public class UserModel { public string Name {get;set;}=""; public string Role {get;set;}=""; public string Tenants {get;set;}=""; }
    private List<UserModel> _mockUsers = new() { new() { Name = "Christian Grams", Role = "Global Admin", Tenants = "Alle (Systemweit)" } };

    protected override async Task OnInitializedAsync()
    {
        _themeConfig = ThemeService.Config;
        var version = Assembly.GetExecutingAssembly().GetName().Version;
        if (version != null) _currentVersion = version.ToString();

        await LoadMasterData();
        await LoadLifecycleSettings();
    }

    private async Task LoadMasterData()
    {
        _isLoadingMasterData = true;
        try { _masterData = await Http.GetFromJsonAsync<MasterDataModel>("api/settings/masterdata") ?? new(); } catch { }
        finally { _isLoadingMasterData = false; }
    }

    private async Task SaveMasterData()
    {
        if (string.IsNullOrWhiteSpace(_masterData.CompanyName) || string.IsNullOrWhiteSpace(_masterData.CompanyPrefix)) {
            Snackbar.Add("Pflichtfelder fehlen.", Severity.Warning); return;
        }
        var res = await Http.PostAsJsonAsync("api/settings/masterdata", _masterData);
        if (res.IsSuccessStatusCode) {
            Snackbar.Add("Stammdaten gespeichert!", Severity.Success);
            Nav.NavigateTo(Nav.Uri, forceLoad: true);
        }
    }

    private async Task CheckForUpdates()
    {
        _isCheckingUpdate = true; _isUpToDate = false; _newVersionAvailable = false;
        var latest = await UpdateService.GetLatestReleaseAsync(_gitHubToken);
        if (latest != null) {
            var cleanTag = latest.TagName.TrimStart('v');
            if (cleanTag != _currentVersion) _newVersionAvailable = true;
            else _isUpToDate = true;
        } else Snackbar.Add("Fehler bei der Prüfung.", Severity.Warning);
        _isCheckingUpdate = false;
    }

    private void NotifyManualChange() => ThemeService.UpdateConfig(_themeConfig);
    private void SaveThemeSettings() { ThemeService.UpdateConfig(_themeConfig); Snackbar.Add("Design permanent gespeichert.", Severity.Success); }

    // Lifecycle Logic
    private async Task LoadLifecycleSettings() {
        try {
            _lifecycleConfig = await Http.GetFromJsonAsync<Dictionary<string, List<string>>>("api/settings/asset-lifecycle");
            if (_lifecycleConfig != null) foreach (var k in _lifecycleConfig.Keys) { _newStatusInputs[k] = ""; _phaseRenames[k] = k; }
        } catch { }
    }
    private void AddStatus(string phase) { if (!string.IsNullOrWhiteSpace(_newStatusInputs[phase])) { _lifecycleConfig?[phase].Add(_newStatusInputs[phase]); _newStatusInputs[phase] = ""; } }
    private void RemoveStatus(string phase, string status) => _lifecycleConfig?[phase].Remove(status);
    private void AddPhase() { var name = "Neue Phase"; if (_lifecycleConfig != null && !_lifecycleConfig.ContainsKey(name)) { _lifecycleConfig.Add(name, new List<string>()); _newStatusInputs[name] = ""; _phaseRenames[name] = name; } }
    private void RemovePhase(string phase) => _lifecycleConfig?.Remove(phase);
    private async Task SaveLifecycleSettings() {
        if (_lifecycleConfig == null) return;
        var final = new Dictionary<string, List<string>>();
        foreach(var e in _lifecycleConfig) final.Add(_phaseRenames[e.Key], e.Value);
        var res = await Http.PostAsJsonAsync("api/settings/asset-lifecycle", final);
        if (res.IsSuccessStatusCode) Snackbar.Add("Lebenszyklus gespeichert!", Severity.Success);
    }

    private void ApplyPreset(string name)
    {
        var cfg = new ThemeConfig();
        cfg.FontFamily = _themeConfig.FontFamily;
        cfg.BaseFontSize = _themeConfig.BaseFontSize;
        switch (name) {
            case "Midnight": cfg.IsDark = true; cfg.PrimaryColor = "#3F51B5"; cfg.SecondaryColor = "#5C6BC0"; cfg.BackgroundColor = "#0A0E21"; cfg.SurfaceColor = "#161B33"; cfg.AppbarColor = "#0D1117"; cfg.AppbarText = "#E0E0E0"; cfg.DrawerColor = "#161B33"; cfg.DrawerText = "#E0E0E0"; cfg.DrawerIcon = "#3F51B5"; cfg.TextPrimary = "#E0E0E0"; break;
            case "Nature": cfg.PrimaryColor = "#2E7D32"; cfg.SecondaryColor = "#689F38"; cfg.BackgroundColor = "#F1F8E9"; cfg.SurfaceColor = "#FFFFFF"; cfg.AppbarColor = "#1B5E20"; cfg.AppbarText = "#FFFFFF"; cfg.DrawerColor = "#FFFFFF"; cfg.DrawerText = "#1B5E20"; cfg.DrawerIcon = "#2E7D32"; cfg.TextPrimary = "#1B5E20"; break;
            case "Energy": cfg.PrimaryColor = "#FF6D00"; cfg.SecondaryColor = "#00B8D4"; cfg.BackgroundColor = "#FFF3E0"; cfg.SurfaceColor = "#FFFFFF"; cfg.AppbarColor = "#E65100"; cfg.AppbarText = "#FFFFFF"; cfg.DrawerColor = "#FFFFFF"; cfg.DrawerText = "#3E2723"; cfg.DrawerIcon = "#FF6D00"; cfg.TextPrimary = "#3E2723"; break;
            case "Pastel": cfg.PrimaryColor = "#F48FB1"; cfg.SecondaryColor = "#90CAF9"; cfg.BackgroundColor = "#FFF1F6"; cfg.SurfaceColor = "#FFFFFF"; cfg.AppbarColor = "#AD1457"; cfg.AppbarText = "#FFFFFF"; cfg.DrawerColor = "#FFFFFF"; cfg.DrawerText = "#880E4F"; cfg.DrawerIcon = "#F48FB1"; cfg.TextPrimary = "#880E4F"; break;
            case "Elegance": cfg.PrimaryColor = "#5D4037"; cfg.SecondaryColor = "#8D6E63"; cfg.BackgroundColor = "#FAF9F6"; cfg.SurfaceColor = "#FFFFFF"; cfg.AppbarColor = "#3E2723"; cfg.AppbarText = "#FFFFFF"; cfg.DrawerColor = "#FFFFFF"; cfg.DrawerText = "#3E2723"; cfg.DrawerIcon = "#5D4037"; cfg.TextPrimary = "#3E2723"; break;
            case "Retro": cfg.PrimaryColor = "#E64A19"; cfg.SecondaryColor = "#00796B"; cfg.BackgroundColor = "#FFFDE7"; cfg.SurfaceColor = "#FFFFFF"; cfg.AppbarColor = "#BF360C"; cfg.AppbarText = "#FFFFFF"; cfg.DrawerColor = "#FFFFFF"; cfg.DrawerText = "#212121"; cfg.DrawerIcon = "#E64A19"; cfg.TextPrimary = "#212121"; break;
            case "HighContrast": cfg.PrimaryColor = "#FFFF00"; cfg.SecondaryColor = "#FFFFFF"; cfg.BackgroundColor = "#000000"; cfg.SurfaceColor = "#000000"; cfg.AppbarColor = "#000000"; cfg.AppbarText = "#FFFF00"; cfg.DrawerColor = "#000000"; cfg.DrawerText = "#FFFFFF"; cfg.DrawerIcon = "#FFFF00"; cfg.TextPrimary = "#FFFFFF"; break;
            default: cfg.PrimaryColor = "#1976D2"; cfg.SecondaryColor = "#424242"; cfg.BackgroundColor = "#F0F2F5"; cfg.SurfaceColor = "#FFFFFF"; cfg.AppbarColor = "#333333"; cfg.AppbarText = "#FFFFFF"; cfg.DrawerColor = "#FFFFFF"; cfg.DrawerText = "#424242"; cfg.DrawerIcon = "#1976D2"; cfg.TextPrimary = "#424242"; break;
        }
        _themeConfig = cfg; ThemeService.UpdateConfig(cfg); Snackbar.Add($"Preset '{name}' angewendet.", Severity.Info);
    }
}