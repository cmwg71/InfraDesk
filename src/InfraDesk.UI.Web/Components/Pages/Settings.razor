        } catch { }
    }
    private async Task DeletePerson() {
        if (_editPerson == null || _editPerson.Id == Guid.Empty) { _editPerson = null; return; }
        try {
            var res = await Http.DeleteAsync($"api/persons/{_editPerson.Id}");
            if (res.IsSuccessStatusCode) { 
                _persons.Remove(_editPerson); 
                _editPerson = null; 
