        string companyHtml = string.IsNullOrEmpty(company) ? "" : "<div style='font-size: 8pt; font-weight: bold; border-bottom: 0.1mm solid #eee; width: 100%; padding-bottom: 0.5mm; margin-bottom: 1mm;'>" + company + "</div>";
        string tagHtml = _masterData.ShowTextBelowBarcode ? "<div style='font-size: 7pt; font-weight:bold; font-family: monospace;'>" + tag + "</div>" : "";
