@* Dateipfad: src/InfraDesk.UI.Web/Components/Pages/Settings.razor *@
@page "/settings"
@using MudBlazor
@using InfraDesk.UI.Web.Services
@using System.Text.Json
@using System.Reflection
@inject HttpClient Http
@inject ISnackbar Snackbar
@inject ThemeService ThemeService
@inject UpdateService UpdateService
@inject NavigationManager Nav

<PageTitle>InfraDesk - Einstellungen</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-10 px-10">
    <MudText Typo="Typo.h4" Class="mb-8 font-weight-bold">System-Einstellungen</MudText>

    <MudTabs Elevation="4" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-12" Color="Color.Primary" Outlined="true" Style="background-color: var(--mud-palette-surface); border-radius: 16px;">
        
        <!-- TAB 1: DESIGN & THEME -->
        <MudTabPanel Icon="@Icons.Material.Filled.Palette" Text="Design & Theme">
            <MudGrid Spacing="6">
                <MudItem xs="12" md="7">
                    <MudText Typo="Typo.h6" Class="mb-6 font-weight-bold">Farbschema manuell anpassen</MudText>
                    <MudGrid Spacing="4">
                        <MudItem xs="12" sm="6">
                            <MudColorPicker Label="Primärfarbe" @bind-Text="_themeConfig.PrimaryColor" Variant="Variant.Outlined" Margin="Margin.Dense" OnClick="NotifyManualChange" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudColorPicker Label="Sekundärfarbe" @bind-Text="_themeConfig.SecondaryColor" Variant="Variant.Outlined" Margin="Margin.Dense" OnClick="NotifyManualChange" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudColorPicker Label="Hintergrund" @bind-Text="_themeConfig.BackgroundColor" Variant="Variant.Outlined" Margin="Margin.Dense" OnClick="NotifyManualChange" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudColorPicker Label="Oberflächen" @bind-Text="_themeConfig.SurfaceColor" Variant="Variant.Outlined" Margin="Margin.Dense" OnClick="NotifyManualChange" />
                        </MudItem>
                        <MudItem xs="12">
                            <MudColorPicker Label="Standard Textfarbe" @bind-Text="_themeConfig.TextPrimary" Variant="Variant.Outlined" Margin="Margin.Dense" OnClick="NotifyManualChange" />
                        </MudItem>
                    </MudGrid>

                    <MudText Typo="Typo.h6" Class="mt-12 mb-6 font-weight-bold">Typografie</MudText>
                    <MudGrid Spacing="4">
                        <MudItem xs="12" sm="8">
                            <MudSelect T="string" Label="Schriftart" @bind-Value="_themeConfig.FontFamily" Variant="Variant.Outlined" Margin="Margin.Dense" SelectedValuesChanged="NotifyManualChange">
                                <MudSelectItem Value="@("'Roboto', sans-serif")">Roboto (Standard)</MudSelectItem>
                                <MudSelectItem Value="@("'Inter', sans-serif")">Inter (Modern)</MudSelectItem>
                                <MudSelectItem Value="@("'Open Sans', sans-serif")">Open Sans</MudSelectItem>
                                <MudSelectItem Value="@("'Segoe UI', Tahoma, Geneva, Verdana, sans-serif")">System UI</MudSelectItem>
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" sm="4">
                            <MudNumericField Label="Größe (px)" @bind-Value="_themeConfig.BaseFontSize" Min="12" Max="20" Variant="Variant.Outlined" Margin="Margin.Dense" @onkeyup="NotifyManualChange" />
                        </MudItem>
                    </MudGrid>
                </MudItem>

                <!-- VORDEFINIERTE PALETTEN -->
                <MudItem xs="12" md="5">
                    <MudPaper Class="pa-8" Elevation="0" Outlined="true" Style="background-color: var(--mud-palette-background-grey); border-radius: 20px;">
                        <MudText Typo="Typo.subtitle1" Class="font-weight-bold mb-6">Design-Konzepte</MudText>
                        <MudStack Spacing="3">
                            <MudButton Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Business" OnClick="@(() => ApplyPreset("Corporate"))" FullWidth Style="background-color: #1976D2; color: white; justify-content: flex-start; text-transform: none; padding: 12px; border-radius: 10px;">Corporate Blue</MudButton>
                            <MudButton Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.NightsStay" OnClick="@(() => ApplyPreset("Midnight"))" FullWidth Style="background-color: #1A237E; color: white; justify-content: flex-start; text-transform: none; padding: 12px; border-radius: 10px;">Midnight Deep Ocean</MudButton>
                            <MudButton Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Forest" OnClick="@(() => ApplyPreset("Nature"))" FullWidth Style="background-color: #2E7D32; color: white; justify-content: flex-start; text-transform: none; padding: 12px; border-radius: 10px;">Nature Inspired</MudButton>
                            <MudButton Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Bolt" OnClick="@(() => ApplyPreset("Energy"))" FullWidth Style="background-color: #FF6D00; color: white; justify-content: flex-start; text-transform: none; padding: 12px; border-radius: 10px;">Vibrant Energy</MudButton>
                            <MudButton Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.ColorLens" OnClick="@(() => ApplyPreset("Pastel"))" FullWidth Style="background-color: #F48FB1; color: white; justify-content: flex-start; text-transform: none; padding: 12px; border-radius: 10px;">Soft Pastels</MudButton>
                            <MudButton Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.AutoAwesome" OnClick="@(() => ApplyPreset("Elegance"))" FullWidth Style="background-color: #8D6E63; color: white; justify-content: flex-start; text-transform: none; padding: 12px; border-radius: 10px;">Neutral Elegance</MudButton>
                            <MudButton Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.WbSunny" OnClick="@(() => ApplyPreset("Retro"))" FullWidth Style="background-color: #E64A19; color: white; justify-content: flex-start; text-transform: none; padding: 12px; border-radius: 10px;">Retro Sunset</MudButton>
                            <MudDivider Class="my-4" />
                            <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.LightMode" OnClick="@(() => ApplyPreset("Default"))" FullWidth Color="Color.Primary" Style="justify-content: flex-start; text-transform: none; padding: 12px; border-radius: 10px;">Standard Light</MudButton>
                            <MudButton Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Visibility" OnClick="@(() => ApplyPreset("HighContrast"))" FullWidth Style="background-color: #000000; color: #FFFF00; border: 2px solid #FFFF00; justify-content: flex-start; text-transform: none; padding: 12px; border-radius: 10px;">High Contrast (WCAG)</MudButton>
                        </MudStack>
                    </MudPaper>
                </MudItem>
            </MudGrid>
            
            <MudDivider Class="my-12" />
            <MudStack Row="true" AlignItems="AlignItems.Center">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Save" Size="Size.Large" OnClick="SaveThemeSettings" Style="padding: 12px 32px; border-radius: 12px;">Design permanent speichern</MudButton>
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="ml-6">Presets werden sofort live angewendet.</MudText>
            </MudStack>
        </MudTabPanel>

        <!-- TAB 2: ASSET-LEBENSZYKLUS -->
        <MudTabPanel Icon="@Icons.Material.Filled.Recycling" Text="Asset-Lebenszyklus">
            <MudText Typo="Typo.h6" Class="mb-4 font-weight-bold">Phasen & Status-Werte</MudText>
            <MudText Typo="Typo.body2" Class="mb-10" Color="Color.Secondary">Diese Auswahlfelder stehen systemweit in der Asset-Detailansicht zur Verfügung.</MudText>

            @if (_lifecycleConfig == null)
            {
                <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
            }
            else
            {
                @foreach (var phase in _lifecycleConfig.Keys.ToList())
                {
                    <MudPaper Class="pa-10 mb-10" Elevation="2" Style="border-radius: 20px;">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-8">
                            <MudIcon Icon="@Icons.Material.Filled.Label" Color="Color.Primary" Size="Size.Medium" />
                            <MudTextField @bind-Value="_phaseRenames[phase]" Label="Name der Phase" Variant="Variant.Text" FullWidth="false" Style="width: 450px; font-weight: bold; font-size: 1.2rem;" />
                            <MudSpacer />
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" OnClick="@(() => RemovePhase(phase))" ToolTip="Phase löschen" Size="Size.Medium" />
                        </MudStack>
                        
                        <MudDivider Class="mb-8" />
                        
                        <MudText Typo="Typo.caption" Class="mb-4 d-block" Style="text-transform: uppercase; letter-spacing: 1.2px; opacity: 0.8; font-weight: 700;">Zugeordnete Status-Werte:</MudText>
                        <MudChipSet T="string" AllClosable="true" OnClose="@((chip) => { if (chip.Text != null) RemoveStatus(phase, chip.Text); })">
                            @foreach (var status in _lifecycleConfig[phase])
                            {
                                <MudChip Text="@status" Color="Color.Primary" Variant="Variant.Text" Style="font-weight: 600; padding: 8px 16px;" />
                            }
                        </MudChipSet>
                        
                        <MudStack Row="true" Class="mt-10" AlignItems="AlignItems.Center">
                            <MudTextField T="string" @bind-Value="_newStatusInputs[phase]" Placeholder="Neuen Status hinzufügen..." Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true" />
                            <MudIconButton Icon="@Icons.Material.Filled.Add" Color="Color.Success" OnClick="@(() => AddStatus(phase))" Variant="Variant.Filled" Class="ml-4" Style="border-radius: 8px;" />
                        </MudStack>
                    </MudPaper>
                }
                <MudButton StartIcon="@Icons.Material.Filled.AddCircle" Color="Color.Primary" Variant="Variant.Outlined" OnClick="AddPhase" Class="mt-6" Size="Size.Large" Style="border-radius: 12px; padding: 12px 24px;">Neue Phase hinzufügen</MudButton>
            }
            
            <MudDivider Class="my-12" />
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Save" Size="Size.Large" OnClick="SaveLifecycleSettings" Style="padding: 12px 32px; border-radius: 12px;">Lebenszyklus Speichern</MudButton>
        </MudTabPanel>

        <!-- TAB 3: ÜBER INFRADESK -->
        <MudTabPanel Icon="@Icons.Material.Filled.Info" Text="Über InfraDesk">
            <div class="d-flex justify-center py-10">
                <MudPaper Class="pa-16 d-flex flex-column align-center" Elevation="4" Outlined="true" Style="max-width: 900px; width: 100%; border-radius: 32px; background-color: var(--mud-palette-surface);">
                    
                    <div class="mb-12 d-flex justify-center">
                        <img src="InfraDesk_Ico.png" alt="InfraDesk Logo" style="height: 160px; object-fit: contain;" />
                    </div>
                    
                    <MudText Typo="Typo.h3" Class="font-weight-bold mb-2" Align="Align.Center">InfraDesk Enterprise</MudText>
                    <MudText Typo="Typo.h6" Color="Color.Primary" Class="mb-12" Align="Align.Center" Style="letter-spacing: 1px; opacity: 0.8;">Professional IT Infrastructure Management</MudText>
                    
                    <MudGrid Class="w-100 px-8" Spacing="4">
                        <MudItem xs="12">
                            <MudDivider Class="mb-8" />
                        </MudItem>
                        
                        <MudItem xs="5" Class="d-flex align-center">
                            <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" Class="mr-4" Color="Color.Secondary" />
                            <MudText Typo="Typo.body1" Class="font-weight-bold">Autor:</MudText>
                        </MudItem>
                        <MudItem xs="7">
                            <MudText Typo="Typo.body1">Christian Grams</MudText>
                        </MudItem>
                        
                        <MudItem xs="5" Class="d-flex align-center">
                            <MudIcon Icon="@Icons.Material.Filled.Business" Size="Size.Small" Class="mr-4" Color="Color.Secondary" />
                            <MudText Typo="Typo.body1" Class="font-weight-bold">Unternehmen:</MudText>
                        </MudItem>
                        <MudItem xs="7">
                            <MudText Typo="Typo.body1">Grams IT</MudText>
                        </MudItem>

                        <MudItem xs="5" Class="d-flex align-center">
                            <MudIcon Icon="@Icons.Material.Filled.Verified" Size="Size.Small" Class="mr-4" Color="Color.Secondary" />
                            <MudText Typo="Typo.body1" Class="font-weight-bold">Lizenz:</MudText>
                        </MudItem>
                        <MudItem xs="7">
                            <MudText Typo="Typo.body1">Enterprise Subscription</MudText>
                        </MudItem>

                        <MudItem xs="5" Class="d-flex align-center">
                            <MudIcon Icon="@Icons.Material.Filled.Update" Size="Size.Small" Class="mr-4" Color="Color.Secondary" />
                            <MudText Typo="Typo.body1" Class="font-weight-bold">Version:</MudText>
                        </MudItem>
                        <MudItem xs="7">
                            <div class="d-flex align-center">
                                <MudChip T="string" Color="Color.Info" Size="Size.Medium" Variant="Variant.Outlined" Style="font-weight: 800; font-family: monospace;">@_currentVersion</MudChip>
                                <MudIconButton Icon="@Icons.Material.Filled.Refresh" Size="Size.Medium" OnClick="CheckForUpdates" Class="ml-4" Color="Color.Primary" Title="Auf GitHub nach Updates suchen" Loading="_isCheckingUpdate" />
                            </div>
                        </MudItem>

                        <MudItem xs="12" Class="mt-8">
                            <MudExpansionPanels MultiExpansion="true" Elevation="0">
                                <MudExpansionPanel Text="GitHub Update-Konfiguration (Private Projekte)" Icon="@Icons.Custom.Brands.GitHub">
                                    <MudAlert Severity="Severity.Warning" Dense="true" Class="mb-4" Style="border-radius: 8px;">
                                        Für den Zugriff auf private Repositories wird ein <b>Personal Access Token (PAT)</b> benötigt.
                                    </MudAlert>
                                    <MudTextField @bind-Value="_gitHubToken" Label="GitHub Personal Access Token"
                                                  Variant="Variant.Outlined" Margin="Margin.Dense"
                                                  InputType="InputType.Password" Placeholder="ghp_..."
                                                  HelperText="Wird nur für diese Session im Speicher gehalten." />
                                </MudExpansionPanel>
                            </MudExpansionPanels>
                        </MudItem>
                        
                        @if (_newVersionAvailable)
                        {
                            <MudItem xs="12">
                                <MudAlert Severity="Severity.Info" Variant="Variant.Filled" Square="false" Class="mt-8 py-6" Icon="@Icons.Material.Filled.NewReleases" Style="border-radius: 16px;">
                                    Eine neue Version (@_latestVersionTag) ist auf GitHub verfügbar!
                                    <MudLink Href="@_githubReleaseUrl" Target="_blank" Color="Color.Inherit" Underline="Underline.Always" Class="ml-4 font-weight-bold">Release Notes ansehen</MudLink>
                                </MudAlert>
                            </MudItem>
                        }
                        else if (_isUpToDate)
                        {
                            <MudItem xs="12">
                                <MudAlert Severity="Severity.Success" Variant="Variant.Outlined" Dense="false" Class="mt-8" Icon="@Icons.Material.Filled.CheckCircle" Style="border-radius: 16px;">
                                    Ihre Installation ist auf dem aktuellsten Stand.
                                </MudAlert>
                            </MudItem>
                        }

                        <MudItem xs="12">
                            <MudDivider Class="mt-12 mb-10" />
                        </MudItem>
                    </MudGrid>

                    <MudText Typo="Typo.caption" Align="Align.Center" Style="line-height: 2; opacity: 0.8; font-size: 0.9rem;">
                        &copy; @DateTime.Now.Year Grams IT. Alle Rechte vorbehalten.<br />
                        Exklusiv entwickelt für hochverfügbare IT-Infrastrukturen,<br />
                        professionelles Asset-Management und Helpdesk-Services.
                    </MudText>
                </MudPaper>
            </div>
        </MudTabPanel>

    </MudTabs>
</MudContainer>

@code {
    private ThemeConfig _themeConfig = new();
    private Dictionary<string, List<string>>? _lifecycleConfig;
    private Dictionary<string, string> _newStatusInputs = new();
    private Dictionary<string, string> _phaseRenames = new();

    // Start-Wert, der sofort im OnInitializedAsync überschrieben wird
    private string _currentVersion = "Lade...";
    private string _gitHubToken = "";
    private bool _isCheckingUpdate = false;
    private bool _newVersionAvailable = false;
    private bool _isUpToDate = false;
    private string _latestVersionTag = "";
    private string _githubReleaseUrl = "";

    protected override async Task OnInitializedAsync()
    {
        _themeConfig = ThemeService.Config;
        
        // Dynamisches Auslesen der Version aus der aktuellen Assembly
        var version = Assembly.GetExecutingAssembly().GetName().Version;
        if (version != null)
        {
            _currentVersion = version.ToString(); // Setzt z.B. 2026.4.30.45
        }

        await LoadLifecycleSettings();
    }

    private async Task CheckForUpdates()
    {
        _isCheckingUpdate = true;
        _isUpToDate = false;
        _newVersionAvailable = false;

        var latest = await UpdateService.GetLatestReleaseAsync(_gitHubToken);
        
        if (latest != null)
        {
            var cleanTag = latest.TagName.TrimStart('v');
            _latestVersionTag = latest.TagName;
            _githubReleaseUrl = latest.HtmlUrl;

            if (cleanTag != _currentVersion)
            {
                _newVersionAvailable = true;
                Snackbar.Add($"Update verfügbar: {latest.TagName}", Severity.Info);
            }
            else
            {
                _isUpToDate = true;
            }
        }
        else
        {
            Snackbar.Add("Prüfung fehlgeschlagen. Bitte GitHub-Token prüfen.", Severity.Warning);
        }

        _isCheckingUpdate = false;
    }

    private void NotifyManualChange() => ThemeService.UpdateConfig(_themeConfig);

    private void ApplyPreset(string name)
    {
        var cfg = new ThemeConfig();
        cfg.FontFamily = _themeConfig.FontFamily;
        cfg.BaseFontSize = _themeConfig.BaseFontSize;

        switch (name)
        {
            case "Midnight":
                cfg.IsDark = true;
                cfg.PrimaryColor = "#3F51B5";
                cfg.SecondaryColor = "#5C6BC0";
                cfg.BackgroundColor = "#0A0E21";
                cfg.SurfaceColor = "#161B33";
                cfg.AppbarColor = "#0D1117";
                cfg.AppbarText = "#E0E0E0";
                cfg.DrawerColor = "#161B33";
                cfg.DrawerText = "#E0E0E0";
                cfg.DrawerIcon = "#3F51B5";
                cfg.TextPrimary = "#E0E0E0";
                break;
            case "Nature":
                cfg.PrimaryColor = "#2E7D32";
                cfg.SecondaryColor = "#689F38";
                cfg.BackgroundColor = "#F1F8E9";
                cfg.SurfaceColor = "#FFFFFF";
                cfg.AppbarColor = "#1B5E20";
                cfg.AppbarText = "#FFFFFF";
                cfg.DrawerColor = "#FFFFFF";
                cfg.DrawerText = "#1B5E20";
                cfg.DrawerIcon = "#2E7D32";
                cfg.TextPrimary = "#1B5E20";
                break;
            case "Energy":
                cfg.PrimaryColor = "#FF6D00";
                cfg.SecondaryColor = "#00B8D4";
                cfg.BackgroundColor = "#FFF3E0";
                cfg.SurfaceColor = "#FFFFFF";
                cfg.AppbarColor = "#E65100";
                cfg.AppbarText = "#FFFFFF";
                cfg.DrawerColor = "#FFFFFF";
                cfg.DrawerText = "#3E2723";
                cfg.DrawerIcon = "#FF6D00";
                cfg.TextPrimary = "#3E2723";
                break;
            case "Pastel":
                cfg.PrimaryColor = "#F48FB1";
                cfg.SecondaryColor = "#90CAF9";
                cfg.BackgroundColor = "#FFF1F6";
                cfg.SurfaceColor = "#FFFFFF";
                cfg.AppbarColor = "#AD1457";
                cfg.AppbarText = "#FFFFFF";
                cfg.DrawerColor = "#FFFFFF";
                cfg.DrawerText = "#880E4F";
                cfg.DrawerIcon = "#F48FB1";
                cfg.TextPrimary = "#880E4F";
                break;
            case "Elegance":
                cfg.PrimaryColor = "#5D4037";
                cfg.SecondaryColor = "#8D6E63";
                cfg.BackgroundColor = "#FAF9F6";
                cfg.SurfaceColor = "#FFFFFF";
                cfg.AppbarColor = "#3E2723";
                cfg.AppbarText = "#FFFFFF";
                cfg.DrawerColor = "#FFFFFF";
                cfg.DrawerText = "#3E2723";
                cfg.DrawerIcon = "#5D4037";
                cfg.TextPrimary = "#3E2723";
                break;
            case "Retro":
                cfg.PrimaryColor = "#E64A19";
                cfg.SecondaryColor = "#00796B";
                cfg.BackgroundColor = "#FFFDE7";
                cfg.SurfaceColor = "#FFFFFF";
                cfg.AppbarColor = "#BF360C";
                cfg.AppbarText = "#FFFFFF";
                cfg.DrawerColor = "#FFFFFF";
                cfg.DrawerText = "#212121";
                cfg.DrawerIcon = "#E64A19";
                cfg.TextPrimary = "#212121";
                break;
            case "Monochrome":
                cfg.PrimaryColor = "#212121";
                cfg.SecondaryColor = "#D32F2F";
                cfg.BackgroundColor = "#F5F5F5";
                cfg.SurfaceColor = "#FFFFFF";
                cfg.AppbarColor = "#000000";
                cfg.AppbarText = "#FFFFFF";
                cfg.DrawerColor = "#FFFFFF";
                cfg.DrawerText = "#000000";
                cfg.DrawerIcon = "#212121";
                cfg.TextPrimary = "#000000";
                break;
            case "HighContrast":
                cfg.PrimaryColor = "#FFFF00";
                cfg.SecondaryColor = "#FFFFFF";
                cfg.BackgroundColor = "#000000";
                cfg.SurfaceColor = "#000000";
                cfg.AppbarColor = "#000000";
                cfg.AppbarText = "#FFFF00";
                cfg.DrawerColor = "#000000";
                cfg.DrawerText = "#FFFFFF";
                cfg.DrawerIcon = "#FFFF00";
                cfg.TextPrimary = "#FFFFFF";
                break;
            default: // Corporate Blue / Default
                cfg.PrimaryColor = "#1976D2";
                cfg.SecondaryColor = "#424242";
                cfg.BackgroundColor = "#F0F2F5";
                cfg.SurfaceColor = "#FFFFFF";
                cfg.AppbarColor = "#333333";
                cfg.AppbarText = "#FFFFFF";
                cfg.DrawerColor = "#FFFFFF";
                cfg.DrawerText = "#424242";
                cfg.DrawerIcon = "#1976D2";
                cfg.TextPrimary = "#424242";
                break;
        }

        _themeConfig = cfg;
        ThemeService.UpdateConfig(cfg);
        Snackbar.Add($"Preset '{name}' wurde angewendet.", Severity.Info);
    }

    private void SaveThemeSettings()
    {
        ThemeService.UpdateConfig(_themeConfig);
        Snackbar.Add("Design-Einstellungen wurden permanent übernommen.", Severity.Success);
    }

    private async Task LoadLifecycleSettings()
    {
        try
        {
            _lifecycleConfig = await Http.GetFromJsonAsync<Dictionary<string, List<string>>>("api/settings/asset-lifecycle");
            if (_lifecycleConfig != null)
            {
                foreach (var k in _lifecycleConfig.Keys)
                {
                    _newStatusInputs[k] = "";
                    _phaseRenames[k] = k;
                }
            }
        }
        catch { }
    }

    private void AddStatus(string phase)
    {
        if (!string.IsNullOrWhiteSpace(_newStatusInputs[phase]))
        {
            _lifecycleConfig?[phase].Add(_newStatusInputs[phase]);
            _newStatusInputs[phase] = "";
        }
    }

    private void RemoveStatus(string phase, string status)
    {
        if (_lifecycleConfig != null && _lifecycleConfig.ContainsKey(phase))
            _lifecycleConfig[phase].Remove(status);
    }

    private void AddPhase()
    {
        var name = "Neue Phase";
        if (_lifecycleConfig != null && !_lifecycleConfig.ContainsKey(name))
        {
            _lifecycleConfig.Add(name, new List<string>());
            _newStatusInputs[name] = "";
            _phaseRenames[name] = name;
        }
    }

    private void RemovePhase(string phase) => _lifecycleConfig?.Remove(phase);

    private async Task SaveLifecycleSettings()
    {
        if (_lifecycleConfig == null) return;
        var finalConfig = new Dictionary<string, List<string>>();
        foreach (var entry in _lifecycleConfig)
            finalConfig.Add(_phaseRenames[entry.Key], entry.Value);

        var response = await Http.PostAsJsonAsync("api/settings/asset-lifecycle", finalConfig);
        if (response.IsSuccessStatusCode) Snackbar.Add("Lebenszyklus erfolgreich gespeichert!", Severity.Success);
    }
}