@* Dateipfad: src/InfraDesk.UI.Web/Components/Pages/Settings.razor *@
@page "/settings"
@using InfraDesk.Core.Entities
@using MudBlazor
@using InfraDesk.UI.Web.Services
@using System.Net.Http.Headers
@using System.Text.Json
@inject HttpClient Http
@inject ThemeService ThemeService
@inject ISnackbar Snackbar
@inject IJSRuntime JSRuntime
@inject NavigationManager Nav
@inject UpdateService UpdateService

<PageTitle>InfraDesk - Einstellungen</PageTitle>

<style>
    .pdq-container { background-color: #fff; height: calc(100vh - 110px); display: flex; flex-direction: row; border: 1px solid #ccc; border-radius: 4px; overflow: hidden; }
    .pdq-sidebar { width: 240px; border-right: 1px solid #ccc; background-color: #f0f0f0; overflow-y: auto; flex-shrink: 0; }
    .pdq-content { flex-grow: 1; overflow-y: auto; background-color: #fff; padding: 24px; }
    .pdq-toolbar { height: 42px; background-color: #eee; border-bottom: 1px solid #ccc; display: flex; align-items: center; padding: 0 12px; }
    .sidebar-active { background-color: #fff !important; font-weight: bold; border-left: 4px solid var(--mud-palette-primary); color: var(--mud-palette-primary) !important; }
    .pdq-section-header { background-color: #e0e0e0; padding: 4px 12px; font-weight: 800; font-size: 0.75rem; text-transform: uppercase; border-bottom: 1px solid #ccc; border-top: 1px solid #ccc; color: #333; margin-bottom: 16px; margin-top: 24px; }
    .pdq-section-header:first-child { margin-top: 0; border-top: none; }
    
    .master-detail-grid { display: grid; grid-template-columns: 350px 1fr; border: 1px solid #ccc; border-radius: 4px; background: #fff; min-height: 60vh; }
    .master-pane { border-right: 1px solid #ccc; background: #fafafa; padding: 12px; overflow-y: auto; }
    .detail-pane { padding: 24px; overflow-y: auto; }

    .info-grid { display: grid; grid-template-columns: 140px 1fr; gap: 12px; padding: 20px; background-color: #fafafa; border-radius: 8px; border: 1px solid #eee; margin-bottom: 24px; }
    .info-label { font-weight: bold; color: #666; font-size: 0.85rem; display: flex; align-items: center; }
    .info-value { font-weight: 600; color: #333; font-size: 0.9rem; display: flex; align-items: center; }
    
    .status-ok-text { color: #2e7d32; font-weight: 800; font-size: 0.85rem; display: flex; align-items: center; gap: 8px; background: #e8f5e9; padding: 4px 12px; border-radius: 4px; border: 1px solid #c8e6c9; }
    .status-update-text { color: #c62828; font-weight: 800; font-size: 0.85rem; display: flex; align-items: center; gap: 8px; background: #ffebee; padding: 4px 12px; border-radius: 4px; border: 1px solid #ffcdd2; }
    .status-error-text { color: #666; font-weight: 800; font-size: 0.85rem; display: flex; align-items: center; gap: 8px; background: #f5f5f5; padding: 4px 12px; border-radius: 4px; border: 1px solid #e0e0e0; }
    
    .footer-copyright { text-align: center; color: #999; font-size: 0.75rem; padding: 20px 0; width: 100%; }
    .info-logo-monochrome { height: 60px; margin-bottom: 16px; filter: grayscale(100%) brightness(0); opacity: 0.8; }

    /* Label Preview Styles */
    .label-preview-container { display: flex; justify-content: center; padding: 20px; background: #999; border-radius: 8px; }
    .physical-label { background: white; padding: 4mm; box-shadow: 0 4px 10px rgba(0,0,0,0.3); display: flex; flex-direction: column; align-items: center; justify-content: space-between; font-family: sans-serif; overflow: hidden; }
    .label-header { border-bottom: 1px solid #eee; width: 100%; text-align: center; font-weight: bold; margin-bottom: 2mm; text-overflow: ellipsis; white-space: nowrap; overflow: hidden; }
    .barcode-svg-mock { width: 100%; height: 10mm; background: repeating-linear-gradient(90deg, #000, #000 1px, #fff 1px, #fff 3px); margin-bottom: 1mm; }
    .qr-white-inner { background: white; padding: 2px; border: 1px solid #eee; display: flex; align-items: center; justify-content: center; position: relative; }
    .qr-logo-overlay { position: absolute; background: white; padding: 1px; border-radius: 2px; }
    .label-footer { border-top: 1px solid #eee; width: 100%; text-align: center; font-size: 0.6rem; margin-top: 2mm; color: #666; text-overflow: ellipsis; white-space: nowrap; overflow: hidden; }
</style>

<div class="pdq-toolbar">
    <MudIcon Icon="@Icons.Material.Filled.Settings" Color="Color.Primary" Size="Size.Small" Class="mr-2" />
    <MudText Typo="Typo.body2" Class="font-weight-bold">System-Konfiguration</MudText>
    <MudSpacer />
    @if (_activeSection != "Info")
    {
        <MudButton Variant="Variant.Filled" Color="Color.Success" Size="Size.Small" StartIcon="@Icons.Material.Filled.Save" OnClick="SaveSettings" Loading="_isSaving">Speichern</MudButton>
    }
</div>

<div class="pdq-container">
    <div class="pdq-sidebar">
        <MudNavMenu Margin="Margin.Dense" Rounded="false">
            <div class="pdq-section-header">Mandant & Organisation</div>
            <MudNavLink OnClick="@(() => _activeSection = "MasterData")" Class="@(_activeSection == "MasterData" ? "sidebar-active" : "")" Icon="@Icons.Material.Filled.Business">Stammdaten</MudNavLink>
            <MudNavLink OnClick="@(() => _activeSection = "Locations")" Class="@(_activeSection == "Locations" ? "sidebar-active" : "")" Icon="@Icons.Material.Filled.LocationCity">Standorte & Räume</MudNavLink>
            <MudNavLink OnClick="@(() => _activeSection = "Persons")" Class="@(_activeSection == "Persons" ? "sidebar-active" : "")" Icon="@Icons.Material.Filled.People">Personen & Teams</MudNavLink>
            <MudNavLink OnClick="@(() => _activeSection = "Lifecycle")" Class="@(_activeSection == "Lifecycle" ? "sidebar-active" : "")" Icon="@Icons.Material.Filled.Autorenew">Asset-Lebenszyklus</MudNavLink>
            <MudNavLink OnClick="@(() => _activeSection = "TagSchema")" Class="@(_activeSection == "TagSchema" ? "sidebar-active" : "")" Icon="@Icons.Material.Filled.QrCode">Asset-Tag Schema</MudNavLink>
            <MudNavLink OnClick="@(() => _activeSection = "AssetTypes")" Class="@(_activeSection == "AssetTypes" ? "sidebar-active" : "")" Icon="@Icons.Material.Filled.AccountTree">Asset Kategorien</MudNavLink>
            
            <div class="pdq-section-header">Service-Desk / ITSM</div>
            <MudNavLink OnClick="@(() => _activeSection = "TicketViews")" Class="@(_activeSection == "TicketViews" ? "sidebar-active" : "")" Icon="@Icons.Material.Filled.FilterAlt">Standard-Ansichten</MudNavLink>
            <MudNavLink OnClick="@(() => _activeSection = "TicketLifecycle")" Class="@(_activeSection == "TicketLifecycle" ? "sidebar-active" : "")" Icon="@Icons.Material.Filled.LowPriority">Status & Prioritäten</MudNavLink>

            <div class="pdq-section-header">UI & Personalisierung</div>
            <MudNavLink OnClick="@(() => _activeSection = "Design")" Class="@(_activeSection == "Design" ? "sidebar-active" : "")" Icon="@Icons.Material.Filled.Palette">Farben & Themes</MudNavLink>
            
            <div class="pdq-section-header">System & Service</div>
            <MudNavLink OnClick="@(() => _activeSection = "Info")" Class="@(_activeSection == "Info" ? "sidebar-active" : "")" Icon="@Icons.Material.Filled.Update">Update & Info</MudNavLink>
        </MudNavMenu>
    </div>

    <div class="pdq-content">
        @if (_isLoading)
        {
            <div class="d-flex justify-center align-center" style="height: 200px;"><MudProgressCircular Color="Color.Primary" Indeterminate="true" /></div>
        }
        else
        {
            @if (_activeSection == "AssetTypes")
            {
                <div class="pdq-section-header">Asset Kategorien (Taxonomie-Baum)</div>
                <div class="master-detail-grid">
                    <div class="master-pane">
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" StartIcon="@Icons.Material.Filled.Add" Class="mb-4" OnClick="AddAssetType">Neue Kategorie</MudButton>
                        <MudTreeView T="Guid?" SelectedValue="@_editCategoryId" SelectedValueChanged="OnCategorySelected" Hover="true" Dense="true" Color="Color.Primary">
                            @RenderCategoryTreeNodes(_dynamicAssetTypes.Where(t => t.ParentAssetTypeId == null).OrderBy(t => t.Name))
                        </MudTreeView>
                    </div>
                    <div class="detail-pane">
                        @if (_editCategory != null)
                        {
                            <MudText Typo="Typo.h6" Class="mb-4">Kategorie bearbeiten</MudText>
                            <MudTextField @bind-Value="_editCategory.Name" Label="Kategorie-Name" Variant="Variant.Outlined" Required="true" Class="mb-4" />
                            <MudTextField @bind-Value="_editCategory.Description" Label="Beschreibung" Variant="Variant.Outlined" Lines="2" Class="mb-4" />
                            <MudSelect T="Guid?" @bind-Value="_editCategory.ParentAssetTypeId" Label="Übergeordnete Kategorie" Clearable="true" Variant="Variant.Outlined" Class="mb-4">
                                @foreach(var parent in _dynamicAssetTypes.Where(t => t.Id != _editCategory.Id).OrderBy(t => t.Name)) {
                                    <MudSelectItem T="Guid?" Value="@parent.Id">@GetCategoryPath(parent.Id)</MudSelectItem>
                                }
                            </MudSelect>
                            <MudSelect T="string" @bind-Value="_editCategory.IconKey" Label="Symbol (Icon)" Variant="Variant.Outlined" Class="mb-6">
                                @foreach(var icon in _availableIcons) {
                                    <MudSelectItem Value="@icon"><div class="d-flex align-center"><MudIcon Icon="@GetDynamicIcon(icon)" Size="Size.Small" Class="mr-3"/> @icon</div></MudSelectItem>
                                }
                            </MudSelect>
                            <div class="d-flex gap-2">
                                <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Save" OnClick="SaveCategory">Speichern</MudButton>
                                <MudButton Variant="Variant.Outlined" Color="Color.Error" StartIcon="@Icons.Material.Filled.Delete" OnClick="DeleteCategory">Löschen</MudButton>
                            </div>
                        }
                        else { <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mt-10 text-center">Wählen Sie links eine Kategorie aus oder erstellen Sie eine neue.</MudText> }
                    </div>
                </div>
            }
            else if (_activeSection == "Locations")
            {
                <div class="pdq-section-header">Standorte, Gebäude & Räume</div>
                <div class="master-detail-grid">
                    <div class="master-pane">
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" StartIcon="@Icons.Material.Filled.Add" Class="mb-4" OnClick="AddLocation">Neuer Standort</MudButton>
                        <MudTreeView T="Guid?" SelectedValue="@_editLocationId" SelectedValueChanged="OnLocationSelected" Hover="true" Dense="true" Color="Color.Primary">
                            @RenderLocationTreeNodes(_locations.Where(l => l.ParentLocationId == null).OrderBy(l => l.Name))
                        </MudTreeView>
                    </div>
                    <div class="detail-pane">
                        @if (_editLocation != null)
                        {
                            <MudText Typo="Typo.h6" Class="mb-4">Standort bearbeiten</MudText>
                            <MudTextField @bind-Value="_editLocation.Name" Label="Standort / Raumname" Variant="Variant.Outlined" Required="true" Class="mb-4" />
                            <MudTextField @bind-Value="_editLocation.Address" Label="Adresse / Details" Variant="Variant.Outlined" Class="mb-4" />
                            <MudTextField @bind-Value="_editLocation.RoomNumber" Label="Raum-Nummer" Variant="Variant.Outlined" Class="mb-4" />
                            <MudSelect T="Guid?" @bind-Value="_editLocation.ParentLocationId" Label="Übergeordneter Standort (Hierarchie)" Clearable="true" Variant="Variant.Outlined" Class="mb-6">
                                @foreach(var loc in _locations.Where(l => l.Id != _editLocation.Id).OrderBy(l => GetLocationPath(l.Id))) {
                                    <MudSelectItem T="Guid?" Value="@loc.Id">@GetLocationPath(loc.Id)</MudSelectItem>
                                }
                            </MudSelect>
                            <div class="d-flex gap-2">
                                <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Save" OnClick="SaveLocation">Speichern</MudButton>
                                <MudButton Variant="Variant.Outlined" Color="Color.Error" StartIcon="@Icons.Material.Filled.Delete" OnClick="DeleteLocation">Löschen</MudButton>
                            </div>
                        }
                        else { <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mt-10 text-center">Wählen Sie links einen Standort aus.</MudText> }
                    </div>
                </div>
            }
            else if (_activeSection == "Persons")
            {
                <div class="pdq-section-header">Teams & Personen</div>
                <div class="master-detail-grid">
                    <div class="master-pane">
                        <div class="d-flex gap-2 mb-4">
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" StartIcon="@Icons.Material.Filled.GroupAdd" OnClick="AddTeam">Team</MudButton>
                            <MudButton Variant="Variant.Outlined" Color="Color.Primary" FullWidth="true" StartIcon="@Icons.Material.Filled.PersonAdd" OnClick="AddPerson">Person</MudButton>
                        </div>
                        <MudTreeView T="string" SelectedValue="@_editOrgId" SelectedValueChanged="OnOrgSelected" Hover="true" Dense="true" Color="Color.Primary">
                            @foreach (var team in _teams.OrderBy(t => t.Name)) {
                                <MudTreeViewItem T="string" Value="@($"TEAM_{team.Id}")" Text="@team.Name" Icon="@Icons.Material.Filled.Groups" Expanded="true">
                                    @foreach (var person in _personsByTeam[team.Id].OrderBy(p => p.LastName)) {
                                        <MudTreeViewItem T="string" Value="@($"PERS_{person.Id}")" Text="@($"{person.LastName}, {person.FirstName}")" Icon="@Icons.Material.Filled.Person" />
                                    }
                                </MudTreeViewItem>
                            }
                            @if (_personsByTeam[null].Any()) {
                                <MudTreeViewItem T="string" Value="@("NO_TEAM")" Text="Ohne Team-Zuweisung" Icon="@Icons.Material.Filled.FolderOff" Expanded="true">
                                    @foreach (var person in _personsByTeam[null].OrderBy(p => p.LastName)) {
                                        <MudTreeViewItem T="string" Value="@($"PERS_{person.Id}")" Text="@($"{person.LastName}, {person.FirstName}")" Icon="@Icons.Material.Filled.Person" />
                                    }
                                </MudTreeViewItem>
                            }
                        </MudTreeView>
                    </div>
                    <div class="detail-pane">
                        @if (_editTeam != null) {
                            <MudText Typo="Typo.h6" Class="mb-4">Team bearbeiten</MudText>
                            <MudTextField @bind-Value="_editTeam.Name" Label="Team-Name" Variant="Variant.Outlined" Required="true" Class="mb-4" />
                            <MudSelect T="Guid?" @bind-Value="_editTeam.LeadId" Label="Team-Leitung (Lead)" Clearable="true" Variant="Variant.Outlined" Class="mb-6">
                                @foreach(var p in _persons.OrderBy(x => x.LastName)) { <MudSelectItem T="Guid?" Value="@p.Id">@p.LastName, @p.FirstName</MudSelectItem> }
                            </MudSelect>
                            <div class="d-flex gap-2">
                                <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Save" OnClick="SaveTeam">Speichern</MudButton>
                                <MudButton Variant="Variant.Outlined" Color="Color.Error" StartIcon="@Icons.Material.Filled.Delete" OnClick="DeleteTeam">Löschen</MudButton>
                            </div>
                        } else if (_editPerson != null) {
                            <MudText Typo="Typo.h6" Class="mb-4">Person bearbeiten</MudText>
                            <MudGrid Spacing="2" Class="mb-4">
                                <MudItem xs="6"><MudTextField @bind-Value="_editPerson.FirstName" Label="Vorname" Variant="Variant.Outlined" Required="true" /></MudItem>
                                <MudItem xs="6"><MudTextField @bind-Value="_editPerson.LastName" Label="Nachname" Variant="Variant.Outlined" Required="true" /></MudItem>
                                <MudItem xs="12"><MudTextField @bind-Value="_editPerson.Email" Label="E-Mail Adresse" Variant="Variant.Outlined" /></MudItem>
                                <MudItem xs="6">
                                    <MudSelect T="Guid?" @bind-Value="_editPerson.TeamId" Label="Team-Zuweisung" Clearable="true" Variant="Variant.Outlined">
                                        @foreach(var t in _teams.OrderBy(x => x.Name)) { <MudSelectItem T="Guid?" Value="@t.Id">@t.Name</MudSelectItem> }
                                    </MudSelect>
                                </MudItem>
                                <MudItem xs="6"><MudTextField @bind-Value="_editPerson.Department" Label="Freitext-Abteilung" Variant="Variant.Outlined" /></MudItem>
                                <MudItem xs="12">
                                    <MudSelect T="string" @bind-Value="_editPerson.SystemRole" Label="System-Rechte (Rolle)" Variant="Variant.Outlined" Class="mb-4">
                                        <MudSelectItem Value="@("Reader")">Reader (Nur Lesezugriff)</MudSelectItem>
                                        <MudSelectItem Value="@("CI Editor")">CI Editor (Support / Agent)</MudSelectItem>
                                        <MudSelectItem Value="@("Tenant Admin")">Tenant Admin</MudSelectItem>
                                        <MudSelectItem Value="@("Global Admin")">Global Admin</MudSelectItem>
                                    </MudSelect>
                                </MudItem>
                            </MudGrid>
                            <div class="d-flex gap-2">
                                <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Save" OnClick="SavePerson">Speichern</MudButton>
                                <MudButton Variant="Variant.Outlined" Color="Color.Error" StartIcon="@Icons.Material.Filled.Delete" OnClick="DeletePerson">Löschen</MudButton>
                            </div>
                        } else {
                            <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mt-10 text-center">Wählen Sie links ein Team oder eine Person aus.</MudText>
                        }
                    </div>
                </div>
            }
            else if (_activeSection == "MasterData")
            {
                <div class="pdq-section-header">Organisation & Mandant</div>
                <MudText Typo="Typo.body2" Class="mb-4" Color="Color.Secondary">Definieren Sie hier den internen System-Mandantennamen sowie den offiziellen Firmennamen (für Berichte und Etiketten).</MudText>
                
                <MudGrid Spacing="2">
                    <MudItem xs="12" md="6"><MudTextField @bind-Value="_masterData.TenantName" Label="System-Mandantenname (Anzeige oben links)" Variant="Variant.Outlined" Margin="Margin.Dense" Required="true" HelperText="z.B. IT-Betrieb" /></MudItem>
                    <MudItem xs="12" md="6"><MudTextField @bind-Value="_masterData.CompanyName" Label="Offizieller Firmenname" Variant="Variant.Outlined" Margin="Margin.Dense" Required="true" HelperText="Wird auf Etiketten gedruckt." /></MudItem>
                    
                    <MudItem xs="12" md="4"><MudTextField @bind-Value="_masterData.CompanyPrefix" Label="Asset-Präfix (3 Stellen)" Variant="Variant.Outlined" Margin="Margin.Dense" MaxLength="3" HelperText="z.B. GIT für Grams IT" Required="true" /></MudItem>
                    <MudItem xs="12" md="8"><MudTextField @bind-Value="_masterData.Domain" Label="E-Mail Domäne" Variant="Variant.Outlined" Margin="Margin.Dense" Placeholder="firma.de" /></MudItem>
                    
                    <MudItem xs="12" md="12"><MudTextField @bind-Value="_masterData.Street" Label="Straße & Hausnummer" Variant="Variant.Outlined" Margin="Margin.Dense" /></MudItem>
                    <MudItem xs="12" md="4"><MudTextField @bind-Value="_masterData.ZipCity" Label="PLZ & Ort" Variant="Variant.Outlined" Margin="Margin.Dense" Required="true" /></MudItem>
                    <MudItem xs="12" md="4"><MudTextField @bind-Value="_masterData.State" Label="Bundesland" Variant="Variant.Outlined" Margin="Margin.Dense" /></MudItem>
                    <MudItem xs="12" md="4"><MudTextField @bind-Value="_masterData.Country" Label="Land" Variant="Variant.Outlined" Margin="Margin.Dense" /></MudItem>
                </MudGrid>
            }
            else if (_activeSection == "TagSchema")
            {
                <div class="pdq-section-header">Asset-Tag Generierung</div>
                <MudPaper Class="pa-6 mb-8" Outlined="true" Style="border-left: 6px solid var(--mud-palette-primary);">
                    <MudTextField @bind-Value="_masterData.AssetTagPattern" Label="Schema-Formel bearbeiten" Variant="Variant.Outlined" Margin="Margin.Dense" Placeholder="{COMP}-{LOC}-{CAT}-{NUM:5}" OnBlur="OnFieldChanged" />
                    <MudDivider Class="my-4" />
                    <MudText Typo="Typo.caption" Class="font-weight-bold mb-2 d-block">VORSCHAU:</MudText>
                    <MudText Typo="Typo.body1" Style="font-family: monospace; font-weight: bold; font-size: 1.2rem; background: #eee; padding: 12px; border-radius: 4px;">@GetTagPreview()</MudText>
                </MudPaper>

                <div class="pdq-section-header">Barcode & QR-Code Konfiguration</div>
                <MudGrid Spacing="3">
                    <MudItem xs="12" md="8">
                        <MudCard Outlined="true" Class="mb-4">
                            <MudCardContent>
                                <MudGrid Spacing="2">
                                    <MudItem xs="12">
                                        <MudSelect T="string" Label="Druckvorlage" @bind-Value="_masterData.LabelTemplate" @bind-Value:after="ApplyTemplateDimensions" Variant="Variant.Outlined" Margin="Margin.Dense" Dense="true">
                                            <MudSelectItem Value="@("Brother DK-11201 (29x90mm)")">Brother DK-11201 (29x90mm)</MudSelectItem>
                                            <MudSelectItem Value="@("Brother DK-11209 (29x62mm)")">Brother DK-11209 (29x62mm)</MudSelectItem>
                                            <MudSelectItem Value="@("Zebra Desktop 4x2 (102x51mm)")">Zebra Desktop 4x2 (102x51mm)</MudSelectItem>
                                            <MudSelectItem Value="@("Avery Zweckform 70x37mm")">Avery Zweckform 70x37mm</MudSelectItem>
                                            <MudSelectItem Value="@("Custom")">Benutzerdefiniert</MudSelectItem>
                                        </MudSelect>
                                    </MudItem>
                                    <MudItem xs="6">
                                        <MudSelect T="string" Label="Barcode Typ" @bind-Value="_masterData.BarcodeType" @bind-Value:after="OnFieldChanged" Variant="Variant.Outlined" Margin="Margin.Dense" Dense="true">
                                            <MudSelectItem Value="@("Code128")">Code 128</MudSelectItem>
                                            <MudSelectItem Value="@("Code39")">Code 39</MudSelectItem>
                                        </MudSelect>
                                    </MudItem>
                                    <MudItem xs="6">
                                        <MudSelect T="string" Label="QR ECC" @bind-Value="_masterData.QrErrorCorrection" @bind-Value:after="OnFieldChanged" Variant="Variant.Outlined" Margin="Margin.Dense" Dense="true">
                                            <MudSelectItem Value="@("L")">Level L (7%)</MudSelectItem>
                                            <MudSelectItem Value="@("M")">Level M (15%)</MudSelectItem>
                                            <MudSelectItem Value="@("Q")">Level Q (25%)</MudSelectItem>
                                            <MudSelectItem Value="@("H")">Level H (30%)</MudSelectItem>
                                        </MudSelect>
                                    </MudItem>
                                    <MudItem xs="12">
                                        <div class="d-flex flex-wrap gap-4">
                                            <MudCheckBox T="bool" @bind-Value="_masterData.ShowTextBelowBarcode" @bind-Value:after="OnFieldChanged" Label="ID-Klartext" Color="Color.Primary" Dense="true" />
                                            <MudCheckBox T="bool" @bind-Value="_masterData.PrintAssetName" @bind-Value:after="OnFieldChanged" Label="Asset Name" Color="Color.Primary" Dense="true" />
                                            <MudCheckBox T="bool" @bind-Value="_masterData.PrintSerialNumber" @bind-Value:after="OnFieldChanged" Label="Seriennummer" Color="Color.Primary" Dense="true" />
                                            <MudCheckBox T="bool" @bind-Value="_masterData.PrintCompanyName" @bind-Value:after="OnFieldChanged" Label="Firma" Color="Color.Primary" Dense="true" />
                                            <MudCheckBox T="bool" @bind-Value="_masterData.IncludeLogoInQr" @bind-Value:after="OnFieldChanged" Label="Logo (QR)" Color="Color.Primary" Dense="true" />
                                        </div>
                                    </MudItem>
                                    <MudItem xs="4"><MudNumericField T="int" @bind-Value="_masterData.LabelWidth" @bind-Value:after="OnFieldChanged" Label="B (mm)" Variant="Variant.Outlined" Margin="Margin.Dense" Disabled="@(_masterData.LabelTemplate != "Custom")" /></MudItem>
                                    <MudItem xs="4"><MudNumericField T="int" @bind-Value="_masterData.LabelHeight" @bind-Value:after="OnFieldChanged" Label="H (mm)" Variant="Variant.Outlined" Margin="Margin.Dense" Disabled="@(_masterData.LabelTemplate != "Custom")" /></MudItem>
                                    <MudItem xs="4"><MudNumericField T="int" @bind-Value="_masterData.PrintResolutionDpi" @bind-Value:after="OnFieldChanged" Label="DPI" Variant="Variant.Outlined" Margin="Margin.Dense" /></MudItem>
                                </MudGrid>
                            </MudCardContent>
                        </MudCard>
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <MudText Typo="Typo.subtitle2" Class="font-weight-bold mb-2">LIVE-VORSCHAU (ETIKETT)</MudText>
                        <div class="label-preview-container">
                            <div class="physical-label" style="@($"width: {Math.Min(_masterData.LabelWidth * 3.5, 250)}px; height: {Math.Min(_masterData.LabelHeight * 3.5, 150)}px;")">
                                @if (_masterData.PrintCompanyName) { <div class="label-header" style="font-size: 0.7rem;">@_masterData.CompanyName</div> }
                                <div class="d-flex align-center w-100 justify-space-around">
                                    <div class="d-flex flex-column align-center" style="flex: 1; overflow:hidden;">
                                        <div class="barcode-svg-mock"></div>
                                        @if (_masterData.ShowTextBelowBarcode) { <div style="font-size: 0.6rem; font-family: monospace; font-weight: bold;">@GetTagPreview()</div> }
                                    </div>
                                    <div class="qr-container ml-2">
                                        <div class="qr-white-inner">
                                            <MudIcon Icon="@Icons.Material.Filled.QrCode2" Size="Size.Large" Color="Color.Dark" />
                                            @if (_masterData.IncludeLogoInQr) { <div class="qr-logo-overlay"><MudIcon Icon="@Icons.Material.Filled.AutoFixHigh" Style="font-size: 10px;" Color="Color.Primary" /></div> }
                                        </div>
                                    </div>
                                </div>
                                <div class="label-footer">@(_masterData.PrintAssetName ? "PROD-SERVER-01" : "") @(_masterData.PrintSerialNumber ? "| SN-9938" : "")</div>
                            </div>
                        </div>
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" Class="mt-4" StartIcon="@Icons.Material.Filled.Print" OnClick="PrintTestLabel">Testausdruck</MudButton>
                    </MudItem>
                </MudGrid>
            }
            else if (_activeSection == "TicketViews")
            {
                <div class="pdq-section-header">Ticket-Queue & Filter-Optionen</div>
                <MudGrid Spacing="3">
                    <MudItem xs="12" md="6">
                        <MudCard Outlined="true" Class="h-100">
                            <MudCardContent>
                                <MudSelect T="string" Label="Standard-Filter beim Öffnen" @bind-Value="_masterData.TicketDefaultFilter" Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-2">
                                    <MudSelectItem Value="@("Alle")">Alle Tickets</MudSelectItem>
                                    <MudSelectItem Value="@("Meins")">Nur eigene Tickets</MudSelectItem>
                                    <MudSelectItem Value="@("NichtZugewiesen")">Warteschlange</MudSelectItem>
                                </MudSelect>
                                <MudSwitch T="bool" @bind-Value="_masterData.TicketShowClosed" Label="Geschlossene standardmäßig einblenden" Color="Color.Primary" />
                            </MudCardContent>
                        </MudCard>
                    </MudItem>
                </MudGrid>
            }
            else if (_activeSection == "TicketLifecycle")
            {
                <div class="pdq-section-header">Ticket Status (Workflow)</div>
                <MudDataGrid T="TicketStatusItem" Items="@_masterData.TicketStatusList" Dense="true" EditMode="DataGridEditMode.Cell" ReadOnly="false" Bordered="true" Elevation="0" Class="mb-4">
                    <Columns>
                        <PropertyColumn Property="x => x.Name" Title="Status-Name" />
                        <PropertyColumn Property="x => x.Color" Title="Farbe (Hex)" />
                        <PropertyColumn Property="x => x.Icon" Title="Material Icon Name" />
                        <TemplateColumn Title="Vorschau" Editable="false">
                            <CellTemplate><MudIcon Icon="@GetDynamicIcon(context.Item.Icon)" Style="@($"color: {context.Item.Color}")" Size="Size.Small" /></CellTemplate>
                        </TemplateColumn>
                        <TemplateColumn CellClass="d-flex justify-end" Editable="false">
                            <CellTemplate><MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" OnClick="@(() => _masterData.TicketStatusList.Remove(context.Item))" /></CellTemplate>
                        </TemplateColumn>
                    </Columns>
                </MudDataGrid>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" OnClick="@(() => _masterData.TicketStatusList.Add(new TicketStatusItem{Name="NEU", Color="#757575", Icon="Label"}))">Neuen Status hinzufügen</MudButton>

                <div class="pdq-section-header mt-8">Ticket Prioritäten</div>
                <MudDataGrid T="TicketPriorityItem" Items="@_masterData.TicketPriorityList" Dense="true" EditMode="DataGridEditMode.Cell" ReadOnly="false" Bordered="true" Elevation="0" Class="mb-4">
                    <Columns>
                        <PropertyColumn Property="x => x.Name" Title="Prioritäts-Name" />
                        <PropertyColumn Property="x => x.Color" Title="Farbe (Hex)" />
                        <PropertyColumn Property="x => x.Icon" Title="Material Icon Name" />
                        <TemplateColumn Title="Vorschau" Editable="false">
                            <CellTemplate><MudIcon Icon="@GetDynamicIcon(context.Item.Icon)" Style="@($"color: {context.Item.Color}")" Size="Size.Small" /></CellTemplate>
                        </TemplateColumn>
                        <TemplateColumn CellClass="d-flex justify-end" Editable="false">
                            <CellTemplate><MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" OnClick="@(() => _masterData.TicketPriorityList.Remove(context.Item))" /></CellTemplate>
                        </TemplateColumn>
                    </Columns>
                </MudDataGrid>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" OnClick="@(() => _masterData.TicketPriorityList.Add(new TicketPriorityItem{Name="NEU", Color="#333333", Icon="Flag"}))">Neue Priorität hinzufügen</MudButton>
            }
            else if (_activeSection == "Lifecycle")
            {
                <div class="pdq-section-header">Asset-Lebenszyklus Phasen & Status</div>
                @foreach (var group in _lifecycleConfig)
                {
                    <MudPaper Outlined="true" Class="pa-4 mb-4" Style="background: #fafafa;">
                        <div class="d-flex align-center justify-space-between mb-2">
                            <MudText Typo="Typo.subtitle2" Class="font-weight-bold">PHASE: @group.Key</MudText>
                        </div>
                        <div class="d-flex flex-wrap gap-2">
                            @foreach (var status in group.Value)
                            {
                                <MudChip T="string" OnClose="@(() => RemoveStatus(group.Key, status))" Color="Color.Primary" Variant="Variant.Outlined" Size="Size.Small">@status</MudChip>
                            }
                            <MudIconButton Icon="@Icons.Material.Filled.Add" Size="Size.Small" OnClick="@(() => AddStatus(group.Key))" />
                        </div>
                    </MudPaper>
                }
            }
            else if (_activeSection == "Design")
            {
                <div class="pdq-section-header">Oberfläche & Themes</div>
                <MudGrid Spacing="3">
                    <MudItem xs="12" md="6">
                        <MudCard Outlined="true">
                            <MudCardContent>
                                <MudSwitch T="bool" Value="@ThemeService.Config.IsDark" ValueChanged="OnDarkModeChanged" Color="Color.Primary" Label="Dunkelmodus" />
                                <MudColorPicker Label="Primärfarbe" @bind-Text="_tempPrimaryColor" @bind-Text:after="ApplyColor" />
                            </MudCardContent>
                        </MudCard>
                    </MudItem>
                </MudGrid>
            }
            else if (_activeSection == "Info")
            {
                <div class="text-center mb-8">
                    <img src="InfraDesk_Logo.png" alt="InfraDesk" class="info-logo-monochrome" />
                    <MudText Typo="Typo.h4" Style="font-weight: 900; color: #333;">InfraDesk Enterprise</MudText>
                </div>
                <div class="info-grid">
                    <div class="info-label"><MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" Class="mr-2" /> Version</div>
                    <div class="info-value">@_currentVersion</div>
                    <div class="info-label"><MudIcon Icon="@Icons.Material.Filled.Verified" Size="Size.Small" Class="mr-2" /> Release Status</div>
                    <div class="info-value">
                        @if (_isChecking) { <div class="d-flex align-center"><MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Small" Style="width:16px; height:16px;" /><MudText Typo="Typo.caption" Class="ml-2">Prüfung...</MudText></div> }
                        else if (_updateChecked) {
                            @if (_updateFound) { <div class="status-update-text"><MudIcon Icon="@Icons.Material.Filled.SystemUpdate" Size="Size.Small" />Update verfügbar! (v<b>@_latestVersion</b>)</div> }
                            else { <div class="status-ok-text"><MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" />Ihre Version ist aktuell.</div> }
                        }
                        else { <MudButton Variant="Variant.Text" Size="Size.Small" OnClick="CheckForUpdates">Jetzt prüfen</MudButton> }
                    </div>
                    <div class="info-label"><MudIcon Icon="@Icons.Material.Filled.Code" Size="Size.Small" Class="mr-2" /> Entwicklung</div>
                    <div class="info-value">Christian Grams (Grams IT)</div>
                </div>

                <div class="footer-copyright">© 2026 Grams IT. Alle Rechte vorbehalten.</div>
            }
        }
    </div>
</div>

@code {
    private string _activeSection = "MasterData";
    private bool _isLoading = true;
    private bool _isSaving = false;
    private MasterDataDto _masterData = new();
    private List<string> _timeZones = new();
    private Dictionary<string, List<string>> _lifecycleConfig = new();
    
    // Listen
    private List<AssetType> _dynamicAssetTypes = new();
    private List<Location> _locations = new();
    private List<Person> _persons = new();
    private List<Team> _teams = new();
    
    // Master-Detail Edit State
    private Guid? _editCategoryId;
    private AssetType? _editCategory;
    private Guid? _editLocationId;
    private Location? _editLocation;
    private string? _editOrgId;
    private Team? _editTeam;
    private Person? _editPerson;

    private List<string> _availableIcons = new() { 
        "Computer", "Laptop", "Tablet", "Smartphone", "Storage", "Dns", "Router", "Print", "Keyboard", "Mouse", "Headset", 
        "Security", "Memory", "Cloud", "VideoCameraFront", "DeviceHub", "Cable", "Folder",
        "Wifi", "Phone", "Radio", "BatteryChargingFull", "Power", "AcUnit", "Videocam", "Web", "AccountBalance", "Fingerprint", "IntegrationInstructions", "Business", "People", "Person", "LocationCity", "SettingsEthernet"
    };

    private string _tempPrimaryColor = "#004a99";
    
    // --- CACHES FÜR MASSIVE PERFORMANCE STEIGERUNG ---
    private Dictionary<Guid, string> _locationPathCache = new();
    private Dictionary<Guid, string> _categoryPathCache = new();
    private ILookup<Guid?, Location> _locationsByParent = Array.Empty<Location>().ToLookup(x => x.ParentLocationId);
    private ILookup<Guid?, AssetType> _categoriesByParent = Array.Empty<AssetType>().ToLookup(x => x.ParentAssetTypeId);
    private ILookup<Guid?, Person> _personsByTeam = Array.Empty<Person>().ToLookup(x => x.TeamId);
    private static readonly Dictionary<string, string> _iconCache = new();

    private string _currentVersion => System.Reflection.Assembly.GetExecutingAssembly().GetName().Version?.ToString() ?? "1.0.0";
    private bool _isChecking = false;
    private bool _updateChecked = false;
    private bool _updateFound = false;
    private string _latestVersion = "";

    protected override async Task OnInitializedAsync()
    {
        _isLoading = true;
        try
        {
            var taskMaster = SafeGetAsync("api/settings/masterdata", new MasterDataDto());
            var taskLife = SafeGetAsync("api/settings/dynamic/asset-lifecycle", new Dictionary<string, List<string>>());
            var taskTime = SafeGetAsync("api/settings/timezones", new List<string> { "W. Europe Standard Time" });
            var taskTypes = SafeGetAsync("api/assets/types", new List<AssetType>());
            var taskLocs = SafeGetAsync("api/locations", new List<Location>());
            var taskPers = SafeGetAsync("api/persons", new List<Person>());
            var taskTeams = SafeGetAsync("api/teams", new List<Team>());

            await Task.WhenAll(taskMaster, taskLife, taskTime, taskTypes, taskLocs, taskPers, taskTeams);

            _masterData = await taskMaster;
            _lifecycleConfig = await taskLife;
            _timeZones = await taskTime;
            _dynamicAssetTypes = await taskTypes;
            _locations = await taskLocs;
            _persons = await taskPers;
            _teams = await taskTeams;

            _masterData.TicketStatusList ??= new();
            _masterData.TicketPriorityList ??= new();
            _tempPrimaryColor = ThemeService.Config.PrimaryColor;
            
            UpdateCaches();
            _ = CheckForUpdates();
        }
        catch { Snackbar.Add("Ladefehler.", Severity.Error); }
        finally { _isLoading = false; }
    }
    
    private async Task<T> SafeGetAsync<T>(string url, T defaultVal)
    {
        try {
            var res = await Http.GetFromJsonAsync<T>(url);
            return res != null ? res : defaultVal;
        } catch {
            return defaultVal;
        }
    }

    // --- REKURSIVE BAUM RENDERER ---
    private RenderFragment RenderCategoryTreeNodes(IEnumerable<AssetType> nodes) => __builder =>
    {
        foreach (var node in nodes) {
            var children = _categoriesByParent[node.Id].OrderBy(t => t.Name).ToList();
            <MudTreeViewItem T="Guid?" Value="@(new Guid?(node.Id))" Text="@node.Name" Expanded="true" Icon="@GetDynamicIcon(node.IconKey)">
                @if (children.Any()) { @RenderCategoryTreeNodes(children) }
            </MudTreeViewItem>
        }
    };

    private RenderFragment RenderLocationTreeNodes(IEnumerable<Location> nodes) => __builder =>
    {
        foreach (var node in nodes) {
            var children = _locationsByParent[node.Id].OrderBy(l => l.Name).ToList();
            <MudTreeViewItem T="Guid?" Value="@(new Guid?(node.Id))" Text="@node.Name" Expanded="true" Icon="@(children.Any() ? Icons.Material.Filled.Folder : Icons.Material.Filled.LocationOn)">
                @if (children.Any()) { @RenderLocationTreeNodes(children) }
            </MudTreeViewItem>
        }
    };

    // --- SELECTION HANDLER ---
    private void OnCategorySelected(Guid? id) {
        _editCategoryId = id;
        if (id.HasValue) _editCategory = _dynamicAssetTypes.FirstOrDefault(t => t.Id == id.Value);
        else _editCategory = null;
        StateHasChanged();
    }
    
    private void OnLocationSelected(Guid? id) {
        _editLocationId = id;
        if (id.HasValue) _editLocation = _locations.FirstOrDefault(l => l.Id == id.Value);
        else _editLocation = null;
        StateHasChanged();
    }

    private void OnOrgSelected(string? val) {
        _editOrgId = val;
        _editTeam = null; _editPerson = null;
        if (string.IsNullOrEmpty(val)) return;
        if (val.StartsWith("TEAM_")) _editTeam = _teams.FirstOrDefault(t => t.Id.ToString() == val.Substring(5));
        if (val.StartsWith("PERS_")) _editPerson = _persons.FirstOrDefault(p => p.Id.ToString() == val.Substring(5));
        StateHasChanged();
    }

    // --- PFAD HELPER ---
    private string GetLocationPath(Guid? locationId) {
        if (locationId.HasValue && _locationPathCache.TryGetValue(locationId.Value, out var path)) return path;
        return "---";
    }

    private string GetCategoryPath(Guid? typeId) {
        if (typeId.HasValue && _categoryPathCache.TryGetValue(typeId.Value, out var path)) return path;
        return "---";
    }
    
    private void UpdateCaches()
    {
        _locationsByParent = _locations.ToLookup(l => l.ParentLocationId);
        _categoriesByParent = _dynamicAssetTypes.ToLookup(t => t.ParentAssetTypeId);
        _personsByTeam = _persons.ToLookup(p => p.TeamId);

        _locationPathCache.Clear();
        var locDict = _locations.ToDictionary(l => l.Id);
        foreach (var loc in _locations)
        {
            var path = loc.Name;
            var parentId = loc.ParentLocationId;
            int depth = 0;
            while (parentId.HasValue && depth < 10)
            {
                if (locDict.TryGetValue(parentId.Value, out var parent)) {
                    path = parent.Name + " > " + path;
                    parentId = parent.ParentLocationId;
                    depth++;
                } else break;
            }
            _locationPathCache[loc.Id] = path;
        }

        _categoryPathCache.Clear();
        var catDict = _dynamicAssetTypes.ToDictionary(t => t.Id);
        foreach (var cat in _dynamicAssetTypes)
        {
            var path = cat.Name;
            var parentId = cat.ParentAssetTypeId;
            int depth = 0;
            while (parentId.HasValue && depth < 10)
            {
                if (catDict.TryGetValue(parentId.Value, out var parent)) {
                    path = parent.Name + " > " + path;
                    parentId = parent.ParentAssetTypeId;
                    depth++;
                } else break;
            }
            _categoryPathCache[cat.Id] = path;
        }
    }

    // --- ETIKETTEN VORSCHAU ---
    private string GetTagPreview() => (_masterData.AssetTagPattern ?? "{COMP}-{LOC}-{CAT}-{NUM:5}")
        .Replace("{COMP}", _masterData.CompanyPrefix ?? "GIT").Replace("{LOC}", "FRA").Replace("{CAT}", "SRV").Replace("{NUM:5}", "00001");

    private void ApplyTemplateDimensions() {
        switch (_masterData.LabelTemplate) {
            case "Brother DK-11201 (29x90mm)": _masterData.LabelWidth = 90; _masterData.LabelHeight = 29; break;
            case "Brother DK-11209 (29x62mm)": _masterData.LabelWidth = 62; _masterData.LabelHeight = 29; break;
            case "Zebra Desktop 4x2 (102x51mm)": _masterData.LabelWidth = 102; _masterData.LabelHeight = 51; break;
            case "Avery Zweckform 70x37mm": _masterData.LabelWidth = 70; _masterData.LabelHeight = 37; break;
        }
        StateHasChanged();
    }

    private async Task PrintTestLabel() {
        string tag = GetTagPreview();
        string company = _masterData.PrintCompanyName ? _masterData.CompanyName : "";
        string assetName = "TEST-SERVER-01";
        
        string html = "<html><head><style>body { font-family: sans-serif; display: flex; align-items: center; justify-content: center; } " +
            ".label { width: " + _masterData.LabelWidth + "mm; height: " + _masterData.LabelHeight + "mm; border: 0.1mm solid #ccc; padding: 2mm; text-align: center; display: flex; flex-direction: column; justify-content: space-between; } " +
            "</style></head><body onload='window.print();window.close();'>" +
            "<div class='label'><div>" + company + "</div><div style='font-size: 1.2em; font-weight: bold;'>" + tag + "</div><div>" + assetName + "</div></div></body></html>";
            
        await JSRuntime.InvokeVoidAsync("eval", "var w = window.open(); w.document.write(atob('" + Convert.ToBase64String(System.Text.Encoding.UTF8.GetBytes(html)) + "')); w.document.close();");
    }

    // --- CRUD ---
    private void AddAssetType() {
        _editCategory = new AssetType { Name = "Neue Kategorie", IconKey = "Folder" };
        _editCategoryId = Guid.Empty;
    }
    private async Task SaveCategory() {
        if (_editCategory == null) return;
        try {
            if (_editCategory.Id == Guid.Empty) {
                var res = await Http.PostAsJsonAsync("api/assets/types", _editCategory);
                if (res.IsSuccessStatusCode) {
                    var created = await res.Content.ReadFromJsonAsync<AssetType>();
                    if (created != null) { 
                        _dynamicAssetTypes.Add(created); 
                        _editCategoryId = created.Id; 
                        _editCategory = created; 
                        UpdateCaches(); 
                    }
                    Snackbar.Add("Kategorie erstellt.", Severity.Success);
                }
            } else {
                await Http.PutAsJsonAsync($"api/assets/types/{_editCategory.Id}", _editCategory);
                UpdateCaches();
                Snackbar.Add("Kategorie aktualisiert.", Severity.Success);
            }
        } catch { Snackbar.Add("Fehler.", Severity.Error); }
    }
    private async Task DeleteCategory() {
        if (_editCategory == null) return;
        if (_editCategory.Id == Guid.Empty) { _editCategory = null; _editCategoryId = null; return; }
        try {
            var res = await Http.DeleteAsync($"api/assets/types/{_editCategory.Id}");
            if (res.IsSuccessStatusCode) { 
                _dynamicAssetTypes.Remove(_editCategory); 
                _editCategory = null; 
                _editCategoryId = null; 
                UpdateCaches(); 
                Snackbar.Add("Gelöscht.", Severity.Success); 
            }
            else { Snackbar.Add("Kategorie wird noch verwendet.", Severity.Warning); }
        } catch { }
    }

    private void AddLocation() {
        _editLocation = new Location { Name = "Neuer Standort" };
        _editLocationId = Guid.Empty;
    }
    private async Task SaveLocation() {
        if (_editLocation == null) return;
        try {
            if (_editLocation.Id == Guid.Empty) {
                var res = await Http.PostAsJsonAsync("api/locations", _editLocation);
                if (res.IsSuccessStatusCode) {
                    var created = await res.Content.ReadFromJsonAsync<Location>();
                    if (created != null) { 
                        _locations.Add(created); 
                        _editLocationId = created.Id; 
                        _editLocation = created; 
                        UpdateCaches(); 
                    }
                    Snackbar.Add("Standort erstellt.", Severity.Success);
                }
            } else {
                await Http.PutAsJsonAsync($"api/locations/{_editLocation.Id}", _editLocation);
                UpdateCaches();
                Snackbar.Add("Standort aktualisiert.", Severity.Success);
            }
        } catch { Snackbar.Add("Fehler.", Severity.Error); }
    }
    private async Task DeleteLocation() {
        if (_editLocation == null) return;
        if (_editLocation.Id == Guid.Empty) { _editLocation = null; _editLocationId = null; return; }
        try {
            var res = await Http.DeleteAsync($"api/locations/{_editLocation.Id}");
            if (res.IsSuccessStatusCode) { 
                _locations.Remove(_editLocation); 
                _editLocation = null; 
                _editLocationId = null; 
                UpdateCaches(); 
                Snackbar.Add("Gelöscht.", Severity.Success); 
            }
            else { Snackbar.Add("Standort wird noch verwendet.", Severity.Warning); }
        } catch { }
    }

    private void AddTeam() {
        _editTeam = new Team { Name = "Neues Team" };
        _editOrgId = "TEAM_NEW";
    }
    private async Task SaveTeam() {
        if (_editTeam == null) return;
        try {
            if (_editTeam.Id == Guid.Empty) {
                var res = await Http.PostAsJsonAsync("api/teams", _editTeam);
