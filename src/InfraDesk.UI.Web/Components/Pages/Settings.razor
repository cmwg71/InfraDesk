                UpdateCaches(); 
                Snackbar.Add("Gelöscht.", Severity.Success); 
            }
            else { Snackbar.Add("In Benutzung.", Severity.Warning); }
        } catch { }
    }

    private async Task SaveSettings() {
        _isSaving = true;
        try {
            if (_activeSection == "Lifecycle") await Http.PostAsJsonAsync("api/settings/dynamic/asset-lifecycle", _lifecycleConfig);
            else await Http.PostAsJsonAsync("api/settings/masterdata", _masterData);
            Snackbar.Add("Erfolgreich gespeichert.", Severity.Success);
        } catch { } finally { _isSaving = false; }
    }

    private async Task CheckForUpdates()
    {
        if (_isChecking) return;
        _isChecking = true; _updateChecked = false;
        await InvokeAsync(StateHasChanged);
        try {
            var release = await UpdateService.GetLatestReleaseAsync();
            if (release != null) {
                _latestVersion = release.TagName;
                _updateFound = _latestVersion.TrimStart('v','V') != _currentVersion;
                _updateChecked = true;
            }
        } catch { _updateChecked = false; }
        finally { _isChecking = false; await InvokeAsync(StateHasChanged); }
    }

    private void OnDarkModeChanged(bool isDark) { var cfg = ThemeService.Config; cfg.IsDark = isDark; ThemeService.UpdateConfig(cfg); }
    private void ApplyColor() { var cfg = ThemeService.Config; cfg.PrimaryColor = _tempPrimaryColor; ThemeService.UpdateConfig(cfg); }
    private void RemoveStatus(string g, string s) { if (_lifecycleConfig.ContainsKey(g)) { _lifecycleConfig[g].Remove(s); StateHasChanged(); } }
    private void AddStatus(string g) { if(!_lifecycleConfig.ContainsKey(g)) _lifecycleConfig[g] = new(); _lifecycleConfig[g].Add("NEU"); StateHasChanged(); }

    private void OnFieldChanged() => StateHasChanged();

    private string GetDynamicIcon(string? iconName) {
        if (string.IsNullOrWhiteSpace(iconName)) return Icons.Material.Filled.Folder;
        if (_iconCache.TryGetValue(iconName, out var cachedIcon)) return cachedIcon;
        
        try {
            var field = typeof(Icons.Material.Filled).GetField(iconName);
            var icon = field?.GetValue(null)?.ToString() ?? Icons.Material.Filled.Folder;
            _iconCache[iconName] = icon;
            return icon;
        } catch { return Icons.Material.Filled.Folder; }
    }

