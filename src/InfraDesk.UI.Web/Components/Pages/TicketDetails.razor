@* Dateipfad: src/InfraDesk.UI.Web/Components/Pages/TicketDetails.razor *@
@page "/tickets/{Id:guid}"
@using InfraDesk.Core.Entities
@using MudBlazor
@using InfraDesk.UI.Web.Services
@using System.Text.Json
@using System.Text.Json.Serialization
@using System.Security.Claims
@inject HttpClient Http
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject ThemeService ThemeService
@inject InfraDeskAuthStateProvider AuthStateProvider
@inject IDialogService DialogService
@inject IJSRuntime JSRuntime
@implements IAsyncDisposable

<PageTitle>InfraDesk - Ticket #@(_ticket?.TicketNumber)</PageTitle>

<NavigationLock ConfirmExternalNavigation="_hasUnsavedChanges" OnBeforeInternalNavigation="OnBeforeInternalNavigation" />

<style>
    .pdq-container { background-color: #f4f4f4; height: calc(100vh - 120px); display: flex; flex-direction: row; overflow: hidden; }
    .pdq-main { flex-grow: 1; overflow-y: auto; background-color: #fff; padding: 12px; }
    .pdq-sidebar { width: 400px; border-left: 1px solid #ccc; background-color: #f0f0f0; overflow-y: auto; flex-shrink: 0; padding-bottom: 80px; }
    .pdq-toolbar { height: 42px; background-color: #eee; border-bottom: 1px solid #ccc; display: flex; align-items: center; padding: 0 8px; }
    
    .section-box { border: 1px solid #ccc; border-radius: 4px; margin-bottom: 12px; overflow: hidden; background: #fff; }
    .section-header-compact { background-color: #e0e0e0; padding: 4px 12px; font-weight: 800; font-size: 0.72rem; text-transform: uppercase; color: #333; display: flex; align-items: center; justify-content: space-between; min-height: 32px; }
    
    .header-meta { display: flex; align-items: center; gap: 14px; font-weight: normal; text-transform: none; font-size: 0.75rem; color: #444; }
    .meta-item { display: flex; align-items: center; gap: 5px; }

    .activity-card { border: 1px solid #ccc; border-radius: 4px; margin-bottom: 12px; background: #fff; transition: background-color 0.2s; }
    .activity-agent { margin-left: 48px; border-left: 4px solid var(--mud-palette-primary) !important; background-color: #fcfdff; }
    .activity-header { background-color: #f5f5f5; padding: 4px 12px; border-bottom: 1px solid #ddd; display: flex; justify-content: space-between; align-items: center; }
    .internal-card { border-color: var(--mud-palette-warning) !important; background-color: #fffaf0 !important; }
    
    .sidebar-panel-header { font-size: 0.75rem !important; font-weight: 800 !important; color: #444 !important; }
    .text-danger { color: var(--mud-palette-error); font-weight: bold; }
    .dirty-indicator { font-size: 0.75rem; color: var(--mud-palette-warning); font-weight: bold; margin-right: 12px; display: flex; align-items: center; }
    .mail-notice-box { border: 1px solid #ccc; padding: 10px; border-radius: 2px; background: #fff; margin-bottom: 12px; display: flex; align-items: center; font-size: 0.8rem; font-weight: bold; }
</style>

@if (_ticket == null) {
    <div class="d-flex justify-center align-center" style="height: 80vh;"><MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Large" /></div>
} else {
    <div class="pdq-toolbar">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" OnClick="NavigateBack" Size="Size.Small" Class="mr-2" />
        <MudIcon Icon="@Icons.Material.Filled.ConfirmationNumber" Color="Color.Primary" Size="Size.Small" Class="mr-2" />
        <MudText Typo="Typo.body2" Class="font-weight-bold">Ticket: @(_ticket.Title) (#@_ticket.TicketNumber)</MudText>
        
        <MudSpacer />
        
        @if (_hasUnsavedChanges)
        {
            <div class="dirty-indicator">
                <MudIcon Icon="@Icons.Material.Filled.Warning" Size="Size.Small" Class="mr-1" />
                Ungespeicherte Änderungen
            </div>
            <MudButton Variant="Variant.Outlined" Color="Color.Error" Size="Size.Small" OnClick="DiscardChanges" Class="mr-2" Style="background: white;">Verwerfen</MudButton>
        }

        <MudButton Variant="@(_hasUnsavedChanges ? Variant.Filled : Variant.Outlined)" 
                   Color="@(_hasUnsavedChanges ? Color.Primary : Color.Default)" 
                   Size="Size.Small" 
                   StartIcon="@Icons.Material.Filled.Save" 
                   OnClick="@(() => SaveTicketWithLogging(false))" 
                   Loading="_isSaving"
                   Disabled="@(!_hasUnsavedChanges && !_isSaving)">
            Speichern
        </MudButton>

        <MudDivider Vertical="true" FlexItem="true" Class="mx-4 my-2" />

        <MudButtonGroup Variant="Variant.Outlined" Size="Size.Small" Class="mr-2" Style="background: white;">
            <MudIconButton Icon="@Icons.Material.Filled.Print" Title="Drucken" />
            <MudIconButton Icon="@Icons.Material.Filled.Email" Title="E-Mail an Kontakt" />
        </MudButtonGroup>
    </div>

    @if (_hasUnsavedChanges)
    {
        <MudAlert Severity="Severity.Warning" Variant="Variant.Filled" Square="true" Dense="true" Class="py-1" ContentAlignment="HorizontalAlignment.Center">
            Achtung: Änderungen sind noch nicht permanent gesichert. 
            <MudLink OnClick="@(() => SaveTicketWithLogging(false))" Color="Color.Inherit" Underline="Underline.Always" Class="ml-2 cursor-pointer"><b>Jetzt Speichern</b></MudLink>
        </MudAlert>
    }

    <div class="pdq-container">
        <div class="pdq-main">
            
            <div class="section-box">
                <div class="section-header-compact">
                    Status
                    <span style="color: @GetStatusHex(_ticket.Status); font-weight: 900;">@_ticket.Status.ToUpper()</span>
                </div>
                <div class="pa-4">
                    <MudGrid Spacing="2">
                        <MudItem xs="12" md="4">
                            <MudSelect T="string" Label="Status" @bind-Value="_ticket.Status" @bind-Value:after="OnFieldChanged" Margin="Margin.Dense" Variant="Variant.Outlined" Dense="true">
                                <MudSelectItem Value="@("OFFEN")">OFFEN</MudSelectItem>
                                <MudSelectItem Value="@("BEANTWORTET")">BEANTWORTET</MudSelectItem>
                                <MudSelectItem Value="@("AKTIV")">AKTIV</MudSelectItem>
                                <MudSelectItem Value="@("GESCHLOSSEN")">GESCHLOSSEN</MudSelectItem>
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" md="4">
                            <MudSelect T="string" Label="Priorität" @bind-Value="_ticket.Priority" @bind-Value:after="OnFieldChanged" Margin="Margin.Dense" Variant="Variant.Outlined" Dense="true">
                                <MudSelectItem Value="@("Niedrig")">Niedrig</MudSelectItem>
                                <MudSelectItem Value="@("Normal")">Normal</MudSelectItem>
                                <MudSelectItem Value="@("Hoch")">Hoch</MudSelectItem>
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" md="4">
                             <MudCheckBox T="bool" @bind-Value="_ticket.IsInternal" @bind-Value:after="OnFieldChanged" Label="Internes Ticket" Color="Color.Primary" Dense="true" />
                             <MudText Typo="Typo.caption" Style="display:block; color: #666; line-height: 1.2;">Nur für interne Dokumentationszwecke.</MudText>
                        </MudItem>
                    </MudGrid>
                </div>
            </div>

            <div class="section-box">
                <div class="section-header-compact">
                    Kontakt
                    <div class="header-meta">
                        <span class="meta-item">@(_tenants.FirstOrDefault(t => t.Id == _ticket.TenantId)?.Name ?? "Lade Mandant...")</span>
                        <span class="meta-item"><MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" /> @(_ticket.Requester?.LastName), @(_ticket.Requester?.FirstName)</span>
                    </div>
                </div>
                <div class="pa-4">
                    <MudGrid Spacing="2" AlignItems="AlignItems.Center">
                        <MudItem xs="12" md="6">
                            <MudSelect T="Guid?" Label="Kontakt" @bind-Value="_ticket.RequesterId" @bind-Value:after="OnRequesterChanged" Variant="Variant.Outlined" Margin="Margin.Dense" Dense="true">
                                @foreach(var p in _availableSupporters) { <MudSelectItem T="Guid?" Value="@p.Id">@p.LastName, @p.FirstName</MudSelectItem> }
                            </MudSelect>
                            <div style="font-size: 0.7rem; color: var(--mud-palette-primary); margin-top: 4px;">
                                Tel.: @(_ticket.Requester?.Department ?? "N/A") | Email: @(_ticket.Requester?.Email)
                            </div>
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudSelect T="Guid" Label="Mandant" @bind-Value="_ticket.TenantId" @bind-Value:after="OnFieldChanged" Variant="Variant.Outlined" Margin="Margin.Dense" Dense="true">
                                @foreach(var t in _tenants) { <MudSelectItem Value="@t.Id">@t.Name</MudSelectItem> }
                            </MudSelect>
                        </MudItem>
                    </MudGrid>
                </div>
            </div>

            <div class="section-box">
                <div class="section-header-compact">
                    Beschreibung
                    <div class="header-meta">
                        <span class="meta-item"><MudIcon Icon="@Icons.Material.Filled.CalendarMonth" Size="Size.Small" /> @ThemeService.FormatDate(_ticket.CreatedAt)</span>
                        <span class="meta-item"><MudAvatar Size="Size.Small" Color="Color.Primary" Style="width:18px; height:18px; font-size: 0.6rem;">@(_ticket.Requester?.LastName?.Substring(0,1) ?? "U")</MudAvatar> @(_ticket.Requester?.LastName)</span>
                    </div>
                </div>
                <div class="pa-4">
                    @if (_ticket.CreatedViaEmail) {
                        <div class="mail-notice-box"><MudIcon Icon="@Icons.Material.Filled.Email" Size="Size.Small" Class="mr-3" /><span>Per Mail angelegt.</span></div>
                    }
                    <div style="font-size: 0.85rem; line-height: 1.5; color: #333; overflow-wrap: break-word;">
                        @((MarkupString)(_ticket.Description ?? "Keine Beschreibung hinterlegt."))
                    </div>
                </div>
            </div>

            <MudPaper Class="pa-4 mb-8" Elevation="0" Outlined="true" Style="background: #fdfdfd; border-style: dashed; border-color: #ccc;">
                <MudText Typo="Typo.caption" Class="font-weight-bold mb-2 d-block" Color="Color.Primary">
                    NEUE ANTWORT VERFASSEN <span style="font-weight:normal; color:#888;">(Bilder per Strg+V direkt einfügen)</span>
                </MudText>
                
                <!-- WRAPPER FÜR COPY&PASTE JS-INTEROP -->
                <div id="ticket-comment-wrapper">
                    <MudTextField T="string" @bind-Value="_newComment" Placeholder="Ihre Antwort oder interne Notiz..." Lines="4" Variant="Variant.Outlined" Margin="Margin.Dense" BackgroundColor="#fff" />
                </div>
                
                <div class="d-flex justify-end mt-2 align-center">
                    
                    <!-- NEU: FILE UPLOAD -->
                    <MudFileUpload T="IReadOnlyList<IBrowserFile>" FilesChanged="UploadFiles" MaximumFileCount="10" Class="mr-auto mt-0">
                        <ActivatorContent>
                            <MudButton StartIcon="@Icons.Material.Filled.AttachFile" Variant="Variant.Outlined" Size="Size.Small" Color="Color.Default">Anhang hinzufügen</MudButton>
                        </ActivatorContent>
                    </MudFileUpload>

                    <MudNumericField T="int" @bind-Value="_newCommentMinutes" Label="Aufwand (Minuten)" Margin="Margin.Dense" Variant="Variant.Outlined" Style="width: 120px;" Class="mr-4" />
                    <MudCheckBox T="bool" @bind-Value="_commentIsPublic" Label="Öffentlich (E-Mail an CC)" Dense="true" Size="Size.Small" Class="mr-4" />
                    
                    @if (_ticket.ChildTickets != null && _ticket.ChildTickets.Any() && _commentIsPublic) {
                        <MudText Typo="Typo.caption" Color="Color.Info" Class="mr-4"><i>(Wird auf @_ticket.ChildTickets.Count Sub-Tickets kopiert)</i></MudText>
                    }

                    <MudButton StartIcon="@Icons.Material.Filled.Send" Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" OnClick="AddCommentAndNotify">Nachricht senden</MudButton>
                </div>
            </MudPaper>

            <div class="d-flex align-center mb-3">
                <MudIcon Icon="@Icons.Material.Filled.History" Size="Size.Small" Class="mr-2" Color="Color.Secondary" />
                <MudText Typo="Typo.body2" Class="font-weight-bold">Bearbeitungsverlauf (Journal)</MudText>
                <MudSpacer />
                <MudToggleIconButton @bind-Toggled="_showPrivateNotes" Icon="@Icons.Material.Filled.Visibility" ToggledIcon="@Icons.Material.Filled.VisibilityOff" Size="Size.Small" />
            </div>

            @if (_ticket.Activities != null)
            {
                @foreach (var act in _ticket.Activities.OrderByDescending(a => a.Timestamp)) {
                    bool isInternal = !act.IsPublic;
                    if (isInternal && (!_isAgent || !_showPrivateNotes)) continue;

                    <div class="activity-card @(act.IsStaffAction ? "activity-agent" : "") @(isInternal ? "internal-card" : "")">
                        <div class="activity-header">
                            <div class="header-meta">
                                <span class="meta-item"><MudIcon Icon="@Icons.Material.Filled.Event" Size="Size.Small" /> @ThemeService.FormatDate(act.Timestamp)</span>
                                <span class="meta-item">
                                    <MudAvatar Size="Size.Small" Color="@(act.IsStaffAction ? Color.Primary : Color.Info)" Style="width:18px; height:18px; font-size: 0.6rem;">@(string.IsNullOrEmpty(act.AuthorName) ? "?" : act.AuthorName.Substring(0,1))</MudAvatar> 
                                    <strong>@act.AuthorName</strong>
                                </span>
                                <span class="meta-item"><MudIcon Icon="@Icons.Material.Filled.Timer" Size="Size.Small" /> @act.ActivitySpentMinutes Min</span>
                                
                                @if (!isInternal) {
                                    <MudTooltip>
                                        <ChildContent><MudIcon Icon="@Icons.Material.Filled.Group" Size="Size.Small" Color="Color.Success" /></ChildContent>
                                        <TooltipContent><MudText Typo="Typo.caption">Empfänger: @(_ticket.Requester?.Email) @(string.Join(", ", _ticket.Watchers?.Select(w => w.Email) ?? Enumerable.Empty<string>()))</MudText></TooltipContent>
                                    </MudTooltip>
                                }
                            </div>
                            @if(isInternal) { <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Text" Class="font-weight-bold pa-0 ma-0">INTERN</MudChip> }
                        </div>
                        <div class="pa-4" style="font-size: 0.82rem; color: #444; overflow-wrap: break-word;">@((MarkupString)act.Content)</div>
                    </div>
                }
            }
        </div>

        <!-- SIDEBAR (RECHTS) -->
        <div class="pdq-sidebar">
            <MudExpansionPanels MultiExpansion="true" Elevation="0" Square="true">
                
                <MudExpansionPanel IsExpanded="true">
                    <TitleContent>
                        <div class="d-flex align-center justify-space-between w-100 pr-4">
                            <div class="d-flex align-center"><MudIcon Icon="@Icons.Material.Filled.Class" Size="Size.Small" Class="mr-2"/><span class="sidebar-panel-header">Kategorisierung</span></div>
                            <MudChip T="string" Size="Size.Small" Icon="@GetItilIcon(_ticket.Category1)" Color="@GetItilColor(_ticket.Category1)" Variant="Variant.Outlined" Class="font-weight-bold ma-0">
                                @(_ticket.Category1 ?? "Nicht klassifiziert")
                            </MudChip>
                        </div>
                    </TitleContent>
                    <ChildContent>
                        <MudStack Spacing="2">
                            <MudSelect T="string" Label="Ticket-Typ (ITIL)" @bind-Value="_ticket.Category1" @bind-Value:after="OnFieldChanged" Margin="Margin.Dense" Variant="Variant.Outlined" Dense="true">
                                <MudSelectItem Value="@("Incident (Störung)")"><div class="d-flex align-center"><MudIcon Icon="@Icons.Material.Filled.Bolt" Size="Size.Small" Color="Color.Error" Class="mr-2"/>Incident</div></MudSelectItem>
                                <MudSelectItem Value="@("Service Request (Serviceanfrage)")"><div class="d-flex align-center"><MudIcon Icon="@Icons.Material.Filled.ShoppingCart" Size="Size.Small" Color="Color.Info" Class="mr-2"/>Request</div></MudSelectItem>
                                <MudSelectItem Value="@("Problem (Problem)")"><div class="d-flex align-center"><MudIcon Icon="@Icons.Material.Filled.Search" Size="Size.Small" Color="Color.Dark" Class="mr-2"/>Problem</div></MudSelectItem>
                                <MudSelectItem Value="@("Change (Änderung)")"><div class="d-flex align-center"><MudIcon Icon="@Icons.Material.Filled.Settings" Size="Size.Small" Color="Color.Warning" Class="mr-2"/>Change</div></MudSelectItem>
                            </MudSelect>
                            <MudSelect T="string" Label="Asset-Kategorie" @bind-Value="_ticket.Category2" @bind-Value:after="OnFieldChanged" Margin="Margin.Dense" Variant="Variant.Outlined" Dense="true">
                                @foreach(var type in _dynamicAssetTypes) { <MudSelectItem Value="@type.Name">@type.Name</MudSelectItem> }
                            </MudSelect>
                            <MudTextField T="string" Label="Subkategorie" @bind-Value="_ticket.Category3" OnBlur="OnFieldChanged" Margin="Margin.Dense" Variant="Variant.Outlined" />
                        </MudStack>
                    </ChildContent>
                </MudExpansionPanel>

                <MudExpansionPanel IsExpanded="true">
                    <TitleContent><div class="d-flex align-center"><MudIcon Icon="@Icons.Material.Filled.Tag" Size="Size.Small" Class="mr-2"/><span class="sidebar-panel-header">Schlagworte</span></div></TitleContent>
                    <ChildContent>
                        <MudTextField T="string" @bind-Value="_ticket.Tags" @bind-Value:after="OnFieldChanged" Label="Such-Tags" Placeholder="Hardware, Dringend, VIP" HelperText="Komma-getrennt eingeben" Variant="Variant.Outlined" Margin="Margin.Dense" Lines="2" />
                    </ChildContent>
                </MudExpansionPanel>

                <MudExpansionPanel IsExpanded="true">
                    <TitleContent><div class="d-flex align-center justify-space-between w-100 pr-4"><div class="d-flex align-center"><MudIcon Icon="@Icons.Material.Filled.Star" Size="Size.Small" Class="mr-2"/><span class="sidebar-panel-header">Eskalation</span></div><MudRating SelectedValue="@_ticket.EscalationLevel" ReadOnly="true" Size="Size.Small" /></div></TitleContent>
                    <ChildContent>
                        <MudText Typo="Typo.caption">Eskalationsstufe</MudText>
                        <MudRating @bind-SelectedValue="_ticket.EscalationLevel" @bind-SelectedValue:after="OnFieldChanged" Size="Size.Small" />
                    </ChildContent>
                </MudExpansionPanel>

                <MudExpansionPanel IsExpanded="true">
                    <TitleContent><div class="d-flex align-center justify-space-between w-100 pr-4"><div class="d-flex align-center"><MudIcon Icon="@Icons.Material.Filled.AccountTree" Size="Size.Small" Class="mr-2"/><span class="sidebar-panel-header">Master- / Sub-Tickets</span></div></div></TitleContent>
                    <ChildContent>
                        <MudAutocomplete T="Ticket" Label="Ist Sub-Ticket von..." @bind-Value="SelectedMasterTicket" 
                                         SearchFunc="SearchTickets" ToStringFunc="@(t => t == null ? null : $"#{t.TicketNumber} {t.Title}")" 
                                         Variant="Variant.Outlined" Margin="Margin.Dense" Dense="true" Clearable="true" 
                                         HelperText="Macht dieses Ticket zu einer Unteraufgabe." />

                        @if (_ticket.ChildTickets != null && _ticket.ChildTickets.Any()) {
                            <MudText Typo="Typo.caption" Class="mt-4 mb-2 d-block font-weight-bold">Verknüpfte Sub-Tickets:</MudText>
                            @foreach(var child in _ticket.ChildTickets) {
                                <div class="d-flex align-center pa-2 mb-1" style="background: #fff; border: 1px solid #ddd; border-radius: 4px;">
                                    <MudIcon Icon="@Icons.Material.Filled.SubdirectoryArrowRight" Size="Size.Small" Color="Color.Secondary" Class="mr-2" />
                                    <MudLink Href="@($"/tickets/{child.Id}")" Style="font-size: 0.72rem; font-weight: bold; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">#@child.TicketNumber @child.Title</MudLink>
                                </div>
                            }
                        }
                    </ChildContent>
                </MudExpansionPanel>

                <MudExpansionPanel IsExpanded="true">
                    <TitleContent><div class="d-flex align-center justify-space-between w-100 pr-4"><div class="d-flex align-center"><MudIcon Icon="@Icons.Material.Filled.Support" Size="Size.Small" Class="mr-2"/><span class="sidebar-panel-header">Zuständigkeit</span></div></div></TitleContent>
                    <ChildContent>
                        <MudSelect T="Guid?" Label="Bearbeiter" @bind-Value="_ticket.SupporterId" @bind-Value:after="OnFieldChanged" Margin="Margin.Dense" Variant="Variant.Outlined" Dense="true">
                            @foreach(var p in _availableSupporters) { <MudSelectItem T="Guid?" Value="@p.Id">@p.LastName, @p.FirstName</MudSelectItem> }
                        </MudSelect>
                    </ChildContent>
                </MudExpansionPanel>

                <MudExpansionPanel IsExpanded="true">
                    <TitleContent><div class="d-flex align-center justify-space-between w-100 pr-4"><div class="d-flex align-center"><MudIcon Icon="@Icons.Material.Filled.Timer" Size="Size.Small" Class="mr-2"/><span class="sidebar-panel-header">Aufwand & Zeit</span></div></div></TitleContent>
                    <ChildContent>
                        <MudGrid Spacing="1">
                            <MudItem xs="6"><MudNumericField T="int" Label="Verbucht" @bind-Value="_ticket.SpentMinutes" OnBlur="OnFieldChanged" Margin="Margin.Dense" /></MudItem>
                            <MudItem xs="6"><MudNumericField T="int" Label="Erwartet" @bind-Value="_ticket.EstimatedMinutes" OnBlur="OnFieldChanged" Margin="Margin.Dense" /></MudItem>
                            <MudItem xs="12">
                                <MudText Typo="Typo.caption" Class="@(_ticket.EstimatedMinutes - _ticket.SpentMinutes < 0 ? "text-danger" : "")">Saldo: @(_ticket.EstimatedMinutes - _ticket.SpentMinutes) Min.</MudText>
                            </MudItem>
                        </MudGrid>
                        <MudDatePicker Label="Fällig am" @bind-Date="_dueAt" @bind-Date:after="OnFieldChanged" Margin="Margin.Dense" Variant="Variant.Outlined" Class="mt-2" />
                    </ChildContent>
                </MudExpansionPanel>

                <MudExpansionPanel IsExpanded="true">
                    <TitleContent><div class="d-flex align-center justify-space-between w-100 pr-4"><div class="d-flex align-center"><MudIcon Icon="@Icons.Material.Filled.Event" Size="Size.Small" Class="mr-2"/><span class="sidebar-panel-header">Termine</span></div><div style="font-size: 0.6rem; text-align: right;"><div><MudIcon Icon="@Icons.Material.Filled.Input" Size="Size.Small" /> @ThemeService.FormatDate(_ticket.CreatedAt, "dd.MM.yyyy")</div><div><MudIcon Icon="@Icons.Material.Filled.Flag" Size="Size.Small" Color="Color.Error" /> @ThemeService.FormatDate(_ticket.DueAt, "dd.MM.yyyy")</div></div></div></TitleContent>
                    <ChildContent>
                        <MudStack Spacing="2">
                            <MudDatePicker Label="Zurückgestellt bis" @bind-Date="_ticket.DeferredUntil" @bind-Date:after="OnFieldChanged" Margin="Margin.Dense" Variant="Variant.Outlined" Clearable="true" />
                            <MudDivider />
                            <MudDatePicker Label="Wiedervorlage" @bind-Date="_ticket.ReminderDate" @bind-Date:after="OnFieldChanged" Margin="Margin.Dense" Variant="Variant.Outlined" Color="Color.Secondary" />
                            <MudTextField T="string" Label="Hinweis" @bind-Value="_ticket.ReminderNote" OnBlur="OnFieldChanged" Margin="Margin.Dense" Variant="Variant.Outlined" />
                        </MudStack>
                    </ChildContent>
                </MudExpansionPanel>

                <MudExpansionPanel><TitleContent><div class="d-flex align-center"><MudIcon Icon="@Icons.Material.Filled.Schema" Size="Size.Small" Class="mr-2"/><span class="sidebar-panel-header">Workflow</span></div></TitleContent></MudExpansionPanel>

                <MudExpansionPanel IsExpanded="true">
                    <TitleContent><div class="d-flex align-center"><MudIcon Icon="@Icons.Material.Filled.Groups" Size="Size.Small" Class="mr-2"/><span class="sidebar-panel-header">Interessierter Kreis</span></div></TitleContent>
                    <ChildContent>
                        <MudSelect T="Person" Label="Person hinzufügen" ValueChanged="AddWatcher" Margin="Margin.Dense" Variant="Variant.Outlined" Dense="true">
                            @foreach(var p in _availableSupporters) { <MudSelectItem Value="@p">@p.LastName</MudSelectItem> }
                        </MudSelect>
                        <MudList T="string" Dense="true">
                            @if (_ticket.Watchers != null)
                            {
                                @foreach(var w in _ticket.Watchers) {
                                    <MudListItem T="string" Icon="@Icons.Material.Filled.Person">
                                        <div class="d-flex align-center w-100"><MudText Typo="Typo.caption">@w.LastName</MudText><MudSpacer /><MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" OnClick="@(() => RemoveWatcher(w))" /></div>
                                    </MudListItem>
                                }
                            }
                        </MudList>
                    </ChildContent>
                </MudExpansionPanel>

                <MudExpansionPanel IsExpanded="true">
                    <TitleContent><div class="d-flex align-center justify-space-between w-100 pr-4"><div class="d-flex align-center"><MudIcon Icon="@Icons.Material.Filled.Dns" Size="Size.Small" Class="mr-2"/><span class="sidebar-panel-header">Verknüpfte Assets</span></div><span style="font-size: 0.65rem">@(_ticket.AssignedAssets?.Count ?? 0) Assets</span></div></TitleContent>
                    <ChildContent>
                        @if (_ticket.AssignedAssets != null && _ticket.AssignedAssets.Any()) {
                            <div class="mb-2">
                            @foreach (var asset in _ticket.AssignedAssets) {
                                <div class="d-flex align-center pa-2 mb-1" style="background: #fff; border: 1px solid #ddd; border-radius: 4px;">
                                    <MudIcon Icon="@Icons.Material.Filled.Computer" Size="Size.Small" Color="Color.Primary" Class="mr-2" />
                                    <MudLink Href="@($"/assets/{asset.Id}")" Style="font-size: 0.72rem; font-weight: bold; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">@asset.Name</MudLink>
                                    <MudSpacer />
                                    <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small" Color="Color.Error" OnClick="@(() => RemoveAsset(asset))" />
                                </div>
                            }
                            </div>
                        }
                        
                        <MudAutocomplete T="Asset" Label="Asset suchen & anfügen..." ValueChanged="AddAsset" 
                                         SearchFunc="SearchAssets" ToStringFunc="@(a => a == null ? null : $"{a.Name} ({a.AssetTag})")" 
                                         Variant="Variant.Outlined" Margin="Margin.Dense" Dense="true" Clearable="true" 
                                         ResetValueOnEmptyText="true" CoerceText="false" CoerceValue="false" />
                    </ChildContent>
                </MudExpansionPanel>

                <MudExpansionPanel IsExpanded="true">
                    <TitleContent><div class="d-flex align-center"><MudIcon Icon="@Icons.Material.Filled.PersonPin" Size="Size.Small" Class="mr-2"/><span class="sidebar-panel-header">Assets des Kontakts</span></div></TitleContent>
                    <ChildContent>
                        @if (_requesterAssets != null && _requesterAssets.Any()) {
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-1 d-block">Klicken zum Anfügen:</MudText>
                            <MudList T="string" Dense="true" Clickable="true">
                                @foreach(var a in _requesterAssets) {
                                    bool isAlreadyLinked = _ticket.AssignedAssets?.Any(ta => ta.Id == a.Id) ?? false;
                                    <MudListItem T="string" Icon="@Icons.Material.Filled.Devices" OnClick="@(() => { if(!isAlreadyLinked) AddAsset(a); })" Disabled="@isAlreadyLinked">
                                        <MudText Typo="Typo.caption" Style="@(isAlreadyLinked ? "text-decoration: line-through; opacity: 0.5;" : "")"><strong>@a.Name</strong> (@a.AssetTag)</MudText>
                                    </MudListItem>
                                }
                            </MudList>
                        } else {
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Keine Hardware zugewiesen.</MudText>
                        }
                    </ChildContent>
                </MudExpansionPanel>

            </MudExpansionPanels>
        </div>
    </div>
}

@code {
    [Parameter] public Guid Id { get; set; }
    private Ticket? _ticket;
    private Ticket? _originalTicket; 
    private List<Person> _availableSupporters = new();
    private List<AssetType> _dynamicAssetTypes = new();
    private List<Asset> _allAssets = new();
    private List<Asset> _requesterAssets = new();
    private List<Tenant> _tenants = new(); 
    private List<Ticket> _allTickets = new();

    private string _newComment = "";
    private int _newCommentMinutes = 0;
    private bool _commentIsPublic = true;
    private bool _showPrivateNotes = true;
    private bool _isSaving = false;
    private bool _isLoading = true;
    private bool _isAgent = false;
    private bool _hasUnsavedChanges = false;
    private DateTime? _dueAt;
    
    // JS Interop Reference
    private DotNetObjectReference<TicketDetails>? _objRef;

    private int RemainingMinutes => (_ticket?.EstimatedMinutes ?? 0) - (_ticket?.SpentMinutes ?? 0);

    public Ticket? SelectedMasterTicket
    {
        get => _ticket?.MasterTicketId.HasValue == true ? _allTickets.FirstOrDefault(t => t.Id == _ticket.MasterTicketId) : null;
        set {
            if (_ticket != null) {
                if (_ticket.MasterTicketId != value?.Id) {
                    _ticket.MasterTicketId = value?.Id;
                    OnFieldChanged();
                }
            }
        }
    }

    private static readonly JsonSerializerOptions _jsonOptions = new() 
    { 
        ReferenceHandler = ReferenceHandler.IgnoreCycles,
        DefaultIgnoreCondition = JsonIgnoreCondition.WhenWritingNull
    };

    protected override async Task OnInitializedAsync() {
        await LoadData();
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var role = authState.User.FindFirst(ClaimTypes.Role)?.Value;
        _isAgent = role is "Global Admin" or "Tenant Admin" or "CI Editor";
    }

    private async Task LoadData() {
        _isLoading = true;
        try { 
            _ticket = await Http.GetFromJsonAsync<Ticket>($"api/tickets/{Id}"); 
            if (_ticket != null) {
                _ticket.Activities ??= new List<TicketActivity>();
                _ticket.Watchers ??= new List<Person>();
                _ticket.AssignedAssets ??= new List<Asset>();
                _ticket.ChildTickets ??= new List<Ticket>();
                _dueAt = _ticket.DueAt;
                UpdateSnapshot();
                _hasUnsavedChanges = false;

                try { _allTickets = await Http.GetFromJsonAsync<List<Ticket>>("api/tickets") ?? new(); } catch { }
                try { _allAssets = await Http.GetFromJsonAsync<List<Asset>>("api/assets") ?? new(); } catch { }
                try { _availableSupporters = await Http.GetFromJsonAsync<List<Person>>("api/persons") ?? new(); } catch { }
                try { _dynamicAssetTypes = await Http.GetFromJsonAsync<List<AssetType>>("api/assets/types") ?? new(); } catch { }
                try { _tenants = await Http.GetFromJsonAsync<List<Tenant>>("api/tenants") ?? new(); } catch { }
                
                await LoadRequesterAssets();
            }
        } catch (Exception ex) { Snackbar.Add($"Fehler beim Laden: {ex.Message}", Severity.Error); }
        finally { _isLoading = false; }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var jsCode = @"
                window.attachImagePasteListener = function(wrapperId, dotNetRef) {
                    var wrapper = document.getElementById(wrapperId);
                    if(!wrapper) return;
                    
                    var el = wrapper.querySelector('textarea') || wrapper.querySelector('input');
                    if(el && !el.dataset.pasteAttached) {
                        el.dataset.pasteAttached = 'true';
                        
                        el.addEventListener('paste', function(e) {
                            var clipboardData = e.clipboardData || window.clipboardData;
                            if (!clipboardData) return;
                            
                            var items = clipboardData.items;
                            for (var i = 0; i < items.length; i++) {
                                if (items[i].type.indexOf('image') !== -1) {
                                    e.preventDefault(); 
                                    
                                    var blob = items[i].getAsFile();
                                    var reader = new FileReader();
                                    reader.onload = function(event) {
                                        dotNetRef.invokeMethodAsync('HandleImagePasted', event.target.result);
                                    };
                                    reader.readAsDataURL(blob);
                                    break;
                                }
                            }
                        });
                    }
                };
            ";
            
            await JSRuntime.InvokeVoidAsync("eval", jsCode);
            _objRef = DotNetObjectReference.Create(this);
        }

        if (!_isLoading && _ticket != null)
        {
            await JSRuntime.InvokeVoidAsync("attachImagePasteListener", "ticket-comment-wrapper", _objRef);
        }
    }

    [JSInvokable]
    public void HandleImagePasted(string base64Image)
    {
        string imgTag = $"\n<br/><img src=\"{base64Image}\" style=\"max-width: 100%; border-radius: 6px; border: 1px solid #ddd; margin: 10px 0;\" /><br/>\n";
        _newComment += imgTag;
        
        Snackbar.Add("Bild erfolgreich aus der Zwischenablage eingefügt.", Severity.Success);
        StateHasChanged();
    }

    // NEU: Logik zum Verarbeiten hochgeladener Dateien
    private async Task UploadFiles(IReadOnlyList<IBrowserFile> files)
    {
        foreach (var file in files)
        {
            try
            {
                // Max 10 MB pro Datei
                var maxAllowedSize = 10 * 1024 * 1024; 
                using var stream = file.OpenReadStream(maxAllowedSize);
                using var ms = new MemoryStream();
                await stream.CopyToAsync(ms);
                var base64 = Convert.ToBase64String(ms.ToArray());
                var mimeType = file.ContentType;
                
                if (mimeType.StartsWith("image/"))
                {
                    _newComment += $"\n<br/><img src=\"data:{mimeType};base64,{base64}\" style=\"max-width: 100%; border-radius: 6px; border: 1px solid #ddd; margin: 10px 0;\" /><br/>\n";
                }
                else
                {
                    // Erstellt einen eleganten Download-Button direkt im Text-Feld
                    _newComment += $"\n<br/><a href=\"data:{mimeType};base64,{base64}\" download=\"{file.Name}\" style=\"display: inline-flex; align-items: center; padding: 8px 12px; background: #f0f0f0; border: 1px solid #ccc; border-radius: 4px; text-decoration: none; color: #333; margin: 5px 0;\">📎 {file.Name} ({(file.Size / 1024)} KB)</a><br/>\n";
                }
                
                Snackbar.Add($"{file.Name} erfolgreich angehängt.", Severity.Success);
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Fehler bei {file.Name}: {ex.Message}", Severity.Error);
            }
        }
        StateHasChanged();
    }

    private async Task LoadRequesterAssets() {
        if (_ticket?.RequesterId.HasValue == true && _allAssets.Any()) {
            _requesterAssets = _allAssets.Where(a => a.OwnerId == _ticket.RequesterId).ToList();
        }
    }

    private void UpdateSnapshot() {
        if (_ticket != null) {
            var json = JsonSerializer.Serialize(_ticket, _jsonOptions);
            _originalTicket = JsonSerializer.Deserialize<Ticket>(json, _jsonOptions);
        }
    }

    private void OnFieldChanged() => _hasUnsavedChanges = true;

    private void DiscardChanges() {
        if (_originalTicket != null) {
            var json = JsonSerializer.Serialize(_originalTicket, _jsonOptions);
            _ticket = JsonSerializer.Deserialize<Ticket>(json, _jsonOptions);
            _dueAt = _ticket?.DueAt;
            _hasUnsavedChanges = false;
            Snackbar.Add("Änderungen verworfen.", Severity.Info);
        }
    }

    private async Task OnBeforeInternalNavigation(LocationChangingContext context) {
        if (_hasUnsavedChanges) {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Ungespeicherte Änderungen", 
                "Nicht gespeicherte Daten gehen verloren. Seite wirklich verlassen?", 
                yesText: "Verlassen",
                cancelText: "Bleiben");

            if (result == null || result == false) context.PreventNavigation();
        }
    }

    private void NavigateBack() {
        Nav.NavigateTo("/tickets");
    }

    private async Task AddCommentAndNotify() {
        if (string.IsNullOrWhiteSpace(_newComment)) return;
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var userName = authState.User.Identity?.Name ?? "System Agent";

        var act = new TicketActivity { 
            Id = Guid.NewGuid(), TicketId = _ticket!.Id, AuthorName = userName, 
            Content = _newComment, Timestamp = DateTime.UtcNow, IsPublic = _commentIsPublic,
            IsStaffAction = true, Type = "Comment", ActivitySpentMinutes = _newCommentMinutes
        };
        
        _ticket.SpentMinutes += _newCommentMinutes;
        _ticket.Activities.Add(act);
        
        if (_commentIsPublic) Snackbar.Add($"E-Mail gesendet.", Severity.Info);
        else Snackbar.Add("Interne Notiz gespeichert.", Severity.Warning);

        _newComment = ""; _newCommentMinutes = 0;
        await SaveTicketWithLogging(isNewComment: true);
    }

    private async Task<bool> SaveTicketWithLogging(bool isNewComment = false) {
        if (_ticket == null || _isSaving || _isLoading) return false;
        _isSaving = true;
        
        var newActivities = new List<TicketActivity>();

        try {
            _ticket.DueAt = _dueAt;
            
            if (_originalTicket != null && !isNewComment) {
                if (_originalTicket.Status != _ticket.Status) newActivities.Add(CreateSysActivity($"Status: '{_originalTicket.Status}' -> '{_ticket.Status}'"));
                if (_originalTicket.Priority != _ticket.Priority) newActivities.Add(CreateSysActivity($"Priorität: '{_originalTicket.Priority}' -> '{_ticket.Priority}'"));
                if (_originalTicket.RequesterId != _ticket.RequesterId) newActivities.Add(CreateSysActivity("Kontakt aktualisiert."));
                
                // Logging Logik für die Kategorien
                if (_originalTicket.Category1 != _ticket.Category1) newActivities.Add(CreateSysActivity($"Ticket-Typ: '{_ticket.Category1}'"));
                if (_originalTicket.Category3 != _ticket.Category3) newActivities.Add(CreateSysActivity($"Subkategorie: '{_ticket.Category3}'"));
                if (_originalTicket.Tags != _ticket.Tags) newActivities.Add(CreateSysActivity($"Schlagworte aktualisiert."));
                if ((_originalTicket.AssignedAssets?.Count ?? 0) != (_ticket.AssignedAssets?.Count ?? 0)) newActivities.Add(CreateSysActivity($"Verknüpfte Assets aktualisiert."));
                if (_originalTicket.MasterTicketId != _ticket.MasterTicketId) newActivities.Add(CreateSysActivity($"Master-Ticket Zuweisung geändert."));

                foreach(var act in newActivities) _ticket.Activities.Add(act);
            }

            var res = await Http.PutAsJsonAsync($"api/tickets/{_ticket.Id}", _ticket, _jsonOptions);
            
            if (res.IsSuccessStatusCode) { 
                UpdateSnapshot(); 
                _hasUnsavedChanges = false;
                Snackbar.Add("Ticket gespeichert.", Severity.Success);
                return true; 
            } else {
                var error = await res.Content.ReadAsStringAsync();
                Snackbar.Add($"Fehler: {error}", Severity.Error);
                foreach(var act in newActivities) _ticket.Activities.Remove(act);
                return false;
            }
        } catch (Exception ex) {
            Snackbar.Add($"Netzwerkfehler: {ex.Message}", Severity.Error);
            foreach(var act in newActivities) _ticket.Activities.Remove(act);
            return false;
        } finally { _isSaving = false; StateHasChanged(); }
    }

    private TicketActivity CreateSysActivity(string content) => new TicketActivity { 
        Id = Guid.NewGuid(), TicketId = _ticket!.Id, AuthorName = "System", 
        Content = content, Timestamp = DateTime.UtcNow, Type = "System", IsPublic = true 
    };

    private async Task OnRequesterChanged() { await LoadRequesterAssets(); OnFieldChanged(); }

    private Task<IEnumerable<Ticket>> SearchTickets(string value, CancellationToken cancellationToken) {
        if (string.IsNullOrWhiteSpace(value)) return Task.FromResult(_allTickets.Where(t => t.Id != _ticket?.Id).Take(10));
        return Task.FromResult(_allTickets.Where(t => t.Id != _ticket?.Id && 
            (t.TicketNumber.ToString().Contains(value) || t.Title.Contains(value, StringComparison.OrdinalIgnoreCase))
        ).Take(10));
    }

    private Task<IEnumerable<Asset>> SearchAssets(string value, CancellationToken cancellationToken) {
        if (string.IsNullOrWhiteSpace(value)) return Task.FromResult(_allAssets.Take(10));
        return Task.FromResult(_allAssets.Where(a => 
            (a.Name?.Contains(value, StringComparison.OrdinalIgnoreCase) == true) || 
            (a.AssetTag?.Contains(value, StringComparison.OrdinalIgnoreCase) == true)
        ).Take(10));
    }

    private void AddAsset(Asset? a) { 
        if (a != null) {
            _ticket!.AssignedAssets ??= new List<Asset>();
            if (!_ticket.AssignedAssets.Any(x => x.Id == a.Id)) {
                _ticket.AssignedAssets.Add(a);
                OnFieldChanged();
            }
        }
    }

    private void RemoveAsset(Asset a) { _ticket?.AssignedAssets?.Remove(a); OnFieldChanged(); }

    private void AddWatcher(Person p) { 
        _ticket!.Watchers ??= new List<Person>(); 
        if (!_ticket.Watchers.Any(w => w.Id == p.Id)) { 
            _ticket.Watchers.Add(p); 
            OnFieldChanged();
        } 
    }

    private void RemoveWatcher(Person p) { 
        _ticket?.Watchers?.Remove(p); 
        OnFieldChanged(); 
    }

    private string GetStatusHex(string s) => (s ?? "").ToUpper() switch { "OFFEN" => "#2E7D32", "BEANTWORTET" => "#1976D2", "AKTIV" => "#C62828", _ => "#757575" };
    
    private string GetItilIcon(string? category) => category switch {
        "Incident (Störung)" => Icons.Material.Filled.Bolt,
        "Service Request (Serviceanfrage)" => Icons.Material.Filled.ShoppingCart,
        "Change (Änderung)" => Icons.Material.Filled.Settings,
        "Problem (Problem)" => Icons.Material.Filled.Search,
        _ => Icons.Material.Filled.Label
    };

    private Color GetItilColor(string? category) => category switch {
        "Incident (Störung)" => Color.Error,
        "Service Request (Serviceanfrage)" => Color.Info,
        "Change (Änderung)" => Color.Warning,
        "Problem (Problem)" => Color.Dark,
        _ => Color.Default
    };

    public async ValueTask DisposeAsync()
    {
        _objRef?.Dispose();
    }
}