@* Dateipfad: src/InfraDesk.UI.Web/Components/Pages/Search.razor *@
@page "/search"
@using Microsoft.AspNetCore.Components.Forms
@using MudBlazor
@using InfraDesk.UI.Web.Services
@inject HttpClient Http
@inject NavigationManager Nav
@inject ThemeService ThemeService
@inject ISnackbar Snackbar

<PageTitle>InfraDesk - Globale Suche</PageTitle>

<style>
    .pdq-container { background-color: #fff; height: calc(100vh - 110px); display: flex; flex-direction: row; }
    .pdq-sidebar { width: 240px; border-right: 1px solid #ccc; background-color: #f0f0f0; overflow-y: auto; flex-shrink: 0; }
    .pdq-content { flex-grow: 1; overflow-y: auto; background-color: #fff; padding: 12px 20px; }
    .pdq-toolbar { height: 42px; background-color: #eee; border-bottom: 1px solid #ccc; display: flex; align-items: center; padding: 0 12px; }
    .sidebar-active { background-color: #fff !important; font-weight: bold; border-left: 4px solid var(--mud-palette-primary); color: var(--mud-palette-primary) !important; }
</style>

<div class="pdq-toolbar">
    <MudIcon Icon="@Icons.Material.Filled.Search" Color="Color.Primary" Size="Size.Small" Class="mr-2" />
    <MudText Typo="Typo.body2" Class="font-weight-bold">Suchergebnisse für "@Query"</MudText>
</div>

<div class="pdq-container">
    <div class="pdq-sidebar">
        <div class="pa-4 font-weight-bold" style="font-size:0.75rem;">FILTER</div>
        <MudNavLink OnClick="@(() => SetFilter(null))" Class="@(string.IsNullOrEmpty(_activeFilter) ? "sidebar-active" : "")" Icon="@Icons.Material.Filled.List">Alle (@(_searchResults.Count))</MudNavLink>
        <MudNavLink OnClick="@(() => SetFilter("Asset"))" Class="@(_activeFilter == "Asset" ? "sidebar-active" : "")" Icon="@Icons.Material.Filled.Dns">Assets</MudNavLink>
        <MudNavLink OnClick="@(() => SetFilter("Ticket"))" Class="@(_activeFilter == "Ticket" ? "sidebar-active" : "")" Icon="@Icons.Material.Filled.ConfirmationNumber">Tickets</MudNavLink>
    </div>

    <div class="pdq-content">
        <MudDataGrid T="SearchResultDto" Items="@FilteredResults" Hover="true" RowClick="@((args) => Nav.NavigateTo(args.Item.Url))" Dense="true" Bordered="true">
            <ToolBarContent>
                <MudSpacer />
                <MudTextField @bind-Value="_gridSearchString" Placeholder="In Ergebnissen filtern..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.FilterList" IconSize="Size.Small" Margin="Margin.Dense" Class="mr-4" Style="max-width: 400px;" />
                <MudTooltip Text="Export"><MudIconButton Icon="@Icons.Material.Filled.FileDownload" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Default" OnClick="ExportCsv" /></MudTooltip>
            </ToolBarContent>
            <Columns>
                <PropertyColumn Property="@(x => x.Type)" Title="Kategorie" HeaderStyle="width:120px;" />
                <PropertyColumn Property="@(x => x.Title)" Title="Bezeichnung" />
                <PropertyColumn Property="@(x => x.Subtitle)" Title="Details" />
                <PropertyColumn Property="@(x => x.Status)" Title="Status" />
            </Columns>
        </MudDataGrid>
    </div>
</div>

@code {
    public class SearchResultDto { public Guid Id { get; set; } public string Type { get; set; } = ""; public string Title { get; set; } = ""; public string Subtitle { get; set; } = ""; public string Url { get; set; } = ""; public string Status { get; set; } = ""; }
    
    [SupplyParameterFromQuery(Name = "q")] public string? Query { get; set; }
    private List<SearchResultDto> _searchResults = new();
    private string? _activeFilter = null;
    private string _gridSearchString = "";

    private IEnumerable<SearchResultDto> FilteredResults => _searchResults.Where(x => string.IsNullOrEmpty(_activeFilter) || x.Type == _activeFilter);

    protected override async Task OnParametersSetAsync() {
        if (!string.IsNullOrWhiteSpace(Query)) _searchResults = await Http.GetFromJsonAsync<List<SearchResultDto>>($"api/search?q={Uri.EscapeDataString(Query)}") ?? new();
    }

    // FIX: "_activeFilter = filter" war falsch, Variable heißt f
    private void SetFilter(string? f) => _activeFilter = f;
    private void ExportCsv() => Snackbar.Add("Export...");
}