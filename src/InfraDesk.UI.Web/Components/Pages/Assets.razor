@* Dateipfad: src/InfraDesk.UI.Web/Components/Pages/Assets.razor *@
@page "/assets"
@using InfraDesk.Core.Entities
@using MudBlazor
@using System.Text.Json
@inject HttpClient Http
@inject NavigationManager Nav

<PageTitle>InfraDesk - Asset-CMDB</PageTitle>

<style>
    /* PDQ Inventory Style: High Density Layout */
    .pdq-container { background-color: #fff; height: calc(100vh - 100px); display: flex; flex-direction: row; border-top: none; }
    .pdq-sidebar { width: 260px; border-right: 1px solid #ccc; background-color: #f0f0f0; overflow-y: auto; flex-shrink: 0; }
    .pdq-content { flex-grow: 1; overflow-y: auto; background-color: #fff; padding: 12px 24px; }
    
    .pdq-section-header { background-color: #e0e0e0; padding: 4px 12px; font-weight: 800; font-size: 0.75rem; text-transform: uppercase; border-bottom: 1px solid #ccc; border-top: 1px solid #ccc; color: #333; margin-bottom: 8px; margin-top: 16px; }
    .pdq-section-header:first-child { margin-top: 0; border-top: none; }
    
    .pdq-toolbar { height: 42px; background-color: #eee; border-bottom: 1px solid #ccc; display: flex; align-items: center; padding: 0 12px; }
    
    .sidebar-active { background-color: #fff !important; font-weight: bold; border-left: 4px solid var(--mud-palette-primary); color: var(--mud-palette-primary) !important; }
    
    /* Grid Optimierung für hohe Dichte */
    .mud-table-cell { padding: 4px 12px !important; font-size: 0.82rem !important; }
    .mud-table-row:hover { background-color: rgba(25, 118, 210, 0.05) !important; cursor: pointer; }
</style>

<!-- PDQ Toolbar -->
<div class="pdq-toolbar">
    <MudIcon Icon="@Icons.Material.Filled.Dns" Color="Color.Primary" Size="Size.Small" Class="mr-2" />
    <MudText Typo="Typo.body2" Class="font-weight-bold">Asset-CMDB: @(_activeFilter ?? "Gesamtkatalog")</MudText>
    <MudSpacer />
    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" Size="Size.Small" OnClick="@(() => Nav.NavigateTo("/assets/create"))" Style="text-transform:none; border-radius: 4px;">Objekt hinzufügen</MudButton>
</div>

<div class="pdq-container">
    
    <!-- ERWEITERTE SIDEBAR: Alle Kategorien wiederhergestellt -->
    <div class="pdq-sidebar">
        <MudNavMenu Margin="Margin.Dense" Rounded="false">
            
            <div class="pdq-section-header" style="margin-top: 0; border-top: none;">Filter</div>
            <MudNavLink OnClick="@(() => SetFilter(null))" Class="@(string.IsNullOrEmpty(_activeFilter) ? "sidebar-active" : "")" Icon="@Icons.Material.Filled.List">Alle Objekte</MudNavLink>
            
            <div class="pdq-section-header">Computer & Mobile</div>
            <MudNavLink OnClick="@(() => SetFilter("Hardware"))" Class="@(_activeFilter == "Hardware" ? "sidebar-active" : "")" Icon="@Icons.Material.Filled.Computer">Clients & Server</MudNavLink>
            
            <div class="pdq-section-header">Netzwerk</div>
            <MudNavLink OnClick="@(() => SetFilter("Network"))" Class="@(_activeFilter == "Network" ? "sidebar-active" : "")" Icon="@Icons.Material.Filled.SettingsInputComponent">Switche & Firewalls</MudNavLink>
            
            <div class="pdq-section-header">Storage & Backup</div>
            <MudNavLink OnClick="@(() => SetFilter("Storage"))" Class="@(_activeFilter == "Storage" ? "sidebar-active" : "")" Icon="@Icons.Material.Filled.SdStorage">SAN / NAS / Tape</MudNavLink>

            <div class="pdq-section-header">Cloud & Virtualisierung</div>
            <MudNavLink OnClick="@(() => SetFilter("Cloud"))" Class="@(_activeFilter == "Cloud" ? "sidebar-active" : "")" Icon="@Icons.Material.Filled.Cloud">Instanzen & Cluster</MudNavLink>

            <div class="pdq-section-header">Software & Plattformen</div>
            <MudNavLink OnClick="@(() => SetFilter("Software"))" Class="@(_activeFilter == "Software" ? "sidebar-active" : "")" Icon="@Icons.Material.Filled.Terminal">DBs & Applikationen</MudNavLink>

            <div class="pdq-section-header">Rechenzentrum & Strom</div>
            <MudNavLink OnClick="@(() => SetFilter("Datacenter"))" Class="@(_activeFilter == "Datacenter" ? "sidebar-active" : "")" Icon="@Icons.Material.Filled.EvStation">USV / Racks / Klima</MudNavLink>

            <div class="pdq-section-header">Organisation</div>
            <MudNavLink OnClick="@(() => SetFilter("Org"))" Class="@(_activeFilter == "Org" ? "sidebar-active" : "")" Icon="@Icons.Material.Filled.Groups">Personen & Teams</MudNavLink>

        </MudNavMenu>
    </div>

    <!-- RECHTE SEITE: DataGrid -->
    <div class="pdq-content">
        @if (_assets == null)
        {
            <div class="d-flex justify-center align-center" style="height: 200px;">
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
            </div>
        }
        else
        {
            <MudDataGrid T="Asset" Items="@FilteredAssets" Hover="true" RowClick="@OnRowClicked" Filterable="true" QuickFilter="@QuickFilter" Dense="true" Elevation="0" Bordered="true">
                <ToolBarContent>
                    <MudSpacer />
                    <MudTextField @bind-Value="_searchString" Placeholder="Suche in Name, S/N oder Tag..." Adornment="Adornment.Start" 
                                  AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Small" Immediate="true" Margin="Margin.Dense" Style="max-width: 400px;"></MudTextField>
                </ToolBarContent>
                <Columns>
                    <TemplateColumn Title="Typ" HeaderStyle="width: 40px;" Sortable="false">
                        <CellTemplate>
                            <MudTooltip Text="@context.Item.AssetType?.Name">
                                <MudIcon Icon="@GetIcon(context.Item.AssetType?.Name)" Size="Size.Small" Color="Color.Primary" />
                            </MudTooltip>
                        </CellTemplate>
                    </TemplateColumn>
                    
                    <PropertyColumn Property="x => x.Name" Title="Bezeichnung" />
                    <PropertyColumn Property="x => x.AssetTag" Title="Asset-Tag" />
                    <PropertyColumn Property="x => x.SerialNumber" Title="S/N" />
                    <PropertyColumn Property="@(x => x.AssetType != null ? x.AssetType.Name : "---")" Title="Typ" />
                    <PropertyColumn Property="@(x => x.Location != null ? x.Location.Name : "---")" Title="Standort" />
                    
                    <TemplateColumn Title="Status" HeaderStyle="width: 120px;">
                        <CellTemplate>
                            <MudChip T="string" Size="Size.Small" 
                                     Color="@GetStatusColor(context.Item.LifecycleStatus)" 
                                     Variant="Variant.Text" 
                                     Class="font-weight-bold">
                                @context.Item.LifecycleStatus
                            </MudChip>
                        </CellTemplate>
                    </TemplateColumn>
                </Columns>
                <PagerContent>
                    <MudDataGridPager T="Asset" PageSizeOptions="new int[] { 25, 50, 100, 500 }" />
                </PagerContent>
            </MudDataGrid>
        }
    </div>
</div>

@code {
    private List<Asset>? _assets;
    private string _searchString = "";
    private string? _activeFilter = null;

    private IEnumerable<Asset> FilteredAssets => _assets?
        .Where(a => _activeFilter == null || IsInCategory(a, _activeFilter)) ?? Enumerable.Empty<Asset>();

    protected override async Task OnInitializedAsync()
    {
        try { _assets = await Http.GetFromJsonAsync<List<Asset>>("api/assets"); }
        catch { _assets = new List<Asset>(); }
    }

    private void SetFilter(string? filter) => _activeFilter = filter;

    private void OnRowClicked(DataGridRowClickEventArgs<Asset> args) => Nav.NavigateTo($"/assets/{args.Item.Id}");

    private Color GetStatusColor(string? status) => status switch {
        "Produktiv" or "Aktiv" => Color.Success,
        "Wartung" or "In Planung" => Color.Warning,
        "Defekt" or "Ausgemustert" => Color.Error,
        _ => Color.Default
    };

    // VOLLSTÄNDIGE KATEGORIE-LOGIK WIEDERHERGESTELLT
    private bool IsInCategory(Asset a, string cat) {
        var name = a.AssetType?.Name;
        if (string.IsNullOrEmpty(name)) return false;

        return cat switch {
            "Hardware" => name is "Rack-Server" or "Laptop" or "Mainframe" or "Blade-Center" or "Desktop" or "Workstation" or "Tablet" or "Smartphone" or "Backup-Appliance" or "Hardware-Appliance",
            "Storage" => name is "SAN-Storage" or "NAS-System" or "NVMe-Array" or "Tape-Library",
            "Network" => name is "Core-Switch" or "Access-Switch" or "Firewall" or "Router" or "Load-Balancer" or "VPN-Gateway" or "Access-Point" or "IDS-IPS-System" or "WLAN-Controller" or "WAN-Leitung" or "Internet-Breakout" or "SFP-Modul",
            "Cloud" => name is "Cloud-Instanz" or "S3-Bucket" or "VM-Cluster" or "Kubernetes-Cluster" or "Kubernetes-Namespace" or "Entra-ID-Tenant" or "Azure-VM" or "AWS-EC2" or "Cloud-VNET" or "Docker-Host" or "K8s-Node",
            "Datacenter" => name is "USV-Anlage" or "Klimagerät" or "PDU" or "Rack" or "Stellplatz",
            "Software" => name is "Betriebssystem" or "Datenbank-Instanz" or "MS-SQL-Server" or "PostgreSQL-DB" or "Oracle-DB" or "SAP-HANA" or "Active-Directory-Domain" or "DNS-DHCP-Server" or "PKI-Dienst" or "Linux-Distribution" or "Client-OS",
            "Org" => name is "Person" or "Kontakt" or "Gruppe" or "Team" or "Kostenstelle",
            _ => false
        };
    }

    // VOLLSTÄNDIGE ICON-MAPPING WIEDERHERGESTELLT
    private string GetIcon(string? type) => type switch {
        "Laptop" => Icons.Material.Filled.Laptop,
        "Desktop" or "Client-OS" => Icons.Material.Filled.DesktopWindows,
        "Workstation" => Icons.Material.Filled.Computer,
        "Smartphone" => Icons.Material.Filled.Smartphone,
        "Tablet" => Icons.Material.Filled.TabletAndroid,
        "Rack-Server" => Icons.Material.Filled.Storage,
        "Blade-Center" => Icons.Material.Filled.ViewQuilt,
        "Mainframe" => Icons.Material.Filled.DeveloperBoard,
        "Rack" or "Stellplatz" => Icons.Material.Filled.ViewArray,
        "PDU" => Icons.Material.Filled.Power,
        "USV-Anlage" => Icons.Material.Filled.BatteryChargingFull,
        "Klimagerät" => Icons.Material.Filled.AcUnit,
        "SAN-Storage" or "NVMe-Array" => Icons.Material.Filled.Dns,
        "NAS-System" => Icons.Material.Filled.FolderShared,
        "Tape-Library" => Icons.Material.Filled.Save,
        "Core-Switch" or "Access-Switch" => Icons.Material.Filled.SettingsInputComponent,
        "Router" => Icons.Material.Filled.Router,
        "Access-Point" => Icons.Material.Filled.Wifi,
        "Firewall" => Icons.Material.Filled.Security,
        "VPN-Gateway" => Icons.Material.Filled.VpnLock,
        "Cloud-Instanz" or "Azure VM" => Icons.Material.Filled.Cloud,
        "Kubernetes-Cluster" or "VM-Cluster" => Icons.Material.Filled.Hub,
        "Betriebssystem" or "Windows Server" => Icons.Material.Filled.Settings,
        "PostgreSQL-DB" or "MS-SQL-Server" or "Datenbank-Instanz" => Icons.Material.Filled.Dataset,
        "Person" or "Kontakt" => Icons.Material.Filled.Person,
        "Gruppe" or "Team" => Icons.Material.Filled.Groups,
        _ => Icons.Material.Filled.Label
    };

    private Func<Asset, bool> QuickFilter => x => string.IsNullOrWhiteSpace(_searchString) || 
        (x.Name?.Contains(_searchString, StringComparison.OrdinalIgnoreCase) ?? false) || 
        (x.AssetTag?.Contains(_searchString, StringComparison.OrdinalIgnoreCase) ?? false) ||
        (x.SerialNumber?.Contains(_searchString, StringComparison.OrdinalIgnoreCase) ?? false);
}