@* Dateipfad: src/InfraDesk.UI.Web/Components/Pages/Assets.razor *@
@page "/assets"
@using Microsoft.AspNetCore.Components.Forms
@using InfraDesk.Core.Entities
@using MudBlazor
@using System.Text
@using System.Text.Json
@using System.Threading.Tasks
@using System.Linq
@using InfraDesk.UI.Web.Services
@inject HttpClient Http
@inject ThemeService ThemeService
@inject ISnackbar Snackbar
@inject NavigationManager Nav
@inject IJSRuntime JSRuntime

<PageTitle>InfraDesk - CMDB (Assets)</PageTitle>

<style>
    .pdq-container { background-color: #fff; height: calc(100vh - 110px); display: flex; flex-direction: row; }
    .pdq-sidebar { width: 340px; border-right: 1px solid #ccc; background-color: #f0f0f0; overflow-y: auto; flex-shrink: 0; padding-bottom: 20px; }
    .pdq-content { flex-grow: 1; overflow-y: auto; background-color: #fff; padding: 20px; }
    .pdq-toolbar { height: 42px; background-color: #eee; border-bottom: 1px solid #ccc; display: flex; align-items: center; padding: 0 12px; }
    
    .sidebar-section { padding: 12px 16px; border-bottom: 1px solid #e0e0e0; }
    .sidebar-header { font-weight: 800; font-size: 0.75rem; text-transform: uppercase; color: #555; margin-bottom: 8px; }
    .import-btn-wrapper { display: inline-flex; align-items: center; }
</style>

<div class="pdq-toolbar">
    <MudIcon Icon="@Icons.Material.Filled.Computer" Color="Color.Primary" Size="Size.Small" Class="mr-2" />
    <MudText Typo="Typo.body2" Class="font-weight-bold">CMDB (Assets)</MudText>
    <MudSpacer />
    
    @if (_selectedItems != null && _selectedItems.Count > 1) {
        <MudButton Variant="Variant.Filled" Color="Color.Secondary" StartIcon="@Icons.Material.Filled.Edit" Size="Size.Small" Style="text-transform:none; margin-right: 16px;">
            Massenbearbeitung (@_selectedItems.Count)
        </MudButton>
    }
    
    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" Size="Size.Small" OnClick="@(() => Nav.NavigateTo("/assets/create"))">Asset anlegen</MudButton>
</div>

<div class="pdq-container">
    <div class="pdq-sidebar">
        <div class="sidebar-section" style="background:#e0e0e0;">
            <MudText Typo="Typo.body2" Class="font-weight-bold">QUICK FILTER</MudText>
        </div>
        
        <div class="sidebar-section">
            <div class="sidebar-header">Status</div>
            <MudSelect T="string" Value="@_filterStatus" ValueChanged="OnStatusFilterChanged" Clearable="true" Placeholder="Alle Status" Margin="Margin.Dense" Variant="Variant.Outlined" Dense="true">
                @foreach (var status in _lifecycleStatuses)
                {
                    <MudSelectItem Value="@status">@status</MudSelectItem>
                }
            </MudSelect>
        </div>

        <div class="sidebar-section">
            <div class="d-flex justify-space-between align-center mb-2">
                <div class="sidebar-header mb-0">CMDB Kategorien</div>
                @if (_filterTypeId.HasValue) {
                    <MudTooltip Text="Filter zurücksetzen">
                        <MudIconButton Icon="@Icons.Material.Filled.Clear" Size="Size.Small" Color="Color.Error" OnClick="@(() => OnCategorySelected(null))" Style="padding: 2px; margin-top: -4px;" />
                    </MudTooltip>
                }
            </div>
            
            <div style="background: white; border: 1px solid #ccc; border-radius: 4px; max-height: 350px; overflow-y: auto; padding: 4px;">
                @if (_assetTypes.Any())
                {
                    <MudTreeView T="Guid?" SelectedValue="@_filterTypeId" SelectedValueChanged="OnCategorySelected" Hover="true" Dense="true" Color="Color.Primary">
                        @RenderCategoryTree(_assetTypes.Where(t => t.ParentAssetTypeId == null).OrderBy(t => t.Name))
                    </MudTreeView>
                }
                else
                {
                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="pa-2 d-block text-center">Keine Kategorien gefunden</MudText>
                }
            </div>
        </div>

        <div class="sidebar-section">
            <div class="d-flex justify-space-between align-center mb-2">
                <div class="sidebar-header mb-0">Standort & Geografie</div>
                @if (_filterLocationId.HasValue) {
                    <MudTooltip Text="Filter zurücksetzen">
                        <MudIconButton Icon="@Icons.Material.Filled.Clear" Size="Size.Small" Color="Color.Error" OnClick="@(() => OnLocationSelected(null))" Style="padding: 2px; margin-top: -4px;" />
                    </MudTooltip>
                }
            </div>
            
            <div style="background: white; border: 1px solid #ccc; border-radius: 4px; max-height: 350px; overflow-y: auto; padding: 4px;">
                @if (_locations.Any())
                {
                    <MudTreeView T="Guid?" SelectedValue="@_filterLocationId" SelectedValueChanged="OnLocationSelected" Hover="true" Dense="true" Color="Color.Primary">
                        @RenderLocationTree(_locations.Where(l => l.ParentLocationId == null).OrderBy(l => l.Name))
                    </MudTreeView>
                }
                else
                {
                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="pa-2 d-block text-center">Keine Standorte gefunden</MudText>
                }
            </div>
        </div>
    </div>

    <div class="pdq-content">
        @if (_isLoading) {
            <div class="d-flex justify-center align-center h-100"><MudProgressCircular Color="Color.Primary" Indeterminate="true" /></div>
        } else {
            <MudDataGrid T="Asset" Items="@_filteredAssets" Hover="true" Dense="true" Bordered="true" Elevation="0" MultiSelection="true" @bind-SelectedItems="_selectedItems" RowClick="@OnRowClicked">
                <ToolBarContent>
                    <MudText Typo="Typo.h6">Gefundene Assets (@_filteredAssets.Count)</MudText>
                    <MudSpacer />
                    
                    <MudTextField T="string" Value="@_searchString" ValueChanged="OnSearchChanged" Immediate="true" Placeholder="Suche (Tag, Name, SN)..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Small" Margin="Margin.Dense" Class="mr-4 mt-0" Style="max-width:300px;" />
                    
                    <MudTooltip Text="Spalten anpassen">
                        <MudMenu Icon="@Icons.Material.Filled.ViewColumn" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Default" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight" Dense="true" AutoClose="false" Class="mr-2">
                            <div class="pa-4" style="min-width: 280px;">
                                <MudText Typo="Typo.subtitle2" Class="mb-3 font-weight-bold">Sichtbare Spalten</MudText>
                                @foreach (var col in _columns.OrderBy(c => c.Order)) {
                                    <div class="d-flex align-center mb-1">
                                        <MudCheckBox T="bool" Value="@col.Visible" ValueChanged="@(v => { col.Visible = v; StateHasChanged(); })" Label="@col.Title" Dense="true" Class="mr-auto" />
                                        <MudIconButton Icon="@Icons.Material.Filled.KeyboardArrowUp" Size="Size.Small" OnClick="@(() => MoveColUp(col))" Disabled="@(col.Order == 1)" />
                                        <MudIconButton Icon="@Icons.Material.Filled.KeyboardArrowDown" Size="Size.Small" OnClick="@(() => MoveColDown(col))" Disabled="@(col.Order == _columns.Count)" />
                                    </div>
                                }
                            </div>
                        </MudMenu>
                    </MudTooltip>

                    <MudTooltip Text="CSV Export"><MudIconButton Icon="@Icons.Material.Filled.FileDownload" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Default" OnClick="ExportCsv" Class="mr-2" /></MudTooltip>
                    
                    <div class="import-btn-wrapper">
                        <MudTooltip Text="Aus CSV importieren">
                            <MudIconButton HtmlTag="label" for="import-csv-assets" Icon="@Icons.Material.Filled.FileUpload" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Default" />
                        </MudTooltip>
                        <InputFile id="import-csv-assets" OnChange="@ImportCsv" accept=".csv" style="display: none;" />
                    </div>
                </ToolBarContent>
                
                <Columns>
                    <SelectColumn T="Asset" />
                    
                    @foreach (var col in _columns.OrderBy(c => c.Order))
                    {
                        if (col.Id == "Type" && col.Visible)
                        {
                            <TemplateColumn Title="Typ" HeaderStyle="width: 40px;" Sortable="false" Filterable="false">
                                <CellTemplate>
                                    <MudIcon Icon="@GetDynamicIcon(context.Item.AssetType?.IconKey)" Size="Size.Small" Color="Color.Primary" />
                                </CellTemplate>
                            </TemplateColumn>
                        }
                        else if (col.Id == "Status" && col.Visible)
                        {
                            <PropertyColumn Property="@(x => x.LifecycleStatus)" Title="Status">
                                <CellTemplate>
                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="@GetStatusColor(context.Item.LifecycleStatus)">
                                        @context.Item.LifecycleStatus
                                    </MudChip>
                                </CellTemplate>
                            </PropertyColumn>
                        }
                        else if (col.Id == "Tag" && col.Visible)
                        {
                            <PropertyColumn Property="@(x => x.AssetTag)" Title="Asset-Tag" />
                        }
                        else if (col.Id == "Name" && col.Visible)
                        {
                            <PropertyColumn Property="@(x => x.Name)" Title="Name">
                                <CellTemplate>
                                    <MudLink Href="@($"/assets/{context.Item.Id}")" Typo="Typo.body2" Class="font-weight-bold">
                                        @context.Item.Name
                                    </MudLink>
                                </CellTemplate>
                            </PropertyColumn>
                        }
                        else if (col.Id == "Category" && col.Visible)
                        {
                            <PropertyColumn Property="@(x => x.AssetType != null ? x.AssetType.Name : "")" Title="Kategorie">
                                <CellTemplate>
                                    @if(context.Item.AssetType != null) {
                                        <div class="d-flex align-center">
                                            @GetCategoryPath(context.Item.AssetTypeId)
                                        </div>
                                    }
                                </CellTemplate>
                            </PropertyColumn>
                        }
                        else if (col.Id == "Manufacturer" && col.Visible)
                        {
                            <PropertyColumn Property="@(x => x.Manufacturer != null ? x.Manufacturer.Name : "")" Title="Hersteller" />
                        }
                        else if (col.Id == "Owner" && col.Visible)
                        {
                            <PropertyColumn Property="@(x => x.Owner != null ? x.Owner.LastName : "")" Title="Zugewiesen an">
                                <CellTemplate>
                                    @(context.Item.Owner != null ? $"{context.Item.Owner.FirstName} {context.Item.Owner.LastName}" : "-")
                                </CellTemplate>
                            </PropertyColumn>
                        }
                        else if (col.Id == "Location" && col.Visible)
                        {
                            <PropertyColumn Property="@(x => x.Location != null ? x.Location.Name : "")" Title="Standort">
                                <CellTemplate>
                                    @(GetLocationPath(context.Item.LocationId))
                                </CellTemplate>
                            </PropertyColumn>
                        }
                    }
                </Columns>
                <PagerContent>
                    <MudDataGridPager T="Asset" PageSizeOptions="@(new int[] { 50, 100, 250, 500, 1000 })" />
                </PagerContent>
            </MudDataGrid>
        }
    </div>
</div>

@code {
    private List<Asset> _assets = new();
    private List<Asset> _filteredAssets = new();
    private List<AssetType> _assetTypes = new();
    private List<Location> _locations = new();
    
    private bool _isLoading = true;
    private string _searchString = "";
    private string? _filterStatus;
    private Guid? _filterTypeId;
    private Guid? _filterLocationId;
    
    private HashSet<Asset> _selectedItems = new();
    private List<string> _lifecycleStatuses = new() { "Produktiv", "Auf Lager", "Ausgemustert" };

    // --- CACHES FÜR MASSIVE PERFORMANCE STEIGERUNG ---
    private Dictionary<Guid, string> _locationPathCache = new();
    private Dictionary<Guid, string> _categoryPathCache = new();
    private Dictionary<Guid, AssetType> _typeDict = new();
    private Dictionary<Guid, Location> _locDict = new();
    private ILookup<Guid?, Location> _locationsByParent = Array.Empty<Location>().ToLookup(x => x.ParentLocationId);
    private ILookup<Guid?, AssetType> _categoriesByParent = Array.Empty<AssetType>().ToLookup(x => x.ParentAssetTypeId);
    private static readonly Dictionary<string, string> _iconCache = new();

    public class ColumnDef { public string Id { get; set; } = ""; public string Title { get; set; } = ""; public bool Visible { get; set; } = true; public int Order { get; set; } }
    
    private List<ColumnDef> _columns = new()
    {
        new() { Id = "Type", Title = "Typ-Icon", Order = 1 },
        new() { Id = "Status", Title = "Status", Order = 2 },
        new() { Id = "Tag", Title = "Asset-Tag", Order = 3 },
        new() { Id = "Name", Title = "Name", Order = 4 },
        new() { Id = "Category", Title = "Kategorie", Order = 5 },
        new() { Id = "Manufacturer", Title = "Hersteller", Order = 6 },
        new() { Id = "Owner", Title = "Zugewiesen an", Order = 7 },
        new() { Id = "Location", Title = "Standort", Order = 8 }
    };

    protected override async Task OnInitializedAsync() {
        _isLoading = true;
        try {
            var taskLife = SafeGetAsync("api/settings/dynamic/asset-lifecycle", new Dictionary<string, List<string>>());
            var taskTypes = SafeGetAsync("api/assets/types", new List<AssetType>());
            var taskLocs = SafeGetAsync("api/locations", new List<Location>());
            var taskAssets = SafeGetAsync("api/assets", new List<Asset>());

            await Task.WhenAll(taskLife, taskTypes, taskLocs, taskAssets);

            var lifecycleDict = await taskLife;
            if (lifecycleDict != null && lifecycleDict.Any()) {
                _lifecycleStatuses = lifecycleDict.Values.SelectMany(v => v).Distinct().ToList();
            }

            _assetTypes = await taskTypes;
            _locations = await taskLocs;
            _assets = await taskAssets;

            UpdateCaches();
            ApplyFilter(); // Initiales Setzen der Liste
        } catch { Snackbar.Add("Fehler beim Laden der Assets.", Severity.Error); }
        finally { _isLoading = false; }
    }

    private async Task<T> SafeGetAsync<T>(string url, T defaultVal)
    {
        try {
            var res = await Http.GetFromJsonAsync<T>(url);
            return res != null ? res : defaultVal;
        } catch {
            return defaultVal;
        }
    }

    private void UpdateCaches()
    {
        _locationsByParent = _locations.ToLookup(l => l.ParentLocationId);
        _categoriesByParent = _assetTypes.ToLookup(t => t.ParentAssetTypeId);
        _typeDict = _assetTypes.ToDictionary(t => t.Id);
        _locDict = _locations.ToDictionary(l => l.Id);

        _locationPathCache.Clear();
        foreach (var loc in _locations)
        {
            var path = loc.Name;
            var parentId = loc.ParentLocationId;
            int depth = 0;
            while (parentId.HasValue && depth < 10)
            {
                if (_locDict.TryGetValue(parentId.Value, out var parent)) {
                    path = parent.Name + " > " + path;
                    parentId = parent.ParentLocationId;
                    depth++;
                } else break;
            }
            _locationPathCache[loc.Id] = path;
        }

        _categoryPathCache.Clear();
        foreach (var cat in _assetTypes)
        {
            var path = cat.Name;
            var parentId = cat.ParentAssetTypeId;
            int depth = 0;
            while (parentId.HasValue && depth < 10)
            {
                if (_typeDict.TryGetValue(parentId.Value, out var parent)) {
                    path = parent.Name + " > " + path;
                    parentId = parent.ParentAssetTypeId;
                    depth++;
                } else break;
            }
            _categoryPathCache[cat.Id] = path;
        }
    }

    // --- FILTER & EVENT HANDLER (Entkoppelt vom permanenten Render-Loop!) ---
    private void OnStatusFilterChanged(string? status)
    {
        _filterStatus = status;
        ApplyFilter();
    }

    private void OnSearchChanged(string text)
    {
        _searchString = text;
        ApplyFilter();
    }

    private void OnCategorySelected(Guid? selectedId) 
    { 
        _filterTypeId = selectedId; 
        ApplyFilter();
    }

    private void OnLocationSelected(Guid? selectedId) 
    { 
        _filterLocationId = selectedId; 
        ApplyFilter();
    }

    private HashSet<Guid> GetValidTypeIds(Guid rootId)
    {
        var result = new HashSet<Guid>();
        var stack = new Stack<Guid>();
        stack.Push(rootId);
        
        while (stack.Count > 0)
        {
            var current = stack.Pop();
            result.Add(current);
            foreach (var child in _categoriesByParent[current])
            {
                stack.Push(child.Id);
            }
        }
        return result;
    }

    private HashSet<Guid> GetValidLocationIds(Guid rootId)
    {
        var result = new HashSet<Guid>();
        var stack = new Stack<Guid>();
        stack.Push(rootId);
        
        while (stack.Count > 0)
        {
            var current = stack.Pop();
            result.Add(current);
            foreach (var child in _locationsByParent[current])
            {
                stack.Push(child.Id);
            }
        }
        return result;
    }

    // Explizite Zuweisung an _filteredAssets (Löst das O(N^2) Hänger-Problem auf UI-Ebene)
    private void ApplyFilter()
    {
        var validTypes = _filterTypeId.HasValue ? GetValidTypeIds(_filterTypeId.Value) : null;
        var validLocs = _filterLocationId.HasValue ? GetValidLocationIds(_filterLocationId.Value) : null;

        _filteredAssets = _assets.Where(a => 
            (string.IsNullOrWhiteSpace(_filterStatus) || a.LifecycleStatus == _filterStatus) &&
            (!_filterTypeId.HasValue || validTypes!.Contains(a.AssetTypeId)) &&
            (!_filterLocationId.HasValue || validLocs!.Contains(a.LocationId.GetValueOrDefault())) &&
            (string.IsNullOrWhiteSpace(_searchString) || 
             (a.Name?.Contains(_searchString, StringComparison.OrdinalIgnoreCase) == true) || 
             (a.AssetTag?.Contains(_searchString, StringComparison.OrdinalIgnoreCase) == true) ||
             (a.SerialNumber?.Contains(_searchString, StringComparison.OrdinalIgnoreCase) == true))
        ).ToList();
    }

    // --- TREE VIEWS ---
    private RenderFragment RenderCategoryTree(IEnumerable<AssetType> nodes) => __builder =>
    {
        foreach (var node in nodes)
        {
            var children = _categoriesByParent[node.Id].OrderBy(t => t.Name).ToList();
            bool isRoot = node.ParentAssetTypeId == null;
            
            <MudTreeViewItem T="Guid?" Value="@(new Guid?(node.Id))" Text="@node.Name" Expanded="@isRoot" Icon="@GetDynamicIcon(node.IconKey)">
                @if (children.Any()) { @RenderCategoryTree(children) }
            </MudTreeViewItem>
        }
    };

    private RenderFragment RenderLocationTree(IEnumerable<Location> nodes) => __builder =>
    {
        foreach (var node in nodes)
        {
            var children = _locationsByParent[node.Id].OrderBy(l => l.Name).ToList();
            bool isRoot = node.ParentLocationId == null;
            
            <MudTreeViewItem T="Guid?" Value="@(new Guid?(node.Id))" Text="@node.Name" Expanded="@isRoot" Icon="@(children.Any() ? Icons.Material.Filled.Folder : Icons.Material.Filled.LocationOn)">
                @if (children.Any()) { @RenderLocationTree(children) }
            </MudTreeViewItem>
        }
    };

    // --- PFAD GENERIERUNG (O(1) Dictionary Lookup) ---
    private string GetCategoryPath(Guid? typeId) {
        if (typeId.HasValue && _categoryPathCache.TryGetValue(typeId.Value, out var path)) return path;
        return "---";
    }

    private string GetLocationPath(Guid? locationId) {
        if (locationId.HasValue && _locationPathCache.TryGetValue(locationId.Value, out var path)) return path;
        return "---";
    }

    protected override async Task OnAfterRenderAsync(bool firstRender) {
        if (firstRender) {
            string jsCode = "window.downloadFileFromBase64 = function(fileName, contentType, base64) { var link = document.createElement('a'); link.download = fileName; link.href = 'data:' + contentType + ';base64,' + base64; document.body.appendChild(link); link.click(); document.body.removeChild(link); };";
            await JSRuntime.InvokeVoidAsync("eval", jsCode);
        }
    }

    private void OnRowClicked(DataGridRowClickEventArgs<Asset> args) => Nav.NavigateTo($"/assets/{args.Item.Id}");
    
    private void MoveColUp(ColumnDef col) {
        if (col.Order > 1) { var prev = _columns.First(c => c.Order == col.Order - 1); prev.Order++; col.Order--; StateHasChanged(); }
    }
    private void MoveColDown(ColumnDef col) {
        if (col.Order < _columns.Count) { var next = _columns.First(c => c.Order == col.Order + 1); next.Order--; col.Order++; StateHasChanged(); }
    }

    private async Task ExportCsv() {
        try {
            var sb = new StringBuilder();
            sb.AppendLine("Status;AssetTag;Name;Kategorie;Hersteller;Zuweisung;Standort;Seriennummer");
            foreach(var a in _filteredAssets) {
                string owner = a.Owner != null ? $"{a.Owner.FirstName} {a.Owner.LastName}" : "";
                sb.AppendLine($"{a.LifecycleStatus};{a.AssetTag};{a.Name};{GetCategoryPath(a.AssetTypeId)};{a.Manufacturer?.Name};{owner};{GetLocationPath(a.LocationId)};{a.SerialNumber}");
            }
            var base64 = Convert.ToBase64String(Encoding.UTF8.GetBytes(sb.ToString()));
            await JSRuntime.InvokeVoidAsync("downloadFileFromBase64", $"InfraDesk_Assets_{DateTime.Now:yyyyMMdd}.csv", "text/csv", base64);
            Snackbar.Add("Export erfolgreich!", Severity.Success);
        } catch (Exception ex) { Snackbar.Add($"Fehler: {ex.Message}", Severity.Error); }
    }

    private async Task ImportCsv(InputFileChangeEventArgs e) {
        if (e.File == null) return;
        Snackbar.Add("Import-Prozess gestartet...", Severity.Info);
    }

    private Color GetStatusColor(string? status) => status switch {
        "Produktiv" => Color.Success,
        "Auf Lager" => Color.Info,
        "In Reparatur" => Color.Warning,
        "Ausgemustert" => Color.Error,
        _ => Color.Default
    };

    private string GetDynamicIcon(string? iconName) {
        if (string.IsNullOrWhiteSpace(iconName)) return Icons.Material.Filled.Computer;
        if (_iconCache.TryGetValue(iconName, out var cachedIcon)) return cachedIcon;
        
        try {
            var field = typeof(Icons.Material.Filled).GetField(iconName);
            var icon = field?.GetValue(null)?.ToString() ?? Icons.Material.Filled.Computer;
            _iconCache[iconName] = icon;
            return icon;
        } catch { return Icons.Material.Filled.Computer; }
    }
}