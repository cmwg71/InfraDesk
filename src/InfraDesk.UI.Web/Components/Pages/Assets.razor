@* Dateipfad: src/InfraDesk.UI.Web/Components/Pages/Assets.razor *@
@page "/assets"
@using Microsoft.AspNetCore.Components.Forms
@using InfraDesk.Core.Entities
@using MudBlazor
@using InfraDesk.UI.Web.Services
@using System.Text
@inject HttpClient Http
@inject NavigationManager Nav
@inject ThemeService ThemeService
@inject ISnackbar Snackbar
@inject IJSRuntime JSRuntime

<PageTitle>InfraDesk - Asset-CMDB</PageTitle>

<style>
    .pdq-container { background-color: #fff; height: calc(100vh - 100px); display: flex; flex-direction: row; border-top: none; }
    .pdq-sidebar { width: 240px; border-right: 1px solid #ccc; background-color: #f0f0f0; overflow-y: auto; flex-shrink: 0; }
    .pdq-content { flex-grow: 1; overflow-y: auto; background-color: #fff; padding: 12px 20px; }
    .pdq-toolbar { height: 42px; background-color: #eee; border-bottom: 1px solid #ccc; display: flex; align-items: center; padding: 0 12px; }
    .sidebar-active { background-color: #fff !important; font-weight: bold; border-left: 4px solid var(--mud-palette-primary); color: var(--mud-palette-primary) !important; }
    .pdq-section-header { background-color: #e0e0e0; padding: 4px 12px; font-weight: 800; font-size: 0.75rem; text-transform: uppercase; border-bottom: 1px solid #ccc; border-top: 1px solid #ccc; color: #333; margin-bottom: 8px; margin-top: 16px; }
    .pdq-section-header:first-child { margin-top: 0; border-top: none; }
    .import-btn-wrapper { margin: 0; padding: 0; display: flex; align-items: center; }
</style>

<div class="pdq-toolbar">
    <MudIcon Icon="@Icons.Material.Filled.Dns" Color="Color.Primary" Size="Size.Small" Class="mr-2" />
    <MudText Typo="Typo.body2" Class="font-weight-bold">Asset-CMDB: @(_activeFilter ?? "Alle Assets")</MudText>
    <MudSpacer />
    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" Size="Size.Small" Style="text-transform:none" OnClick="@(() => Nav.NavigateTo("/assets/create"))">Neues Asset</MudButton>
</div>

<div class="pdq-container">
    <div class="pdq-sidebar">
        <MudNavMenu Margin="Margin.Dense" Rounded="false">
            <div class="pdq-section-header">Ansichten</div>
            <MudNavLink OnClick="@(() => SetFilter(null))" Class="@(string.IsNullOrEmpty(_activeFilter) ? "sidebar-active" : "")" Icon="@Icons.Material.Filled.List">Alle Assets</MudNavLink>
            <MudNavLink OnClick="@(() => SetFilter("Produktiv"))" Class="@(_activeFilter == "Produktiv" ? "sidebar-active" : "")" Icon="@Icons.Material.Filled.CheckCircle">Produktiv</MudNavLink>
            <MudNavLink OnClick="@(() => SetFilter("Auf Lager"))" Class="@(_activeFilter == "Auf Lager" ? "sidebar-active" : "")" Icon="@Icons.Material.Filled.Inventory">Auf Lager</MudNavLink>
            <MudNavLink OnClick="@(() => SetFilter("Ausgemustert"))" Class="@(_activeFilter == "Ausgemustert" ? "sidebar-active" : "")" Icon="@Icons.Material.Filled.Delete">Ausgemustert</MudNavLink>
        </MudNavMenu>
    </div>

    <div class="pdq-content">
        @if (_assets == null) 
        {
            <div class="d-flex justify-center align-center" style="height: 200px;">
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
            </div>
        } 
        else 
        {
            <MudDataGrid T="Asset" Items="@FilteredAssets" Hover="true" RowClick="@OnRowClicked" Filterable="true" QuickFilter="@QuickFilter" Dense="true" Elevation="0" Bordered="true">
                <ToolBarContent>
                    <MudSpacer />
                    
                    <MudTextField @bind-Value="_searchString" Placeholder="Suche in allen Daten (Name, Standort, JSON-Details)..." Adornment="Adornment.Start" 
                                  AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Small" Immediate="true" Margin="Margin.Dense" Style="max-width: 450px;" Class="mr-4">
                    </MudTextField>

                    <MudTooltip Text="Als CSV exportieren">
                        <MudIconButton Icon="@Icons.Material.Filled.FileDownload" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Default" OnClick="ExportCsv" Class="mr-2" />
                    </MudTooltip>
                    
                    <div class="import-btn-wrapper">
                        <!-- Nativer Blazor InputFile für zuverlässigen Datei-Upload -->
                        <MudTooltip Text="Aus CSV importieren">
                            <MudIconButton HtmlTag="label" for="import-csv-assets" Icon="@Icons.Material.Filled.FileUpload" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Default" />
                        </MudTooltip>
                        <InputFile id="import-csv-assets" OnChange="@ImportCsv" accept=".csv" style="display: none;" />
                    </div>
                </ToolBarContent>
                <Columns>
                    <TemplateColumn Title="Typ" HeaderStyle="width: 40px;" Sortable="false" Filterable="false">
                        <CellTemplate>
                            <MudIcon Icon="@Icons.Material.Filled.Computer" Size="Size.Small" Color="Color.Primary" />
                        </CellTemplate>
                    </TemplateColumn>
                    <PropertyColumn Property="@(x => x.AssetTag)" Title="Asset-Tag" />
                    <PropertyColumn Property="@(x => x.Name)" Title="Name" />
                    <PropertyColumn Property="@(x => x.AssetType != null ? x.AssetType.Name : string.Empty)" Title="Kategorie" />
                    <PropertyColumn Property="@(x => x.SerialNumber)" Title="Seriennummer" />
                    <PropertyColumn Property="@(x => x.Location != null ? x.Location.Name : string.Empty)" Title="Standort" />
                    <PropertyColumn Property="@(x => x.LifecycleStatus)" Title="Status">
                        <CellTemplate>
                            <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Outlined">@context.Item.LifecycleStatus</MudChip>
                        </CellTemplate>
                    </PropertyColumn>
                </Columns>
                <PagerContent>
                    <MudDataGridPager T="Asset" PageSizeOptions="@(new int[] { 50, 100, 250, 500 })" />
                </PagerContent>
            </MudDataGrid>
        }
    </div>
</div>

@code {
    private List<Asset>? _assets;
    private string _searchString = "";
    private string? _activeFilter = null;

    private IEnumerable<Asset> FilteredAssets
    {
        get
        {
            if (_assets == null) return new List<Asset>();
            return _assets.Where(x => string.IsNullOrEmpty(_activeFilter) || x.LifecycleStatus == _activeFilter);
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            string jsCode = "window.downloadFileFromBase64 = function(fileName, contentType, base64) { var link = document.createElement('a'); link.download = fileName; link.href = 'data:' + contentType + ';base64,' + base64; document.body.appendChild(link); link.click(); document.body.removeChild(link); };";
            await JSRuntime.InvokeVoidAsync("eval", jsCode);
        }
    }

    private async Task LoadDataAsync()
    {
        try { 
            _assets = await Http.GetFromJsonAsync<List<Asset>>("api/assets"); 
        }
        catch { 
            _assets = new List<Asset>(); 
        }
    }

    private void SetFilter(string? filter) => _activeFilter = filter;

    private void OnRowClicked(DataGridRowClickEventArgs<Asset> args)
    {
        Nav.NavigateTo($"/assets/{args.Item.Id}");
    }

    // ERWEITERT: Sucht nun in allen relevanten Feldern inkl. dynamischen JSON-Daten
    private Func<Asset, bool> QuickFilter => x => 
        string.IsNullOrWhiteSpace(_searchString) || 
        (x.Name?.Contains(_searchString, StringComparison.OrdinalIgnoreCase) == true) || 
        (x.AssetTag?.Contains(_searchString, StringComparison.OrdinalIgnoreCase) == true) ||
        (x.SerialNumber?.Contains(_searchString, StringComparison.OrdinalIgnoreCase) == true) ||
        (x.LifecycleStatus?.Contains(_searchString, StringComparison.OrdinalIgnoreCase) == true) ||
        (x.AssetType?.Name?.Contains(_searchString, StringComparison.OrdinalIgnoreCase) == true) ||
        (x.Location?.Name?.Contains(_searchString, StringComparison.OrdinalIgnoreCase) == true) ||
        (x.DynamicDataJson?.Contains(_searchString, StringComparison.OrdinalIgnoreCase) == true);

    private async Task ExportCsv()
    {
        try
        {
            var sb = new StringBuilder();
            sb.AppendLine("AssetTag;Name;Kategorie;Seriennummer;Standort;Status");
            
            foreach(var a in FilteredAssets) 
            {
                var tag = EscapeCsv(a.AssetTag);
                var name = EscapeCsv(a.Name);
                var cat = EscapeCsv(a.AssetType?.Name);
                var sn = EscapeCsv(a.SerialNumber);
                var loc = EscapeCsv(a.Location?.Name);
                var stat = EscapeCsv(a.LifecycleStatus);
                
                sb.AppendLine($"{tag};{name};{cat};{sn};{loc};{stat}");
            }
            
            var bytes = Encoding.UTF8.GetBytes(sb.ToString());
            var base64 = Convert.ToBase64String(bytes);
            
            await JSRuntime.InvokeVoidAsync("downloadFileFromBase64", $"InfraDesk_Assets_{DateTime.Now:yyyyMMdd}.csv", "text/csv", base64);
            
            Snackbar.Add("Export erfolgreich abgeschlossen!");
        }
        catch(Exception ex)
        {
            Snackbar.Add($"Fehler beim Export: {ex.Message}");
        }
    }

    private string EscapeCsv(string? val) 
    {
        if (string.IsNullOrEmpty(val)) return "";
        if (val.Contains(";") || val.Contains("\"") || val.Contains("\n"))
        {
            return "\"" + val.Replace("\"", "\"\"") + "\"";
        }
        return val;
    }

    private async Task ImportCsv(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file == null) return;

        try 
        {
            using var stream = file.OpenReadStream(10 * 1024 * 1024);
            using var reader = new System.IO.StreamReader(stream, Encoding.UTF8);
            var content = await reader.ReadToEndAsync();
            var lines = content.Split(new char[] { '\r', '\n' }, StringSplitOptions.RemoveEmptyEntries);
            
            int importedCount = 0;
            
            for (int i = 1; i < lines.Length; i++)
            {
                var parts = lines[i].Split(';');
                if (parts.Length >= 2) 
                {
                    var asset = new Asset 
                    {
                        AssetTag = parts[0],
                        Name = parts[1],
                        SerialNumber = parts.Length >= 4 ? parts[3] : "",
                        LifecycleStatus = parts.Length >= 6 && !string.IsNullOrWhiteSpace(parts[5]) ? parts[5] : "Auf Lager",
                        DynamicDataJson = "{}" 
                    };
                    
                    var res = await Http.PostAsJsonAsync("api/assets", asset);
                    if (res.IsSuccessStatusCode) importedCount++;
                }
            }
            
            Snackbar.Add($"{importedCount} Assets erfolgreich importiert!");
            await LoadDataAsync(); 
        } 
        catch (Exception ex) 
        {
            Snackbar.Add($"Fehler beim Importieren: {ex.Message}");
        }
    }
}