@* Dateipfad: src/InfraDesk.UI.Web/Components/Pages/AssetDetails.razor *@
@page "/assets/{Id:guid}"
@using InfraDesk.Core.Entities
@using MudBlazor
@using System.Text.Json
@using InfraDesk.UI.Web.Services
@inject HttpClient Http
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject ThemeService ThemeService

<style>
    .pdq-container { background-color: #fff; height: calc(100vh - 110px); display: flex; flex-direction: row; }
    .pdq-sidebar { width: 240px; border-right: 1px solid #ccc; background-color: #f0f0f0; overflow-y: auto; flex-shrink: 0; }
    .pdq-content { flex-grow: 1; overflow-y: auto; background-color: #fff; padding: 4px; }
    .pdq-grid { display: grid; grid-template-columns: 210px 1fr; border-top: 1px solid #e8e8e8; font-size: 0.8rem; }
    .pdq-label { background-color: #f6f6f6; padding: 4px 10px; font-weight: 600; color: #555; border-right: 1px solid #e8e8e8; border-bottom: 1px solid #e8e8e8; white-space: nowrap; }
    .pdq-value { background-color: #fff; padding: 4px 10px; border-bottom: 1px solid #e8e8e8; color: #000; display: flex; align-items: center; min-height: 26px; }
    .pdq-section-header { background-color: #e0e0e0; padding: 3px 12px; font-weight: 800; font-size: 0.7rem; text-transform: uppercase; border-bottom: 1px solid #ccc; color: #333; margin-top: 12px; }
    .pdq-section-header:first-child { margin-top: 0; }
    .sidebar-active { background-color: #fff !important; font-weight: bold; border-left: 4px solid var(--mud-palette-primary); color: var(--mud-palette-primary) !important; }
    .pdq-toolbar { height: 42px; background-color: #eee; border-bottom: 1px solid #ccc; display: flex; align-items: center; padding: 0 8px; }
</style>

@if (_isLoading) {
    <div class="d-flex justify-center align-center" style="height: 100vh;"><MudProgressCircular Color="Color.Primary" Indeterminate="true" /></div>
} else if (_asset != null) {
    <div class="pdq-toolbar">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" OnClick="@(() => Nav.NavigateTo("/assets"))" Size="Size.Small" Class="mr-2" />
        <MudIcon Icon="@GetIcon(_asset.AssetType?.IconKey)" Color="Color.Primary" Size="Size.Small" Class="mr-2" />
        <MudText Typo="Typo.body2" Class="font-weight-bold">@_asset.Name (@(_asset.AssetType?.Name))</MudText>
        <MudSpacer />
        <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Filled" Class="mr-2">@_asset.LifecycleStatus</MudChip>
        <MudButton StartIcon="@Icons.Material.Filled.Edit" OnClick="@(() => _isEditMode = true)" Variant="Variant.Outlined" Size="Size.Small" Color="Color.Primary" Style="text-transform:none">Bearbeiten</MudButton>
    </div>

    <div class="pdq-container">
        <div class="pdq-sidebar">
            <MudNavMenu Margin="Margin.Dense" Rounded="false">
                <div class="pdq-section-header">Informationen</div>
                <MudNavLink OnClick="@(() => _activeTab = "General")" Class="@(_activeTab == "General" ? "sidebar-active" : "")" Icon="@Icons.Material.Filled.Info">Übersicht</MudNavLink>
                
                @if (IsCategory("Hardware") || IsCategory("Datacenter") || IsCategory("Storage")) {
                    <MudNavLink OnClick="@(() => _activeTab = "Hardware")" Class="@(_activeTab == "Hardware" ? "sidebar-active" : "")" Icon="@Icons.Material.Filled.Memory">Technische Daten</MudNavLink>
                }
                @if (IsCategory("Network")) {
                    <MudNavLink OnClick="@(() => _activeTab = "Network")" Class="@(_activeTab == "Network" ? "sidebar-active" : "")" Icon="@Icons.Material.Filled.SettingsInputComponent">Netzwerk & IP</MudNavLink>
                }
                
                @if (!IsCategory("Service") && !IsCategory("License") && !IsCategory("Geo") && !IsCategory("Org")) {
                    <MudNavLink OnClick="@(() => _activeTab = "Software")" Class="@(_activeTab == "Software" ? "sidebar-active" : "")" Icon="@Icons.Material.Filled.Code">Logische Zuweisungen</MudNavLink>
                }

                <MudNavLink OnClick="@(() => _activeTab = "CustomFields")" Class="@(_activeTab == "CustomFields" ? "sidebar-active" : "")" Icon="@Icons.Material.Filled.DisplaySettings">Spezifikationen (Vorlage)</MudNavLink>

                <div class="pdq-section-header">Management</div>
                <MudNavLink OnClick="@(() => _activeTab = "Links")" Class="@(_activeTab == "Links" ? "sidebar-active" : "")" Icon="@Icons.Material.Filled.AccountTree">Abhängigkeiten (Links)</MudNavLink>
                <MudNavLink OnClick="@(() => _activeTab = "History")" Class="@(_activeTab == "History" ? "sidebar-active" : "")" Icon="@Icons.Material.Filled.History">Audit-Log</MudNavLink>
            </MudNavMenu>
        </div>

        <div class="pdq-content">
            @if (_activeTab == "General") {
                <MudGrid Spacing="1">
                    <MudItem xs="12" lg="6">
                        <div class="pdq-section-header">Stammdaten</div>
                        <div class="pdq-grid"><div class="pdq-label">Asset-Tag</div><div class="pdq-value">@(_asset.AssetTag ?? "---")</div></div>
                        <div class="pdq-grid"><div class="pdq-label">Seriennummer (S/N)</div><div class="pdq-value">@(_asset.SerialNumber ?? "---")</div></div>
                        <div class="pdq-grid"><div class="pdq-label">Kategorie</div><div class="pdq-value">@(GetCategoryPath(_asset.AssetTypeId))</div></div>

                        <div class="pdq-section-header mt-4">System Metadaten</div>
                        <div class="pdq-grid">
                            <div class="pdq-label">Letzter Scan</div>
                            <div class="pdq-value">@FormatDynDate("General", "LastScan")</div>
                        </div>

                        <div class="pdq-section-header mt-4">Lokations-Hierarchie</div>
                        <div class="pdq-grid"><div class="pdq-label">Standort / Gebäude</div><div class="pdq-value">@(GetLocationPath(_asset.LocationId))</div></div>
                        <div class="pdq-grid"><div class="pdq-label">Raum-Info</div><div class="pdq-value">@(_asset.Location?.RoomNumber ?? "---")</div></div>
                    </MudItem>

                    <MudItem xs="12" lg="6">
                        <div class="pdq-section-header">Organisation & Rollen</div>
                        <div class="pdq-grid"><div class="pdq-label">Zugeordneter Nutzer</div><div class="pdq-value">@(_asset.Owner != null ? $"{_asset.Owner.FirstName} {_asset.Owner.LastName}" : "---")</div></div>
                        <div class="pdq-grid"><div class="pdq-label">Abteilung / Team</div><div class="pdq-value">@(_asset.Owner?.Department ?? "---")</div></div>

                        <div class="pdq-section-header mt-4">Externe Partner & Lieferanten</div>
                        <div class="pdq-grid"><div class="pdq-label">Hersteller</div><div class="pdq-value">@(_asset.Manufacturer?.Name ?? "---")</div></div>
                    </MudItem>
                </MudGrid>
            }
            else if (_activeTab == "Hardware") {
                <MudGrid Spacing="1">
                    <MudItem xs="12" lg="6">
                        <div class="pdq-section-header">Physische Konfiguration</div>
                        <div class="pdq-grid"><div class="pdq-label">Prozessor</div><div class="pdq-value">@GetVal("Hardware", "CPU")</div></div>
                        <div class="pdq-grid"><div class="pdq-label">Arbeitsspeicher</div><div class="pdq-value">@GetVal("Hardware", "RAM")</div></div>
                    </MudItem>
                    @if (IsCategory("Storage")) {
                        <MudItem xs="12" lg="6">
                            <div class="pdq-section-header">Storage</div>
                            <div class="pdq-grid"><div class="pdq-label">Kapazität</div><div class="pdq-value">@GetVal("Storage", "Capacity")</div></div>
                        </MudItem>
                    }
                </MudGrid>
            }
            else if (_activeTab == "Network") {
                <div class="pdq-section-header">Netzwerk-Interfaces (IPv4/v6)</div>
                <MudDataGrid T="IpAddress" Items="@_asset.NetworkInterfaces" Dense="true" Bordered="true" Elevation="0">
                    <Columns>
                        <PropertyColumn Property="x => x.Address" Title="IP Adresse" />
                        <PropertyColumn Property="x => x.MacAddress" Title="MAC" />
                        <PropertyColumn Property="@(x => x.Subnet != null ? x.Subnet.Name : "N/A")" Title="Netz / VLAN" />
                    </Columns>
                </MudDataGrid>
            }
            else if (_activeTab == "CustomFields") {
                <div class="pdq-section-header">Dynamische Spezifikationen (Gemäß Vorlage)</div>
                <MudGrid Spacing="1">
                    <MudItem xs="12">
                        @foreach (var field in GetCustomFields()) {
                            <div class="pdq-grid"><div class="pdq-label">@field.Key</div><div class="pdq-value">@field.Value</div></div>
                        }
                        @if (!GetCustomFields().Any()) {
                            <div class="pa-4 text-muted">Keine spezifischen Felder in der Vorlage ausgefüllt.</div>
                        }
                    </MudItem>
                </MudGrid>
            }
            else if (_activeTab == "Links") {
                <div class="pdq-section-header">CMDB Abhängigkeiten (Impact-Graph)</div>
                @if (_assetLinks != null && _assetLinks.Any()) {
                    <MudDataGrid T="AssetLinkDto" Items="@_assetLinks" Dense="true" Bordered="true" Elevation="0">
                        <Columns>
                            <PropertyColumn Property="x => x.Direction" Title="Richtung" />
                            <PropertyColumn Property="x => x.Type" Title="Art der Beziehung" />
                            <TemplateColumn Title="Verknüpftes Asset">
                                <CellTemplate>
                                    <MudLink Href="@($"/assets/{context.Item.TargetId}")" Typo="Typo.body2" Class="font-weight-bold">
                                        @context.Item.TargetName
                                    </MudLink>
                                </CellTemplate>
                            </TemplateColumn>
                        </Columns>
                    </MudDataGrid>
                } else {
                    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mt-4">Dieses Asset hat noch keine Abhängigkeiten oder Verknüpfungen.</MudAlert>
                }
            }
        </div>
    </div>
}

@code {
    [Parameter] public Guid Id { get; set; }
    private Asset? _asset;
    private List<AssetLinkDto> _assetLinks = new();
    private List<AssetType> _assetTypes = new();
    private List<Location> _locations = new();
    
    private string _activeTab = "General";
    private bool _isLoading = true;
    private bool _isEditMode = false;

    public class AssetLinkDto {
        public Guid Id { get; set; }
        public string Type { get; set; } = "";
        public Guid TargetId { get; set; }
        public string TargetName { get; set; } = "";
        public string Direction { get; set; } = "";
    }

    protected override async Task OnInitializedAsync() {
        try { 
            _assetTypes = await Http.GetFromJsonAsync<List<AssetType>>("api/assets/types") ?? new();
            _locations = await Http.GetFromJsonAsync<List<Location>>("api/locations") ?? new();
            _asset = await Http.GetFromJsonAsync<Asset>($"api/assets/{Id}"); 
            try {
                _assetLinks = await Http.GetFromJsonAsync<List<AssetLinkDto>>($"api/assets/{Id}/links") ?? new();
            } catch { }
        }
        catch { Snackbar.Add("Fehler beim Laden", Severity.Error); }
        finally { _isLoading = false; }
    }

    private string GetLocationPath(Guid? locationId) {
        if (locationId == null) return "---";
        var loc = _locations.FirstOrDefault(l => l.Id == locationId);
        if (loc == null) return "---";
        var path = loc.Name;
        var parentId = loc.ParentLocationId;
        int depth = 0;
        while (parentId.HasValue && depth < 10) {
            var parent = _locations.FirstOrDefault(l => l.Id == parentId);
            if (parent != null) { path = parent.Name + " > " + path; parentId = parent.ParentLocationId; depth++; }
            else break;
        }
        return path;
    }

    private string GetCategoryPath(Guid? typeId) {
        if (typeId == null) return "---";
        var type = _assetTypes.FirstOrDefault(t => t.Id == typeId);
        if (type == null) return "---";
        var path = type.Name;
        var parentId = type.ParentAssetTypeId;
        int depth = 0;
        while (parentId.HasValue && depth < 10) {
            var parent = _assetTypes.FirstOrDefault(l => l.Id == parentId);
            if (parent != null) { path = parent.Name + " > " + path; parentId = parent.ParentAssetTypeId; depth++; }
            else break;
        }
        return path;
    }

    private string GetVal(string section, string prop) {
        if (string.IsNullOrEmpty(_asset?.DynamicDataJson)) return "---";
        try {
            using var doc = JsonDocument.Parse(_asset.DynamicDataJson);
            if (doc.RootElement.TryGetProperty(section, out var s) && s.TryGetProperty(prop, out var p)) return p.ToString();
            if (doc.RootElement.TryGetProperty("CustomFields", out var cf) && cf.TryGetProperty(prop, out var cfp)) return cfp.ToString();
            return "---";
        } catch { return "---"; }
    }

    private Dictionary<string, string> GetCustomFields() {
        var dict = new Dictionary<string, string>();
        if (string.IsNullOrEmpty(_asset?.DynamicDataJson)) return dict;
        try {
            using var doc = JsonDocument.Parse(_asset.DynamicDataJson);
            if (doc.RootElement.TryGetProperty("CustomFields", out var cf)) {
                foreach (var prop in cf.EnumerateObject()) {
                    dict.Add(prop.Name, prop.Value.ToString() ?? "");
                }
            }
        } catch { }
        return dict;
    }

    private string FormatDynDate(string section, string prop) {
        var rawVal = GetVal(section, prop);
        if (rawVal == "---") return rawVal;
        if (DateTime.TryParse(rawVal, out var dt)) return ThemeService.FormatDate(dt);
        return rawVal;
    }

    private bool IsCategory(string cat) {
        var path = GetCategoryPath(_asset?.AssetTypeId);
        return cat switch {
            "Hardware" => new[]{"Server", "Laptop", "Computer", "Tablet", "Hardware", "Smartphone", "Drucker", "AV", "Video"}.Any(x => path.Contains(x)),
            "Network" => new[]{"Switch", "Router", "Firewall", "WLAN", "Telefon", "Funk", "Netz"}.Any(x => path.Contains(x)),
            "Storage" => path.Contains("Storage") || path.Contains("Speicher"),
            "Cloud" => path.Contains("Virtual") || path.Contains("Software") || path.Contains("Dienste"),
            "Datacenter" => new[]{"USV", "PDU", "Kühlung", "Klima", "Überwachung", "Sicherheit"}.Any(x => path.Contains(x)),
            _ => false
        };
    }

    private string GetIcon(string? iconName) {
        if (string.IsNullOrWhiteSpace(iconName)) return Icons.Material.Filled.Computer;
        try {
            var field = typeof(Icons.Material.Filled).GetField(iconName);
            if (field != null) return field.GetValue(null)?.ToString() ?? Icons.Material.Filled.Computer;
        } catch {}
        return Icons.Material.Filled.Computer;
    }
}