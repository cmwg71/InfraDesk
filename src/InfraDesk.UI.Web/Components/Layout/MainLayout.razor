@* Dateipfad: src/InfraDesk.UI.Web/Components/Layout/MainLayout.razor *@
@namespace InfraDesk.UI.Web.Components.Layout
@inherits LayoutComponentBase
@using MudBlazor
@using InfraDesk.UI.Web.Services
@using Microsoft.AspNetCore.Components.Web
@using System.Security.Claims
@inject ThemeService ThemeService
@inject NavigationManager Nav
@inject InfraDeskAuthStateProvider AuthStateProvider
@implements IDisposable

<MudThemeProvider @bind-IsDarkMode="@_isDarkMode" Theme="_theme" />
<MudDialogProvider />
<MudSnackbarProvider />
<MudPopoverProvider />

<AuthorizeView>
    <Authorized>
        <MudLayout>
            @* OBERE TITELLEISTE: Dunkelgrau (#333333) mit Logo links und Suche rechts *@
            <MudAppBar Elevation="1" Style="@AppbarStyle" Fixed="true">
                <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="@DrawerToggle" />
                
                @* Logo Links *@
                <img src="InfraDesk_Logo.png" alt="InfraDesk Logo" class="header-logo ml-2" />
                
                <MudSpacer />
                
                @* Globale Suche Rechts *@
                <div class="header-search-container">
                    <MudTextField T="string"
                                  @bind-Value="_globalSearchQuery" 
                                  Placeholder="Globale Suche (Enter)..." 
                                  Variant="Variant.Outlined" 
                                  Margin="Margin.Dense" 
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Search"
                                  AdornmentColor="Color.Inherit"
                                  OnKeyDown="@HandleSearch"
                                  Immediate="true"
                                  Class="header-search-input" />
                </div>

                <MudIconButton Icon="@(_isDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)" Color="Color.Inherit" OnClick="@ToggleDarkMode" Class="ml-2" />
            </MudAppBar>

            <MudDrawer @bind-Open="_drawerOpen" Elevation="1" ClipMode="DrawerClipMode.Always" Style="@DrawerStyle" Width="300px">
                <div class="sidebar-wrapper">
                    
                    @* OBERER BEREICH: Navigation *@
                    <div class="sidebar-content">
                        <MudNavMenu Margin="Margin.Dense" Class="mt-4">
                            <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Dashboard">Dashboard</MudNavLink>
                            <MudNavGroup Title="Support" Icon="@Icons.Material.Filled.HeadsetMic" Expanded="true">
                                <MudNavLink Href="tickets" Icon="@Icons.Material.Filled.ConfirmationNumber">Ticket-Queue</MudNavLink>
                            </MudNavGroup>
                            <MudNavGroup Title="Infrastruktur" Icon="@Icons.Material.Filled.Computer" Expanded="true">
                                <MudNavLink Href="assets" Icon="@Icons.Material.Filled.Dns">Asset-CMDB</MudNavLink>
                                <MudNavLink Href="ipam" Icon="@Icons.Material.Filled.Router">IPAM / Netzwerke</MudNavLink>
                            </MudNavGroup>
                        </MudNavMenu>
                    </div>

                    @* UNTERER BEREICH: Fixierter Footer mit Einstellungen & Status *@
                    <div class="sidebar-footer">
                        <MudDivider Class="mb-2" />
                        
                        <MudNavMenu Margin="Margin.Dense">
                            <MudNavLink Href="/settings" Icon="@Icons.Material.Filled.Settings" IconColor="Color.Primary">Einstellungen</MudNavLink>
                        </MudNavMenu>

                        <div class="user-status-card px-4 py-3 mt-2">
                            <div class="d-flex align-center mb-2">
                                <MudAvatar Color="Color.Secondary" Size="Size.Small" Class="mr-3">@_userInitials</MudAvatar>
                                <div class="d-flex flex-column">
                                    <MudText Typo="Typo.caption" Class="font-weight-bold">@_userName</MudText>
                                    <MudText Typo="Typo.caption" Style="font-size: 0.65rem; opacity: 0.7;">@_userRole</MudText>
                                </div>
                                <MudSpacer />
                                <MudIconButton Icon="@Icons.Material.Filled.Logout" Size="Size.Small" Color="Color.Error" OnClick="@Logout" />
                            </div>

                            <MudDivider Style="opacity: 0.3;" Class="my-2" />

                            @* System-Status Meldungen *@
                            <div class="status-row">
                                <div class="status-indicator online"></div>
                                <MudText Typo="Typo.caption" Style="font-size: 0.7rem;">API: <b>Online</b></MudText>
                                <MudSpacer />
                                <MudText Typo="Typo.caption" Style="font-size: 0.7rem; opacity: 0.5;">v2026.5</MudText>
                            </div>
                            <div class="status-row mt-1">
                                <div class="status-indicator online"></div>
                                <MudText Typo="Typo.caption" Style="font-size: 0.7rem;">Verbindung: <b>Gesichert</b></MudText>
                                <MudSpacer />
                                <div style="width: 24px;"></div>
                            </div>
                        </div>
                    </div>
                </div>
            </MudDrawer>

            <MudMainContent Class="main-content-fluid">
                <div style="padding: 0; height: 100%;">
                    @Body
                </div>
            </MudMainContent>
        </MudLayout>
    </Authorized>
    <NotAuthorized>
        @if (Nav.Uri.Contains("/login"))
        {
            @Body
        }
        else
        {
            <div class="d-flex justify-center align-center" style="height: 100vh; background-color: #f4f4f4;">
                <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
            </div>
        }
    </NotAuthorized>
</AuthorizeView>

<style>
    /* Header & Titelleiste */
    .header-logo { height: 32px; object-fit: contain; filter: brightness(0) invert(1); }
    .header-search-container { width: 400px; margin-right: 12px; }
    .header-search-input .mud-input { color: white !important; background-color: rgba(255,255,255,0.15) !important; border-radius: 4px; }
    .header-search-input .mud-input > input::placeholder { color: rgba(255,255,255,0.7) !important; }
    .header-search-input .mud-input-outlined-border { border-color: rgba(255,255,255,0.3) !important; }
    .header-search-input:hover .mud-input-outlined-border { border-color: white !important; }

    /* Layout Struktur für die Sidebar */
    .sidebar-wrapper { height: 100%; display: flex; flex-direction: column; overflow: hidden; }
    .sidebar-content { flex-grow: 1; overflow-y: auto; }
    .sidebar-footer { flex-shrink: 0; background-color: rgba(0,0,0,0.03); padding-bottom: 12px; }
    
    /* Status Bereich Styling */
    .user-status-card { background-color: rgba(0,0,0,0.02); border-radius: 8px; margin: 0 12px; border: 1px solid rgba(0,0,0,0.05); }
    .status-row { display: flex; align-items: center; gap: 8px; }
    .status-indicator { width: 8px; height: 8px; border-radius: 50%; }
    .status-indicator.online { background-color: #2e7d32; box-shadow: 0 0 4px #2e7d32; }
    
    /* Hauptinhaltsbereich */
    .main-content-fluid { min-height: 100vh; background-color: #fff; }
</style>

@code {
    private bool _drawerOpen = true;
    private bool _isDarkMode = false;
    private MudTheme _theme = new MudTheme();
    private string _userName = "User";
    private string _userEmail = "";
    private string _userRole = "Reader";
    private string _userInitials = "U";
    private string _globalSearchQuery = "";

    // AppbarStyle auf Dunkelgrau (#333333) fixiert
    private string AppbarStyle => $"background-color: #333333; color: white;";
    private string DrawerStyle => $"background-color: {(_isDarkMode ? "#161b22" : "#f8f9fa")}; border-right: 1px solid {(_isDarkMode ? "#30363d" : "#e0e0e0")};";

    protected override async Task OnInitializedAsync()
    {
        UpdateTheme();
        ThemeService.OnThemeChanged += UpdateTheme;

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity?.IsAuthenticated == true)
        {
            _userName = user.Identity.Name ?? "User";
            _userEmail = user.FindFirst(ClaimTypes.Email)?.Value ?? "";
            _userRole = user.FindFirst(ClaimTypes.Role)?.Value ?? "Reader";
            _userInitials = string.IsNullOrWhiteSpace(_userName) ? "U" : _userName.Substring(0, 1).ToUpper();
        }
        else
        {
            if (!Nav.Uri.Contains("/login")) Nav.NavigateTo("/login");
        }
    }

    private void HandleSearch(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(_globalSearchQuery))
        {
            Nav.NavigateTo($"/search?q={Uri.EscapeDataString(_globalSearchQuery)}");
            _globalSearchQuery = "";
        }
    }

    private void DrawerToggle() => _drawerOpen = !_drawerOpen;

    private void ToggleDarkMode()
    {
        var cfg = ThemeService.Config;
        cfg.IsDark = !cfg.IsDark;
        ThemeService.UpdateConfig(cfg);
    }

    private void UpdateTheme()
    {
        var cfg = ThemeService.Config;
        _isDarkMode = cfg.IsDark;
        var newTheme = new MudTheme();
        newTheme.PaletteLight.Primary = cfg.PrimaryColor;
        newTheme.PaletteLight.Background = "#ffffff";
        newTheme.PaletteLight.DrawerBackground = "#f8f9fa";
        
        newTheme.PaletteDark.Primary = cfg.PrimaryColor;
        newTheme.PaletteDark.Background = "#0d1117"; 
        newTheme.PaletteDark.Surface = "#161b22";
        newTheme.PaletteDark.DrawerBackground = "#161b22";
        _theme = newTheme;
        InvokeAsync(StateHasChanged);
    }

    private async Task Logout()
    {
        await AuthStateProvider.MarkUserAsLoggedOut();
        Nav.NavigateTo("/login");
    }

    public void Dispose() => ThemeService.OnThemeChanged -= UpdateTheme;
}