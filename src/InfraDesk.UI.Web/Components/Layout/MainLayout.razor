@* Dateipfad: src/InfraDesk.UI.Web/Components/Layout/MainLayout.razor *@
@namespace InfraDesk.UI.Web.Components.Layout
@inherits LayoutComponentBase
@using MudBlazor
@using InfraDesk.UI.Web.Services
@using Microsoft.AspNetCore.Components.Web
@inject ThemeService ThemeService
@inject NavigationManager Nav
@inject InfraDeskAuthStateProvider AuthStateProvider
@inject HttpClient Http
@implements IDisposable

<MudThemeProvider @bind-IsDarkMode="@_isDarkMode" Theme="_theme" />
<MudDialogProvider />
<MudSnackbarProvider />
<MudPopoverProvider />

<MudLayout>
    <MudAppBar Elevation="1" Style="@AppbarStyle">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="@((e) => DrawerToggle())" />
        <img src="InfraDesk_Logo.png" alt="InfraDesk Logo" style="height: 48px; margin-left: 8px; object-fit: contain; display: block; filter: brightness(0) invert(1);" />
        
        <MudSpacer />
        
        <!-- GLOBALE SUCHE (Leitet nun auf die Suchergebnis-Seite weiter) -->
        <MudTextField @bind-Value="_globalSearchQuery" 
                      Placeholder="Globale Suche (Enter)..." 
                      Variant="Variant.Outlined" 
                      Margin="Margin.Dense" 
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search"
                      AdornmentColor="Color.Inherit"
                      OnKeyDown="HandleSearch"
                      Immediate="true"
                      Style="background-color: rgba(255,255,255,0.15); border-radius: 4px; width: 350px; color: white;" 
                      Class="mr-4 mt-2 mb-2 global-search" />

        <MudIconButton Icon="@(_isDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)" Color="Color.Inherit" OnClick="ToggleDarkMode" Title="Design umschalten" />
        
        <MudMenu AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight" Class="ml-2">
            <ActivatorContent>
                <MudAvatar Color="Color.Secondary" Size="Size.Medium" Class="cursor-pointer font-weight-bold">@_userInitials</MudAvatar>
            </ActivatorContent>
            <ChildContent>
                <div class="px-4 py-3" style="min-width: 220px;">
                    <MudText Typo="Typo.subtitle2" Class="font-weight-bold">@_userName</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">@_userEmail</MudText>
                    <div class="mt-2">
                        <MudChip T="string" Size="Size.Small" Color="@GetRoleColor(_userRole)" Variant="Variant.Filled">@_userRole</MudChip>
                    </div>
                </div>
                <MudDivider />
                <MudMenuItem Icon="@Icons.Material.Filled.Settings" Href="/settings">Einstellungen</MudMenuItem>
                <MudDivider />
                <MudMenuItem Icon="@Icons.Material.Filled.Logout" OnClick="Logout" style="color: var(--mud-palette-error);">Abmelden</MudMenuItem>
            </ChildContent>
        </MudMenu>
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" Elevation="1" ClipMode="DrawerClipMode.Docked" Style="@DrawerStyle">
        <MudNavMenu Margin="Margin.Dense" Class="mt-4">
            <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Dashboard">Dashboard</MudNavLink>
            <MudNavGroup Title="Support & Helpdesk" Icon="@Icons.Material.Filled.HeadsetMic" Expanded="true">
                <MudNavLink Href="tickets" Icon="@Icons.Material.Filled.ConfirmationNumber">Ticket-Queue</MudNavLink>
            </MudNavGroup>
            <MudNavGroup Title="Infrastruktur" Icon="@Icons.Material.Filled.Computer" Expanded="true">
                <MudNavLink Href="assets" Icon="@Icons.Material.Filled.Dns">Asset-CMDB</MudNavLink>
                <MudNavLink Href="ipam" Icon="@Icons.Material.Filled.Router">IPAM / Netzwerke</MudNavLink>
            </MudNavGroup>
        </MudNavMenu>
    </MudDrawer>

    <MudMainContent Class="mud-main-content">
        <MudContainer MaxWidth="MaxWidth.False" Class="mud-container" Style="padding: 0; margin: 0; height: 100%;">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

<style>
    .mud-main-content { min-height: 100vh; display: flex; flex-direction: column; }
    .mud-container { padding-left: 0 !important; padding-right: 0 !important; }
    
    /* Globale Suche Styling-Anpassung in Appbar */
    .global-search .mud-input { color: white !important; }
    .global-search .mud-input > input::placeholder { color: rgba(255,255,255,0.7) !important; }
    .global-search .mud-input-outlined-border { border-color: rgba(255,255,255,0.3) !important; }
    .global-search:hover .mud-input-outlined-border { border-color: white !important; }
</style>

@code {
    private bool _drawerOpen = true;
    private bool _isDarkMode = false;
    private MudTheme _theme = new MudTheme();

    private string _userName = "User";
    private string _userEmail = "";
    private string _userRole = "Reader";
    private string _userInitials = "U";
    
    private string _globalSearchQuery = "";

    private string AppbarStyle => $"background-color: {(_isDarkMode ? "#0d1117" : ThemeService.Config.AppbarColor)}; color: {ThemeService.Config.AppbarText};";
    private string DrawerStyle => $"background-color: {(_isDarkMode ? "#161b22" : ThemeService.Config.DrawerColor)};";

    protected override async Task OnInitializedAsync()
    {
        UpdateTheme();
        ThemeService.OnThemeChanged += UpdateTheme;

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity?.IsAuthenticated == true)
        {
            _userName = user.Identity.Name ?? "User";
            _userEmail = user.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value ?? "";
            _userRole = user.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "Reader";
            _userInitials = string.IsNullOrWhiteSpace(_userName) ? "U" : _userName.Substring(0, 1).ToUpper();
        }
    }

    private void HandleSearch(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(_globalSearchQuery))
        {
            Nav.NavigateTo($"/search?q={Uri.EscapeDataString(_globalSearchQuery)}");
        }
    }

    private Color GetRoleColor(string role) => role switch {
        "Global Admin" => Color.Error,
        "Tenant Admin" => Color.Warning,
        "CI Editor" => Color.Success,
        _ => Color.Info
    };

    private void DrawerToggle() => _drawerOpen = !_drawerOpen;

    private void ToggleDarkMode()
    {
        var cfg = ThemeService.Config;
        cfg.IsDark = !cfg.IsDark;
        ThemeService.UpdateConfig(cfg);
    }

    private void UpdateTheme()
    {
        var cfg = ThemeService.Config;
        _isDarkMode = cfg.IsDark;

        var newTheme = new MudTheme();
        newTheme.PaletteLight.Primary = cfg.PrimaryColor;
        newTheme.PaletteLight.Secondary = cfg.SecondaryColor;
        newTheme.PaletteLight.Background = cfg.BackgroundColor;
        newTheme.PaletteLight.Surface = cfg.SurfaceColor;
        newTheme.PaletteLight.TextPrimary = cfg.TextPrimary;
        newTheme.PaletteLight.ActionDefault = cfg.PrimaryColor;
        
        newTheme.PaletteDark.Primary = cfg.PrimaryColor;
        newTheme.PaletteDark.Background = "#0d1117"; 
        newTheme.PaletteDark.Surface = "#161b22";
        newTheme.PaletteDark.TextPrimary = "#c9d1d9";
        newTheme.PaletteDark.ActionDefault = cfg.PrimaryColor;
        
        if (!string.IsNullOrWhiteSpace(cfg.FontFamily))
        {
            newTheme.Typography.Default.FontFamily = new[] { cfg.FontFamily };
            newTheme.Typography.Default.FontSize = $"{cfg.BaseFontSize}px";
        }
        
        _theme = newTheme;
        InvokeAsync(StateHasChanged);
    }

    private async Task Logout()
    {
        await AuthStateProvider.MarkUserAsLoggedOut();
        Nav.NavigateTo("/login");
    }

    public void Dispose() => ThemeService.OnThemeChanged -= UpdateTheme;
}