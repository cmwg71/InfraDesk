<Page
    x:Class="InfraDesk.UI.WinUI.Views.AssetDetailPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:entities="using:InfraDesk.Core.Entities"
    xmlns:views="using:InfraDesk.UI.WinUI.Views"
    mc:Ignorable="d">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <!-- Definition der Edit-Zustände für das UI-Umschalten -->
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup x:Name="EditStates">
                <VisualState x:Name="ReadOnly">
                    <VisualState.Setters>
                        <Setter Target="EditButton.Visibility" Value="Visible"/>
                        <Setter Target="SaveButton.Visibility" Value="Collapsed"/>
                        <Setter Target="CancelButton.Visibility" Value="Collapsed"/>
                    </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="EditMode">
                    <VisualState.Setters>
                        <Setter Target="EditButton.Visibility" Value="Collapsed"/>
                        <Setter Target="SaveButton.Visibility" Value="Visible"/>
                        <Setter Target="CancelButton.Visibility" Value="Visible"/>
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Header -->
            <RowDefinition Height="*"/>    <!-- Content -->
        </Grid.RowDefinitions>

        <!-- Header Bereich mit Navigation und Aktionen -->
        <Grid Grid.Row="0" Padding="24,20" Background="{ThemeResource LayerFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Zurück-Button -->
            <Button Grid.Column="0" Content="&#xE72B;" FontFamily="Segoe Fluent Icons" Click="GoBack_Click" Style="{StaticResource SubtleButtonStyle}" VerticalAlignment="Center" Margin="0,0,16,0"/>
            
            <!-- Logo und Titel -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="15">
                <FontIcon Glyph="&#xE950;" FontSize="32" Foreground="{ThemeResource SystemAccentColor}"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{x:Bind SelectedAsset.Name, Mode=OneWay}" Style="{StaticResource TitleTextBlockStyle}" FontWeight="Bold"/>
                    <TextBlock Text="{x:Bind SelectedAsset.InventoryNumber, Mode=OneWay}" Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.7"/>
                </StackPanel>
            </StackPanel>

            <!-- Aktions-Buttons -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                <Button x:Name="EditButton" Click="ToggleEdit_Click" Style="{StaticResource AccentButtonStyle}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE70F;" FontSize="14"/>
                        <TextBlock Text="Bearbeiten"/>
                    </StackPanel>
                </Button>
                <Button x:Name="SaveButton" Content="Speichern" Click="SaveAsset_Click" Style="{StaticResource AccentButtonStyle}" Visibility="Collapsed"/>
                <Button x:Name="CancelButton" Content="Abbrechen" Click="ToggleEdit_Click" Visibility="Collapsed"/>
            </StackPanel>
        </Grid>

        <!-- Hauptnavigation (Tabs) -->
        <NavigationView Grid.Row="1" x:Name="DetailNav" PaneDisplayMode="Top" IsSettingsVisible="False" IsBackButtonVisible="Collapsed" SelectionChanged="DetailNav_SelectionChanged">
            <NavigationView.MenuItems>
                <NavigationViewItem Content="Allgemein" Tag="General" Icon="ContactInfo" />
                <NavigationViewItem Content="Hardware" Tag="Hardware" Icon="Repair" />
                <NavigationViewItem Content="Netzwerk" Tag="Network" Icon="World" />
                <NavigationViewItem Content="Historie" Tag="History" Icon="History" />
                <NavigationViewItem Content="Beziehungen" Tag="Links" Icon="Link" />
            </NavigationView.MenuItems>

            <ScrollViewer Padding="24">
                <Grid>
                    <!-- Hier wird der Content der Tabs injiziert -->
                    <ContentControl x:Name="DetailContentPresenter" HorizontalContentAlignment="Stretch"/>
                    
                    <!-- Globaler Lade-Indikator -->
                    <ProgressRing x:Name="IsLoadingOverlay" IsActive="False" Visibility="Collapsed" Width="64" Height="64" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Grid>
            </ScrollViewer>
        </NavigationView>

        <!-- Ressourcen für die Tab-Inhalte -->
        <Grid.Resources>
            <!-- WICHTIG: x:DataType ist entscheidend für den XAML-Compiler -->
            <DataTemplate x:Key="GeneralTemplate" x:DataType="views:AssetDetailPage">
                <StackPanel Spacing="24" MaxWidth="800">
                    <Grid Background="{ThemeResource LayerFillColorDefaultBrush}" CornerRadius="8" Padding="24" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                        <StackPanel Spacing="16">
                            <TextBlock Text="Stammdaten" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                            
                            <Grid RowSpacing="12" ColumnSpacing="20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Text="Asset Name" VerticalAlignment="Center" Opacity="0.6"/>
                                <TextBox Grid.Row="0" Grid.Column="1" Text="{x:Bind SelectedAsset.Name, Mode=TwoWay}" IsReadOnly="{x:Bind IsReadOnlyMode, Mode=OneWay}"/>

                                <TextBlock Grid.Row="1" Text="Inventarnummer" VerticalAlignment="Center" Opacity="0.6"/>
                                <TextBox Grid.Row="1" Grid.Column="1" Text="{x:Bind SelectedAsset.InventoryNumber, Mode=TwoWay}" IsReadOnly="{x:Bind IsReadOnlyMode, Mode=OneWay}"/>

                                <TextBlock Grid.Row="2" Text="Standort" VerticalAlignment="Center" Opacity="0.6"/>
                                <ComboBox Grid.Row="2" Grid.Column="1" HorizontalAlignment="Stretch"
                                          ItemsSource="{x:Bind AvailableLocations, Mode=OneWay}"
                                          DisplayMemberPath="Name"
                                          SelectedValuePath="Id"
                                          IsEnabled="{x:Bind IsEditMode, Mode=OneWay}"
                                          SelectedValue="{x:Bind SelectedAsset.LocationId, Mode=TwoWay}"/>

                                <TextBlock Grid.Row="3" Text="Verantwortlich" VerticalAlignment="Center" Opacity="0.6"/>
                                <ComboBox Grid.Row="3" Grid.Column="1" HorizontalAlignment="Stretch"
                                          ItemsSource="{x:Bind AvailablePeople, Mode=OneWay}"
                                          DisplayMemberPath="LastName"
                                          SelectedValuePath="Id"
                                          IsEnabled="{x:Bind IsEditMode, Mode=OneWay}"
                                          SelectedValue="{x:Bind SelectedAsset.OwnerId, Mode=TwoWay}"/>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </DataTemplate>
        </Grid.Resources>
    </Grid>
</Page>