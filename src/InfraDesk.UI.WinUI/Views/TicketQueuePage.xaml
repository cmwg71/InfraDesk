<Page
    x:Class="InfraDesk.UI.WinUI.Views.TicketQueuePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:entities="using:InfraDesk.Core.Entities"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    xmlns:converters="using:InfraDesk.UI.WinUI.Converters"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:TicketColorConverter x:Key="TicketColorConverter"/>
        <converters:ReverseBooleanConverter x:Key="ReverseBooleanConverter"/>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header Bereich -->
        <Grid Grid.Row="0" Padding="24,24,24,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Spacing="4">
                <TextBlock Text="Ticket-Queue" Style="{StaticResource TitleTextBlockStyle}" FontWeight="Bold"/>
                <TextBlock Text="Verwalten Sie hier alle Anfragen für Ihren Mandanten." 
                           Style="{StaticResource BodyTextBlockStyle}" Opacity="0.7"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                <!-- Spaltenauswahl -->
                <AppBarButton Icon="ViewAll" Label="Spalten" Visibility="{x:Bind ViewTableBtn.IsChecked, Mode=OneWay}">
                    <AppBarButton.Flyout>
                        <MenuFlyout>
                            <ToggleMenuFlyoutItem x:Name="ColIdVisible" Text="ID" IsChecked="False"/>
                            <ToggleMenuFlyoutItem x:Name="ColDescVisible" Text="Beschreibung" IsChecked="True"/>
                            <ToggleMenuFlyoutItem x:Name="ColDateVisible" Text="Datum" IsChecked="False"/>
                        </MenuFlyout>
                    </AppBarButton.Flyout>
                </AppBarButton>

                <!-- Ansichts-Umschalter -->
                <StackPanel Orientation="Horizontal" Background="{ThemeResource LayerFillColorDefaultBrush}" 
                            CornerRadius="8" Padding="4" Spacing="4" VerticalAlignment="Center" 
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">

                    <ToggleButton x:Name="ViewCardsBtn" 
                                  IsChecked="True" 
                                  Content="&#xEA37;" 
                                  FontFamily="Segoe Fluent Icons" 
                                  Padding="12,8" 
                                  ToolTipService.ToolTip="Kartenansicht"/>

                    <ToggleButton x:Name="ViewTableBtn" 
                                  IsChecked="{Binding IsChecked, ElementName=ViewCardsBtn, Converter={StaticResource ReverseBooleanConverter}, Mode=TwoWay}" 
                                  Content="&#xE8EF;" 
                                  FontFamily="Segoe Fluent Icons" 
                                  Padding="12,8" 
                                  ToolTipService.ToolTip="Tabellenansicht"/>
                </StackPanel>
            </StackPanel>
        </Grid>

        <!-- HAUPTINHALT -->
        <Grid Grid.Row="1">

            <!-- KARTEN-ANSICHT (ListView) -->
            <ListView ItemsSource="{x:Bind ViewModel.Tickets, Mode=OneWay}"
                      Visibility="{x:Bind ViewCardsBtn.IsChecked, Mode=OneWay}"
                      SelectionMode="None" 
                      Padding="24,0,24,24">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Margin" Value="0,0,0,12"/>
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="entities:Ticket">
                        <Grid Background="{ThemeResource LayerFillColorDefaultBrush}" 
                              BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                              BorderThickness="1" 
                              CornerRadius="8" 
                              Padding="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Spacing="8">
                                <TextBlock Text="{x:Bind Title}" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                                <TextBlock Text="{x:Bind Description}" Style="{StaticResource CaptionTextBlockStyle}" MaxLines="1" Opacity="0.8"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <Border Background="{x:Bind Priority, Converter={StaticResource TicketColorConverter}, ConverterParameter=priority}" 
                                        CornerRadius="4" Padding="10,4">
                                    <TextBlock Text="{x:Bind Priority}" Foreground="White" FontSize="11" FontWeight="Bold"/>
                                </Border>
                                <Border Background="{x:Bind Status, Converter={StaticResource TicketColorConverter}, ConverterParameter=status}" 
                                        CornerRadius="4" Padding="10,4">
                                    <TextBlock Text="{x:Bind Status}" Foreground="White" FontSize="11" FontWeight="Bold"/>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- TABELLEN-ANSICHT (DataGrid) -->
            <controls:DataGrid x:Name="TicketDataGrid"
                               ItemsSource="{x:Bind ViewModel.Tickets, Mode=OneWay}"
                               Visibility="{x:Bind ViewTableBtn.IsChecked, Mode=OneWay}"
                               AutoGenerateColumns="False" 
                               CanUserSortColumns="True" 
                               IsReadOnly="True"
                               GridLinesVisibility="Horizontal" 
                               Margin="24,0,24,24"
                               Background="{ThemeResource LayerFillColorDefaultBrush}" 
                               BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                               BorderThickness="1" 
                               CornerRadius="8">
                <controls:DataGrid.Columns>
                    <controls:DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="100" 
                                                 Visibility="{x:Bind ColIdVisible.IsChecked, Mode=OneWay}"/>
                    <controls:DataGridTextColumn Header="Titel" Binding="{Binding Title}" Width="*"/>
                    <controls:DataGridTextColumn Header="Beschreibung" Binding="{Binding Description}" Width="2*" 
                                                 Visibility="{x:Bind ColDescVisible.IsChecked, Mode=OneWay}"/>
                    <controls:DataGridTemplateColumn Header="Priorität" Width="140">
                        <controls:DataGridTemplateColumn.CellTemplate>
                            <DataTemplate x:DataType="entities:Ticket">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0">
                                    <Ellipse Width="10" Height="10" Fill="{x:Bind Priority, Converter={StaticResource TicketColorConverter}, ConverterParameter=priority}" Margin="0,0,8,0"/>
                                    <TextBlock Text="{x:Bind Priority}"/>
                                </StackPanel>
                            </DataTemplate>
                        </controls:DataGridTemplateColumn.CellTemplate>
                    </controls:DataGridTemplateColumn>
                    <controls:DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="120"/>
                    <controls:DataGridTextColumn Header="Erstellt am" Binding="{Binding CreatedAt}" Width="150" 
                                                 Visibility="{x:Bind ColDateVisible.IsChecked, Mode=OneWay}"/>
                </controls:DataGrid.Columns>
            </controls:DataGrid>
        </Grid>
    </Grid>
</Page>