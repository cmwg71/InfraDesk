<Page
    x:Class="InfraDesk.UI.WinUI.Views.AssetPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:entities="using:InfraDesk.Core.Entities"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    xmlns:converters="using:InfraDesk.UI.WinUI.Converters"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:ReverseBooleanConverter x:Key="ReverseBooleanConverter"/>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header Bereich -->
        <Grid Grid.Row="0" Padding="24,24,24,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Spacing="4">
                <TextBlock Text="Asset-CMDB" Style="{StaticResource TitleTextBlockStyle}" FontWeight="Bold"/>
                <TextBlock Text="Zentrale Verwaltung Ihrer Hardware-Assets." Style="{StaticResource BodyTextBlockStyle}" Opacity="0.7"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Background="{ThemeResource LayerFillColorDefaultBrush}" 
                            CornerRadius="8" Padding="4" Spacing="4" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                    <ToggleButton x:Name="ViewCardsBtn" IsChecked="True" Content="&#xEA37;" FontFamily="Segoe Fluent Icons" Padding="12,8"/>
                    <ToggleButton x:Name="ViewTableBtn" IsChecked="{Binding IsChecked, ElementName=ViewCardsBtn, Converter={StaticResource ReverseBooleanConverter}, Mode=TwoWay}" 
                                  Content="&#xE8EF;" FontFamily="Segoe Fluent Icons" Padding="12,8"/>
                </StackPanel>
            </StackPanel>
        </Grid>

        <!-- Content Bereich -->
        <Grid Grid.Row="1">
            <!-- Kartenansicht -->
            <ListView ItemsSource="{x:Bind ViewModel.Assets, Mode=OneWay}"
                      Visibility="{x:Bind ViewCardsBtn.IsChecked, Mode=OneWay}"
                      Padding="24,0,24,24" SelectionMode="None">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="entities:Asset">
                        <!-- KORREKTUR: Margin-Wert gefixt (kein 'autor' mehr) -->
                        <Grid Background="{ThemeResource LayerFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                              BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="64"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <FontIcon Glyph="&#xE9F5;" FontSize="32" VerticalAlignment="Center" Foreground="{ThemeResource SystemAccentColor}"/>

                            <StackPanel Grid.Column="1" Spacing="4" Margin="16,0,0,0">
                                <TextBlock Text="{x:Bind Name}" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                                <TextBlock Text="{x:Bind InventoryNumber}" Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.6"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                <Button Content="Details" Style="{StaticResource AccentButtonStyle}"/>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- Tabellenansicht (DataGrid) -->
            <controls:DataGrid ItemsSource="{x:Bind ViewModel.Assets, Mode=OneWay}"
                               Visibility="{x:Bind ViewTableBtn.IsChecked, Mode=OneWay}"
                               AutoGenerateColumns="False" IsReadOnly="True" Margin="24,0,24,24"
                               GridLinesVisibility="Horizontal" Background="{ThemeResource LayerFillColorDefaultBrush}" 
                               BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <controls:DataGrid.Columns>
                    <controls:DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                    <controls:DataGridTextColumn Header="Seriennummer" Binding="{Binding SerialNumber}" Width="150"/>
                    <controls:DataGridTextColumn Header="Inventarnummer" Binding="{Binding InventoryNumber}" Width="150"/>
                </controls:DataGrid.Columns>
            </controls:DataGrid>
        </Grid>
    </Grid>
</Page>